    "ma_home_risk": {
      "type": "ma-home-risk",
      "settings": {
        "eyebrow": "Buy Without a Doubt",
        "heading": "The Maison Promise",
        "subline": "Wear it first. Decide after. A scent is personal — you should never commit to one you haven't lived with.",
        "k1": "The Tester",
        "t1": "A Tester in Every Order",
        "d1": "Live with the scent for days before you ever break the seal on the bottle.",
        "k2": "The Return",
        "t2": "Seven Days to Decide",
        "d2": "Return the sealed bottle within seven days for a full refund. No questions asked.",
        "k3": "The Climate",
        "t3": "Crafted for India",
        "d3": "Built for Indian skin, heat and humidity — not London winters.",
        "k4": "The Formula",
        "t4": "The Oil is Everything",
        "d4": "Most of what you pay goes into the oil — not the bottle, the box, or the campaign.",
        "sign": "The house takes the risk."
      }
    },
    "ma_home_proof": {
      "type": "ma-home-proof",
      "settings": {
        "a_big": "30% Extrait",
