    "custom_liquid_hmfTtV": {
      "type": "custom-liquid",
      "name": "WORN BY THOSE WHO ARRIVE FIRST",
      "settings": {
        "custom_liquid": "<style>\n  .ma-banner {\n    position: relative;\n    width: 100%;\n    background-color: #0e1a2c;\n    line-height: 0;\n    overflow: visible;\n    cursor: pointer;\n  }\n\n  .ma-banner img.ma-banner__img {\n    display: block !important;\n    width: 100% !important;\n    height: auto !important;\n    max-width: 100% !important;\n    min-height: 0 !important;\n    max-height: none !important;\n    object-fit: contain !important;\n    aspect-ratio: auto !important;\n  }\n\n  .ma-banner__text {\n    position: absolute;\n    z-index: 2;\n    line-height: 1;\n    display: flex;\n    flex-direction: column;\n  }\n\n  .ma-banner__eyebrow {\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    font-weight: 500;\n    letter-spacing: 0.28em;\n    text-transform: uppercase;\n    color: rgba(255, 255, 255, 0.70);\n    margin: 0;\n  }\n\n  .ma-banner__headline {\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    font-weight: 400;\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n    line-height: 1.22;\n    color: #ffffff;\n    margin: 0;\n  }\n\n  .ma-banner__sub {\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    font-weight: 300;\n    letter-spacing: 0.02em;\n    line-height: 1.55;\n    color: rgba(255, 255, 255, 0.80);\n    margin: 0;\n  }\n\n  .ma-banner__shop {\n    display: inline-block;\n    color: #ffffff;\n    text-decoration: none;\n    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n    font-weight: 500;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    padding-bottom: 6px;\n    border-bottom: 1px solid rgba(255, 255, 255, 0.9);\n    transition: color 0.25s ease, border-bottom-color 0.25s ease;\n    -webkit-tap-highlight-color: transparent;\n  }\n  .ma-banner__shop:hover { color: #aaaaaa; border-bottom-color: #aaaaaa; }\n\n  /* DESKTOP */\n  @media (min-width: 768px) {\n    .ma-banner__text {\n      top: 50%;\n      left: 7%;\n      transform: translateY(-50%);\n      width: 40%;\n      align-items: flex-start;\n      text-align: left;\n    }\n    .ma-banner__eyebrow  { font-size: 15px;  margin-bottom: 20px; }\n    .ma-banner__headline { font-size: clamp(36px, 3.6vw, 58px); margin-bottom: 22px; max-width: 9em; }\n    .ma-banner__sub      { font-size: 19px;  margin-bottom: 34px; max-width: 360px; }\n    .ma-banner__shop     { font-size: 14px; }\n    .ma-banner__m { display: none; }\n  }\n\n  /* MOBILE */\n  @media (max-width: 767px) {\n    .ma-banner::after {\n      content: '';\n      position: absolute;\n      left: 0; right: 0; bottom: 0;\n      height: 42%;\n      z-index: 1;\n      pointer-events: none;\n      background: linear-gradient(\n        to top,\n        rgba(10, 18, 32, 0.92) 0%,\n        rgba(10, 18, 32, 0.55) 45%,\n        rgba(10, 18, 32, 0.0) 100%\n      );\n    }\n    .ma-banner__text {\n      left: 22px;\n      right: 22px;\n      bottom: 24px;\n      align-items: center;\n      text-align: center;\n    }\n    .ma-banner__eyebrow  { font-size: 12px; letter-spacing: 0.24em; margin-bottom: 11px; }\n    .ma-banner__headline { font-size: 22px; margin-bottom: 12px; }\n    .ma-banner__sub      { font-size: 14px; margin-bottom: 18px; }\n    .ma-banner__shop     { font-size: 13px; padding-bottom: 5px; }\n    .ma-banner__d { display: none; }\n  }\n</style>\n\n<section class=\"ma-banner\">\n\n  <picture>\n    <source media=\"(max-width: 767px)\" srcset=\"{{ 'ma-iconic-mobile.jpg' | asset_url }}\">\n    <img class=\"ma-banner__img\"\n         style=\"display:block !important; width:100% !important; height:auto !important; max-height:none !important; object-fit:contain !important; aspect-ratio:auto !important;\"\n         src=\"https://cdn.shopify.com/s/files/1/0979/6553/9647/files/Hero.jpg?v=1782406611\"\n         alt=\"The Iconic Collection — Maison Amiir\">\n  </picture>\n\n  <div class=\"ma-banner__text\">\n    <p class=\"ma-banner__eyebrow\">The Iconic Collection</p>\n    <h2 class=\"ma-banner__headline\">Worn by those who arrive first.</h2>\n\n    <p class=\"ma-banner__sub ma-banner__d\">Extrait De Parfum. Crafted without compromise.\nOne unmistakable signature.</p>\n    <a class=\"ma-banner__shop ma-banner__d\" href=\"/collections/new-arrivals\">Shop the Collection</a>\n\n    <p class=\"ma-banner__sub ma-banner__m\">Extrait de parfum. One unmistakable signature.</p>\n    <a class=\"ma-banner__shop ma-banner__m\" href=\"/collections/new-arrivals\">Shop Now</a>\n  </div>\n\n</section>\n\n<script>\n  document.querySelector('.ma-banner').addEventListener('click', function(e) {\n    if (!e.target.closest('a')) {\n      window.location.href = '/collections/new-arrivals';\n    }\n  });\n</script>",
