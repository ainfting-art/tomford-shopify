            "custom_liquid": "<style>\n.hero__media-grid{display:none!important}\n.hero{position:relative;height:100vh!important;min-height:100vh!important;overflow:hidden;margin:0!important;padding:0!important}\n.hero-wrapper,.section-wrapper,.hero .section,.hero__container{margin:0!important;padding:0!important;border:0!important}\n.hero__content-wrapper{display:none!important}\n.custom-hero-video{position:absolute;inset:0;width:100%;height:100%;z-index:1;cursor:pointer}\n.custom-hero-video video{width:100%;height:100%;object-fit:cover}\n.mobile-video{display:none}\n@media(max-width:770px){.desktop-video{display:none}.mobile-video{display:block}}\n\n.hero-overlay-gradient{position:absolute;inset:0;z-index:2;pointer-events:none;background:linear-gradient(to bottom,rgba(0,0,0,.12) 0%,rgba(0,0,0,0) 28%,rgba(0,0,0,0) 48%,rgba(0,0,0,.45) 78%,rgba(0,0,0,.6) 100%)}\n\n.hero-overlay-scrim{position:absolute;left:3%;bottom:10%;transform:translateY(28%);width:680px;max-width:88%;height:420px;z-index:2;pointer-events:none;background:radial-gradient(ellipse at 30% 60%,rgba(0,0,0,.52) 0%,rgba(0,0,0,.38) 38%,rgba(0,0,0,.16) 62%,rgba(0,0,0,0) 80%)}\n@media(max-width:770px){.hero-overlay-scrim{left:2%;bottom:15%;height:340px;transform:translateY(30%)}}\n\n.hero-overlay-content{position:absolute;left:5%;right:auto;bottom:14%;z-index:3;text-align:left;padding:0;pointer-events:none;max-width:520px}\n.hero-overlay-content *{pointer-events:auto}\n.hero-overlay-headline{color:#fff;font-family:var(--font-primary--family),'Bodoni Moda',Didot,'Times New Roman',serif;font-weight:400;font-size:48px;line-height:1.08;letter-spacing:.02em;margin:0 0 16px;text-shadow:0 2px 22px rgba(0,0,0,.4)}\n.hero-overlay-subline{color:#f3f3f3;font-size:14px;letter-spacing:.2em;text-transform:uppercase;margin:0 0 30px;text-shadow:0 1px 14px rgba(0,0,0,.5)}\n.hero-overlay-cta{display:inline-block;color:#fff;border:1px solid rgba(255,255,255,.9);background:rgba(0,0,0,.12);backdrop-filter:blur(2px);padding:15px 44px;font-size:12px;letter-spacing:.22em;text-transform:uppercase;text-decoration:none;transition:background .3s ease,color .3s ease}\n.hero-overlay-cta:hover{background:#fff;color:#1a1a1a}\n@media(max-width:770px){\n  .hero-overlay-content{left:5%;right:5%;bottom:18%;max-width:none;text-align:left}\n  .hero-overlay-headline{font-size:33px;margin-bottom:12px}\n  .hero-overlay-subline{font-size:11px;letter-spacing:.16em;margin-bottom:22px}\n  .hero-overlay-cta{padding:13px 34px;font-size:11px}\n}\n\n.mute-toggle{position:absolute;bottom:20px;right:16px;z-index:4;background:none;border:none;padding:4px;cursor:pointer;display:flex;align-items:center;justify-content:center}\n.mute-toggle svg{width:22px;height:22px;display:block;filter:drop-shadow(0 1px 6px rgba(0,0,0,.6));transition:opacity .2s ease}\n.mute-toggle:hover svg{opacity:.75}\n@media(max-width:770px){.mute-toggle{bottom:16px;right:12px}.mute-toggle svg{width:20px;height:20px}}\n</style>\n\n<div class=\"custom-hero-video\">\n  <video class=\"desktop-video\" autoplay loop muted playsinline data-src=\"https://cdn.shopify.com/videos/c/o/v/fbfa22cb1b0d4e51b748da7e06db1f85.mp4\"></video>\n  <video class=\"mobile-video\" autoplay loop muted playsinline data-src=\"https://cdn.shopify.com/videos/c/o/v/2530bf3f1b634feba91cc6a29f9c0076.mp4\"></video>\n  <script>(function(){var m=window.matchMedia('(max-width: 770px)').matches;var v=document.querySelector(m?'.custom-hero-video .mobile-video':'.custom-hero-video .desktop-video');if(v&&!v.getAttribute('src')){v.setAttribute('src',v.getAttribute('data-src'));v.load();var p=v.play();if(p&&p.catch)p.catch(function(){});}})();</script>\n\n  <div class=\"hero-overlay-gradient\"></div>\n  <div class=\"hero-overlay-scrim\"></div>\n  <div class=\"hero-overlay-content\">\n    <h1 class=\"hero-overlay-headline\">The Art of Quiet Luxury</h1>\n    <p class=\"hero-overlay-subline\">Extrait fragrances, crafted in limited batches</p>\n    <a href=\"/collections/all-perfumes?page=2\" class=\"hero-overlay-cta\">Explore the Collection</a>\n  </div>\n\n  <button class=\"mute-toggle\" aria-label=\"Toggle mute\">\n    <svg class=\"icon-unmuted\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"display:none\">\n      <polygon points=\"11 5 6 9 2 9 2 15 6 15 11 19 11 5\"/>\n      <path d=\"M19.07 4.93a10 10 0 0 1 0 14.14\"/>\n      <path d=\"M15.54 8.46a5 5 0 0 1 0 7.07\"/>\n    </svg>\n    <svg class=\"icon-muted\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n      <polygon points=\"11 5 6 9 2 9 2 15 6 15 11 19 11 5\"/>\n      <line x1=\"23\" y1=\"9\" x2=\"17\" y2=\"15\"/>\n      <line x1=\"17\" y1=\"9\" x2=\"23\" y2=\"15\"/>\n    </svg>\n  </button>\n</div>\n\n<script>function getActiveVideo(){return window.innerWidth<=768?document.querySelector('.mobile-video'):document.querySelector('.desktop-video')}function updateIcons(m){var b=document.querySelector('.mute-toggle');if(!b)return;var im=b.querySelector('.icon-muted'),iu=b.querySelector('.icon-unmuted');if(m){im.style.display=\"block\";iu.style.display=\"none\"}else{im.style.display=\"none\";iu.style.display=\"block\"}}function toggleMuteState(){var v=getActiveVideo();if(!v)return;v.muted=!v.muted;if(!v.muted)v.volume=1;updateIcons(v.muted)}function handleVideos(){var a=getActiveVideo();document.querySelectorAll('.custom-hero-video video').forEach(function(v){v===a?v.play().catch(function(){}):v.pause()});if(a)updateIcons(a.muted)}document.querySelector('.custom-hero-video').addEventListener('click',function(e){if(e.target.closest('.hero-overlay-cta'))return;toggleMuteState()});document.querySelector('.mute-toggle').addEventListener('click',function(e){e.stopPropagation();toggleMuteState()});document.addEventListener(\"DOMContentLoaded\",handleVideos);window.addEventListener(\"resize\",handleVideos);</script>"
