ize":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"text_KXEeBp":{"type":"text","name":"t:names.text","settings":{"text":"<p>Maison Amiir ensures premium packaging, safe handling, and smooth delivery for every order.<br\/>1. Dispatch Time<br\/>Orders are processed and shipped within 1–3 working days of payment confirmation.<br\/>2. Shipping Charges<br\/>Shipping charges are displayed at checkout and may vary based on your delivery location.<br\/>3. Delivery Timeline<br\/><br\/>Metro cities: 3–6 working days<br\/>Non-metro cities & towns: 5–9 working days<br\/><br\/>4. No Cash on Delivery<br\/>Maison Amiir does not offer Cash on Delivery. All orders must be prepaid.<br\/>5. Domestic Shipping Only<br\/>We currently deliver only within India. International shipping is not available at this time.<br\/>6. Order Tracking<br\/>Once your order is shipped, you will receive a tracking link via WhatsApp or SMS.<br\/>7. Courier Damage Protocol<br\/>If your product arrives damaged, you must contact our customer support within 24 hours of delivery. Please provide:<br\/><br\/>An unboxing video (start to end, without interruption)<br\/>Clear photos of the damaged product and packaging<br\/>Proof of damage submitted within 24 hours of delivery<br\/><br\/>Failure to provide the above within the stipulated time may result in your claim being declined.<br\/>8. Replacement & Refund for Transit Damage<br\/><br\/>Replacement will be arranged at no extra charge upon verification of the damage.<br\/>Refund will be issued only if the product cannot be replaced (out of stock), processed within 3–7 working days.<\/p>","width":"100%","max_width":"none","alignment":"left","type_preset":"rte","font":"var(--font-body--family)","font_size":"1rem","line_