{% comment %}
  MAISON AMIIR — launch veil, shown on EVERY page load (Neesh-style).
  Cream overlay + logo paints before content, hides when the DOM is ready
  (min 800ms so it never blinks, max 2600ms so it never traps), and rises
  again the instant a same-origin link is clicked so the browser's white
  flash between pages is always covered.
  Must stay inline in the layout: it has to paint before anything else.
{% endcomment %}
{%- unless request.design_mode -%}
<div id="ma-splash" aria-hidden="true">
  <div class="ma-splash__inner">
    {%- if settings.logo != blank -%}
      <img class="ma-splash__logo" src="{{ settings.logo | image_url: width: 480 }}" alt="{{ shop.name | escape }}" width="240" height="auto">
    {%- else -%}
      <p class="ma-splash__word">MAISON&nbsp;AMIIR</p>
    {%- endif -%}
    <div class="ma-splash__line"></div>
  </div>
</div>
<noscript><style>#ma-splash { display: none !important; }</style></noscript>
<style>
  #ma-splash {
    position: fixed; inset: 0; z-index: 100000;
    background: #F7F3EA;
    display: flex; align-items: center; justify-content: center;
    opacity: 1;
    transition: opacity .5s ease;
  }
  #ma-splash.is-hidden {
    opacity: 0; visibility: hidden; pointer-events: none;
    transition: opacity .5s ease, visibility 0s linear .5s;
  }
  #ma-splash.is-fast { transition: opacity .22s ease; }
  html.ma-splash-lock { overflow: hidden; }

  .ma-splash__inner { text-align: center; padding: 0 1.5rem; }
  .ma-splash__logo {
    display: block; margin: 0 auto; width: min(210px, 52vw); height: auto;
    opacity: 0;
    animation: maSplashIn .55s ease .05s forwards;
  }
  .ma-splash__word {
    margin: 0;
    font-family: 'Sinoreta', Georgia, serif; font-weight: 300;
    font-size: clamp(1.7rem, 5vw, 2.4rem); letter-spacing: .22em; text-indent: .22em;
    color: #171410;
    opacity: 0;
    animation: maSplashIn .55s ease .05s forwards;
  }
  .ma-splash__line {
    width: 0; height: 1px; margin: 1.4rem auto 0;
    background: linear-gradient(90deg, transparent, #A8894E 30%, #E7C98B 50%, #A8894E 70%, transparent);
    animation: maSplashLine 1s ease .25s forwards;
  }
  @keyframes maSplashIn { to { opacity: 1; } }
  @keyframes maSplashLine { to { width: min(170px, 42vw); } }

  @media (prefers-reduced-motion: reduce) {
    .ma-splash__logo, .ma-splash__word { animation: none; opacity: 1; }
    .ma-splash__line { animation: none; width: min(170px, 42vw); }
    #ma-splash { transition-duration: .25s; }
  }
</style>
<script>
  (function () {
    var el = document.getElementById('ma-splash');
    if (!el) return;
    var html = document.documentElement;
    html.classList.add('ma-splash-lock');

    var t0 = Date.now();
    var MIN = 800;  /* never a blink */
    var MAX = 2600; /* never a trap */
    var done = false;
    var hideTimer = null;

    function reallyHide() {
      el.classList.add('is-hidden');
      html.classList.remove('ma-splash-lock');
    }
    function hide() {
      if (done) return;
      done = true;
      hideTimer = setTimeout(reallyHide, Math.max(0, MIN - (Date.now() - t0)));
    }
    function cover() { /* rise again before the browser leaves this page */
      done = true;
      if (hideTimer) clearTimeout(hideTimer);
      el.classList.add('is-fast');
      el.classList.remove('is-hidden');
      html.classList.add('ma-splash-lock');
    }

    if (document.readyState === 'interactive' || document.readyState === 'complete') { hide(); }
    else { document.addEventListener('DOMContentLoaded', hide); }
    setTimeout(hide, MAX);

    document.addEventListener('click', function (e) {
      if (e.defaultPrevented || e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
      var a = e.target && e.target.closest ? e.target.closest('a[href]') : null;
      if (!a) return;
      if (a.target && a.target !== '_self') return;
      if (a.hasAttribute('download')) return;
      var href = a.getAttribute('href');
      if (!href || href.charAt(0) === '#') return;
      var url;
      try { url = new URL(a.href, location.href); } catch (err) { return; }
      if (url.origin !== location.origin) return;
      if (url.protocol !== 'http:' && url.protocol !== 'https:') return;
      if (url.pathname === location.pathname && url.search === location.search && url.hash) return;
      cover();
    });

    document.addEventListener('submit', function (e) {
      if (e.defaultPrevented) return;
      var f = e.target;
      if (f && (!f.target || f.target === '_self')) cover();
    });

    /* back/forward from bfcache restores the old DOM — drop the veil instantly */
    window.addEventListener('pageshow', function (ev) {
      if (!ev.persisted) return;
      done = true;
      if (hideTimer) clearTimeout(hideTimer);
      el.style.transition = 'none';
      reallyHide();
      requestAnimationFrame(function () { el.style.transition = ''; });
    });
  })();
</script>
{%- endunless -%}
