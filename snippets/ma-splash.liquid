{% comment %}
  MAISON AMIIR — page loader veil, typographic treatment (Tom Ford / LV style).
  Ink-black veil, the house wordmark in gold serif caps whose letterspacing
  settles as it fades in, and a liquid-gold hairline that shimmers only
  while a slow page is still loading. One object, one event: the whole veil
  fades out as a single piece. No crest raster (it smears at small sizes),
  no zoom, no scroll lock, no layout shift.
  Shows on every navigation; a sessionStorage handoff after link clicks
  skips the entrance so the wordmark reads as one continuous moment across
  the page change. Must stay inline in the layout: it has to paint first.
{% endcomment %}
{%- unless request.design_mode -%}
<div id="ma-splash" aria-hidden="true">
  <div class="ma-splash__inner">
    <p class="ma-splash__word">MAISON&nbsp;AMIIR</p>
    <div class="ma-splash__line"></div>
  </div>
</div>
<noscript><style>#ma-splash { display: none !important; }</style></noscript>
<style>
  #ma-splash {
    position: fixed; inset: 0; z-index: 100000;
    background: #0A0A0A;
    display: flex; align-items: center; justify-content: center;
    opacity: 1;
    transition: opacity .55s ease;
  }
  #ma-splash.is-hidden {
    opacity: 0; visibility: hidden; pointer-events: none;
    transition: opacity .55s ease, visibility 0s linear .55s;
  }
  #ma-splash.is-fast { transition: opacity .18s ease; }

  .ma-splash__inner { text-align: center; padding: 0 1.5rem; transform: translateY(-2vh); }

  .ma-splash__word {
    margin: 0;
    font-family: 'Sinoreta', Georgia, 'Times New Roman', serif;
    font-weight: 300;
    font-size: clamp(1.5rem, 4.2vw, 2.1rem);
    color: #E7C98B;
    letter-spacing: .5em; text-indent: .5em;
    opacity: 0;
    transition: opacity .9s cubic-bezier(.22, 1, .36, 1), letter-spacing .9s cubic-bezier(.22, 1, .36, 1);
    white-space: nowrap;
  }
  .ma-splash__line {
    width: 0; height: 1px; margin: 1.5rem auto 0;
    background: linear-gradient(90deg, transparent, #A8894E 25%, #F1DCA8 50%, #A8894E 75%, transparent);
    background-size: 200% 100%;
    transition: width .9s ease .35s;
    animation: maSplashShimmer 2.2s linear 1.4s infinite;
  }
  @keyframes maSplashShimmer { 0% { background-position: 100% 0; } 100% { background-position: -100% 0; } }

  /* entrance (fresh load): letters settle in */
  #ma-splash.is-in .ma-splash__word { opacity: 1; letter-spacing: .34em; text-indent: .34em; }
  #ma-splash.is-in .ma-splash__line { width: min(200px, 46vw); }

  /* continuation after a link click — wordmark is already on screen, no re-entrance */
  #ma-splash.is-cont .ma-splash__word { opacity: 1; letter-spacing: .34em; text-indent: .34em; transition: none; }
  #ma-splash.is-cont .ma-splash__line { width: min(200px, 46vw); transition: none; }

  @media (prefers-reduced-motion: reduce) {
    .ma-splash__word { transition: opacity .25s ease; letter-spacing: .34em; text-indent: .34em; }
    .ma-splash__line { animation: none; transition: none; width: min(200px, 46vw); }
    #ma-splash { transition-duration: .25s; }
  }
</style>
<script>
  (function () {
    var el = document.getElementById('ma-splash');
    if (!el) return;

    /* arrived via an internal click? the wordmark is already on screen — no re-entrance */
    var cont = false;
    try {
      var ts = parseInt(sessionStorage.getItem('ma_veil_nav') || '0', 10);
      sessionStorage.removeItem('ma_veil_nav');
      cont = (Date.now() - ts) < 5000;
    } catch (e) {}

    if (cont) { el.classList.add('is-cont'); }
    else { requestAnimationFrame(function () { requestAnimationFrame(function () { el.classList.add('is-in'); }); }); }

    var t0 = Date.now();
    var MIN = cont ? 500 : 1000; /* never a blink */
    var MAX = 2600;              /* never a trap */
    var done = false;
    var hideTimer = null;

    function reveal() { el.classList.remove('is-fast'); el.classList.add('is-hidden'); }
    function hide() {
      if (done) return;
      done = true;
      hideTimer = setTimeout(reveal, Math.max(0, MIN - (Date.now() - t0)));
    }
    function instantOff() {
      done = true;
      if (hideTimer) clearTimeout(hideTimer);
      el.style.transition = 'none';
      el.classList.add('is-hidden');
      requestAnimationFrame(function () { el.style.transition = ''; });
    }
    function cover() { /* rise again before the browser leaves this page */
      done = true;
      if (hideTimer) clearTimeout(hideTimer);
      try { sessionStorage.setItem('ma_veil_nav', String(Date.now())); } catch (e) {}
      el.classList.add('is-fast', 'is-cont');
      el.classList.remove('is-hidden');
    }

    if (document.readyState === 'interactive' || document.readyState === 'complete') { hide(); }
    else { document.addEventListener('DOMContentLoaded', hide); }
    setTimeout(hide, MAX);

    document.addEventListener('click', function (e) {
      if (e.defaultPrevented || e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
      var a = e.target && e.target.closest ? e.target.closest('a[href]') : null;
      if (!a) return;
      if (a.target && a.target !== '_self') return;
      if (a.hasAttribute('download')) return;
      var href = a.getAttribute('href');
      if (!href || href.charAt(0) === '#') return;
      var url;
      try { url = new URL(a.href, location.href); } catch (err) { return; }
      if (url.origin !== location.origin) return;
      if (url.protocol !== 'http:' && url.protocol !== 'https:') return;
      if (url.pathname === location.pathname && url.search === location.search && url.hash) return;
      cover();
    });

    document.addEventListener('submit', function (e) {
      if (e.defaultPrevented) return;
      var f = e.target;
      if (f && (!f.target || f.target === '_self')) cover();
    });

    /* back/forward from bfcache restores the old DOM — drop the veil instantly */
    window.addEventListener('pageshow', function (ev) { if (ev.persisted) instantOff(); });
  })();
</script>
{%- endunless -%}
