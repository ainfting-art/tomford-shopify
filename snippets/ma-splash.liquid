{% comment %}
  MAISON AMIIR — launch veil. Black overlay with the gold-lit logo, shown once
  per browser session on first landing, held until the page has loaded
  (min 1.15s so it never blinks, max 3.4s so it never traps).
  Must stay inline in the layout: it has to paint before any content does.
{% endcomment %}
{%- unless request.design_mode -%}
<div id="ma-splash" aria-hidden="true">
  <div class="ma-splash__inner">
    {%- if settings.logo != blank -%}
      <img class="ma-splash__logo" src="{{ settings.logo | image_url: width: 480 }}" alt="{{ shop.name | escape }}" width="240" height="auto">
    {%- else -%}
      <p class="ma-splash__word">MAISON&nbsp;AMIIR</p>
    {%- endif -%}
    <div class="ma-splash__line"></div>
  </div>
</div>
<noscript><style>#ma-splash { display: none !important; }</style></noscript>
<style>
  #ma-splash {
    position: fixed; inset: 0; z-index: 100000;
    background: #0A0A0A;
    display: flex; align-items: center; justify-content: center;
    transition: opacity .85s ease, visibility .85s ease;
  }
  #ma-splash.is-done { opacity: 0; visibility: hidden; pointer-events: none; }
  html.ma-splash-lock { overflow: hidden; }

  .ma-splash__inner { text-align: center; padding: 0 1.5rem; }
  .ma-splash__logo {
    display: block; margin: 0 auto; width: min(240px, 58vw); height: auto;
    opacity: 0; transform: translateY(12px) scale(.985);
    animation: maSplashIn 1.15s cubic-bezier(.16, 1, .3, 1) .12s forwards;
  }
  .ma-splash__word {
    margin: 0;
    font-family: 'Sinoreta', Georgia, serif; font-weight: 300;
    font-size: clamp(1.7rem, 5vw, 2.5rem); letter-spacing: .22em; text-indent: .22em;
    color: #E7C98B;
    opacity: 0; transform: translateY(12px);
    animation: maSplashIn 1.15s cubic-bezier(.16, 1, .3, 1) .12s forwards;
  }
  .ma-splash__line {
    width: 0; height: 1px; margin: 1.6rem auto 0;
    background: linear-gradient(90deg, transparent, #A8894E 30%, #E7C98B 50%, #A8894E 70%, transparent);
    animation: maSplashLine 1.5s ease .55s forwards;
  }
  @keyframes maSplashIn { to { opacity: 1; transform: translateY(0) scale(1); } }
  @keyframes maSplashLine { to { width: min(180px, 42vw); } }

  @media (prefers-reduced-motion: reduce) {
    .ma-splash__logo, .ma-splash__word { animation: none; opacity: 1; transform: none; }
    .ma-splash__line { animation: none; width: min(180px, 42vw); }
    #ma-splash { transition-duration: .3s; }
  }
</style>
<script>
  (function () {
    var el = document.getElementById('ma-splash');
    if (!el) return;
    var seen = false;
    try { seen = !!sessionStorage.getItem('ma_splash_seen'); } catch (e) {}
    if (seen) { el.parentNode.removeChild(el); return; }
    try { sessionStorage.setItem('ma_splash_seen', '1'); } catch (e) {}
    document.documentElement.classList.add('ma-splash-lock');

    var t0 = Date.now();
    var MIN = 1150; /* never a blink */
    var MAX = 3400; /* never a trap */
    var done = false;

    function hide() {
      if (done) return;
      done = true;
      var wait = Math.max(0, MIN - (Date.now() - t0));
      setTimeout(function () {
        el.classList.add('is-done');
        document.documentElement.classList.remove('ma-splash-lock');
        setTimeout(function () { if (el.parentNode) el.parentNode.removeChild(el); }, 950);
      }, wait);
    }

    if (document.readyState === 'complete') { hide(); }
    else { window.addEventListener('load', hide); }
    setTimeout(hide, MAX);
  })();
</script>
{%- endunless -%}
