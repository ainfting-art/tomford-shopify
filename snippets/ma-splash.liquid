{% comment %}
  MAISON AMIIR — page loader veil: the logo only.
  Cream veil, the crest centered large and served high-res so the engraving
  stays crisp. One object, one event: the crest fades in once, breathes
  gently only while a slow page loads, then the WHOLE veil fades out as a
  single piece. No text, no hairline, no zoom, no scroll lock, no shift.
  Shows on every navigation; a sessionStorage handoff after link clicks
  skips the entrance so the crest reads as one continuous moment across
  the page change. Must stay inline in the layout: it has to paint first.
{% endcomment %}
{%- unless request.design_mode -%}
<div id="ma-splash" aria-hidden="true">
  <div class="ma-splash__inner">
    {%- comment -%} Logo is baked in as a data URI so it exists in the very
    first painted frame — no fetch, no blink. Regenerate if the logo changes:
    curl -H "Accept: image/webp" "https://maisonamiir.com/cdn/shop/files/MAISON-LOGO-NEW.png?width=480" | base64 {%- endcomment -%}
    <img class="ma-splash__logo" src="data:image/webp;base64," alt="{{ shop.name | escape }}" width="260" height="auto" decoding="sync">
  </div>
</div>
<noscript><style>#ma-splash { display: none !important; }</style></noscript>
<style>
  #ma-splash {
    position: fixed; inset: 0; z-index: 100000;
    background: #F7F3EA;
    display: flex; align-items: center; justify-content: center;
    opacity: 1;
    transition: opacity .5s ease;
  }
  #ma-splash.is-hidden {
    opacity: 0; visibility: hidden; pointer-events: none;
    transition: opacity .5s ease, visibility 0s linear .5s;
  }
  #ma-splash.is-fast { transition: opacity .18s ease; }

  .ma-splash__inner {
    text-align: center; padding: 0 1.5rem;
    transform: translateY(-2vh);
    opacity: 0;
    transition: opacity .6s ease;
  }
  #ma-splash.is-in .ma-splash__inner,
  #ma-splash.is-cont .ma-splash__inner { opacity: 1; }
  #ma-splash.is-cont .ma-splash__inner { transition: none; }

  .ma-splash__logo {
    display: block; margin: 0 auto;
    width: min(260px, 60vw); height: auto;
    animation: maSplashBreathe 2.6s ease-in-out 1.2s infinite;
  }
  @keyframes maSplashBreathe { 0%, 100% { opacity: 1; } 50% { opacity: .72; } }

  /* reveal — the crest zooms to fill the page and dissolves BEFORE the veil
     finishes fading, so it never floats over readable content */
  #ma-splash.is-out { opacity: 0; pointer-events: none; transition: opacity .5s ease .22s; }
  #ma-splash.is-out .ma-splash__logo {
    animation: none;
    transform: scale(6); opacity: 0;
    transition: transform .7s cubic-bezier(.5, 0, .85, .4), opacity .42s ease .12s;
    will-change: transform, opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    .ma-splash__logo { animation: none; }
    #ma-splash, .ma-splash__inner { transition-duration: .2s !important; }
    #ma-splash.is-out .ma-splash__logo { transform: none; }
  }
</style>
<script>
  (function () {
    var el = document.getElementById('ma-splash');
    if (!el) return;

    /* arrived via an internal click? the crest is already on screen — no re-entrance */
    var cont = false;
    try {
      var ts = parseInt(sessionStorage.getItem('ma_veil_nav') || '0', 10);
      sessionStorage.removeItem('ma_veil_nav');
      cont = (Date.now() - ts) < 5000;
    } catch (e) {}

    if (cont) { el.classList.add('is-cont'); }
    else { requestAnimationFrame(function () { requestAnimationFrame(function () { el.classList.add('is-in'); }); }); }

    var t0 = Date.now();
    var MIN = cont ? 500 : 900; /* never a blink */
    var MAX = 2600;             /* never a trap */
    var done = false;
    var hideTimer = null;

    function reveal() {
      el.classList.remove('is-fast');
      el.classList.add('is-out');
      setTimeout(function () {
        el.classList.add('is-hidden');
        el.classList.remove('is-out', 'is-in', 'is-cont');
      }, 820);
    }
    function hide() {
      if (done) return;
      done = true;
      hideTimer = setTimeout(reveal, Math.max(0, MIN - (Date.now() - t0)));
    }
    function instantOff() {
      done = true;
      if (hideTimer) clearTimeout(hideTimer);
      el.style.transition = 'none';
      el.classList.add('is-hidden');
      el.classList.remove('is-out');
      requestAnimationFrame(function () { el.style.transition = ''; });
    }
    function cover() { /* rise again before the browser leaves this page */
      done = true;
      if (hideTimer) clearTimeout(hideTimer);
      try { sessionStorage.setItem('ma_veil_nav', String(Date.now())); } catch (e) {}
      el.classList.add('is-fast', 'is-cont');
      el.classList.remove('is-hidden', 'is-out');
    }

    if (document.readyState === 'interactive' || document.readyState === 'complete') { hide(); }
    else { document.addEventListener('DOMContentLoaded', hide); }
    setTimeout(hide, MAX);

    document.addEventListener('click', function (e) {
      if (e.defaultPrevented || e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
      var a = e.target && e.target.closest ? e.target.closest('a[href]') : null;
      if (!a) return;
      if (a.target && a.target !== '_self') return;
      if (a.hasAttribute('download')) return;
      var href = a.getAttribute('href');
      if (!href || href.charAt(0) === '#') return;
      var url;
      try { url = new URL(a.href, location.href); } catch (err) { return; }
      if (url.origin !== location.origin) return;
      if (url.protocol !== 'http:' && url.protocol !== 'https:') return;
      if (url.pathname === location.pathname && url.search === location.search && url.hash) return;
      cover();
    });

    document.addEventListener('submit', function (e) {
      if (e.defaultPrevented) return;
      var f = e.target;
      if (f && (!f.target || f.target === '_self')) cover();
    });

    /* back/forward from bfcache restores the old DOM — drop the veil instantly */
    window.addEventListener('pageshow', function (ev) { if (ev.persisted) instantOff(); });
  })();
</script>
{%- endunless -%}
