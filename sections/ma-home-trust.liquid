{%- comment -%}
  MAISON AMIIR — Home · Trust band (sits directly below the hero video).
  Light ivory strip carrying the credibility numbers pulled out of the hero.
  House style: serif figures, gold star, hairline dividers. Editable text.
{%- endcomment -%}

<section class="ma-tb" id="ma-tb-{{ section.id }}">
  <div class="ma-tb__in">
    <div class="ma-tb__i">
      <div class="ma-tb__v"><span class="ma-tb__st" aria-hidden="true">{{ section.settings.stars }}</span> {{ section.settings.a_big | escape }}</div>
      <div class="ma-tb__l">{{ section.settings.a_sm | escape }}</div>
    </div>
    <div class="ma-tb__i">
      <div class="ma-tb__v">{{ section.settings.b_big | escape }}</div>
      <div class="ma-tb__l">{{ section.settings.b_sm | escape }}</div>
    </div>
    <div class="ma-tb__i">
      <div class="ma-tb__v">{{ section.settings.c_big | escape }}</div>
      <div class="ma-tb__l">{{ section.settings.c_sm | escape }}</div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} { opacity: 1 !important; }
  #ma-tb-{{ section.id }}.ma-tb {
    background: #f4efe7;
    border-bottom: 1px solid #e5dfd2;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    color: #1a1a1a;
  }
  #ma-tb-{{ section.id }} .ma-tb__in {
    max-width: 1100px; margin: 0 auto;
    display: flex; align-items: stretch; justify-content: center;
  }
  #ma-tb-{{ section.id }} .ma-tb__i {
    flex: 1; text-align: center; padding: 26px 18px; position: relative;
  }
  #ma-tb-{{ section.id }} .ma-tb__i + .ma-tb__i::before {
    content: ""; position: absolute; left: 0; top: 24%; height: 52%; width: 1px; background: #e5dfd2;
  }
  #ma-tb-{{ section.id }} .ma-tb__v {
    font-family: Georgia, "Times New Roman", serif; font-size: 26px; line-height: 1; letter-spacing: .01em; color: #1a1a1a;
  }
  #ma-tb-{{ section.id }} .ma-tb__st { color: #a89566; font-size: 15px; letter-spacing: 2px; vertical-align: 2px; }
  #ma-tb-{{ section.id }} .ma-tb__l {
    font-size: 9.5px; letter-spacing: .18em; text-transform: uppercase; color: #928878; margin-top: 9px;
  }
  @media (max-width: 749px) {
    #ma-tb-{{ section.id }} .ma-tb__i { padding: 18px 8px; }
    #ma-tb-{{ section.id }} .ma-tb__v { font-size: 18px; }
    #ma-tb-{{ section.id }} .ma-tb__st { font-size: 11px; }
    #ma-tb-{{ section.id }} .ma-tb__l { font-size: 8px; letter-spacing: .12em; margin-top: 6px; }
  }
</style>

{% schema %}
{
  "name": "MA — Trust Band",
  "tag": "section",
  "class": "ma-trust-section",
  "settings": [
    { "type": "paragraph", "content": "Sits right below the hero. Use figures you can stand behind." },
    { "type": "text", "id": "stars", "label": "Rating stars", "default": "★★★★☆" },
    { "type": "text", "id": "a_big", "label": "1 — figure", "default": "4.3" },
    { "type": "text", "id": "a_sm", "label": "1 — label", "default": "From 500+ reviews" },
    { "type": "text", "id": "b_big", "label": "2 — figure", "default": "15,000+" },
    { "type": "text", "id": "b_sm", "label": "2 — label", "default": "Bottles shipped" },
    { "type": "text", "id": "c_big", "label": "3 — figure", "default": "7-Day" },
    { "type": "text", "id": "c_sm", "label": "3 — label", "default": "Risk-free returns" }
  ],
  "presets": [{ "name": "MA — Trust Band" }]
}
{% endschema %}
