{%- comment -%}
  MAISON AMIIR — Home · Trust band (sits directly below the hero video).
  Light ivory strip carrying the credibility numbers pulled out of the hero.
  House style: serif figures, gold star, hairline dividers. Editable text.
{%- endcomment -%}

<style>
  #shopify-section-{{ section.id }} .ma-marquee {
    background: #f4efe6;
    border-top: 1px solid #c9a24b;
    border-bottom: 1px solid #c9a24b;
    padding: 16px 0;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .ma-marquee__track {
    display: flex;
    width: max-content;
    animation: ma-marquee-scroll {{ section.settings.speed }}s linear infinite;
  }

  #shopify-section-{{ section.id }} .ma-marquee__set {
    display: flex;
    align-items: center;
    gap: 28px;
    padding-right: 28px;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .ma-marquee__item {
    font-family: "Cormorant Garamond", Georgia, serif;
    color: #16130f;
    font-size: 13px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .ma-marquee__dot {
    color: #c9a24b;
    font-size: 12px;
  }

  @keyframes ma-marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .ma-marquee__track {
      animation: none;
    }
  }
</style>