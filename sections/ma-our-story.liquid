{% comment %} MAISON AMIIR — Our Story (connected editorial: house → belief → founder → philosophy → collection) {% endcomment %}

{%- assign accent = section.settings.accent | default: '#A8894E' -%}

<div class="ma-story" id="ma-story-{{ section.id }}">

  {%- if section.settings.art_top != blank -%}
    <div class="ma-story__art ma-story__art--top" aria-hidden="true">
      {{ section.settings.art_top | image_url: width: 2400 | image_tag: loading: 'lazy', alt: '' }}
    </div>
  {%- endif -%}

  <!-- ══════════ HERO ══════════ -->
  <header class="ma-story__hero">
    <p class="ma-story__eyebrow ma-story-reveal">Maison Amiir</p>
    {%- if section.settings.emblem != blank -%}
      <div class="ma-story__emblem ma-story-reveal">{{ section.settings.emblem | image_url: width: 560 | image_tag: loading: 'eager', alt: 'Maison Amiir emblem' }}</div>
    {%- elsif settings.logo != blank -%}
      <div class="ma-story__emblem ma-story-reveal">{{ settings.logo | image_url: width: 560 | image_tag: loading: 'eager', alt: 'Maison Amiir emblem' }}</div>
    {%- endif -%}
    <h1 class="ma-story__title ma-story-reveal">Our Story</h1>
    <p class="ma-story__manifesto ma-story-reveal">We do not create perfumes.<br>We create signatures.</p>
    <span class="ma-story__rule ma-story-reveal" aria-hidden="true"></span>
  </header>

  <!-- ══════════ I · THE HOUSE ══════════ -->
  <section class="ma-story__chapter">
    <p class="ma-story__num ma-story-reveal">I</p>
    <h2 class="ma-story__heading ma-story-reveal">The House</h2>
    <div class="ma-story__body ma-story-reveal">
      <p class="ma-story__lead"><span class="ma-story__dropcap">M</span>aison Amiir is a Paris-inspired luxury perfume house headquartered in Dubai, with its Creative Studio in India.</p>
      <p>Founded with the vision of restoring perfumery to its true essence — <em>craftsmanship, intimacy, and storytelling</em> — the Maison blends French artistry, Dubai sophistication, and Indian heritage into a singular identity.</p>
    </div>
    <div class="ma-story__cities">
      <div class="ma-story__city ma-story-reveal">
        <p class="ma-story__city-name">Paris</p>
        <p class="ma-story__city-line">The artistry</p>
      </div>
      <div class="ma-story__city ma-story-reveal">
        <p class="ma-story__city-name">Dubai</p>
        <p class="ma-story__city-line">The sophistication</p>
      </div>
      <div class="ma-story__city ma-story-reveal">
        <p class="ma-story__city-name">India</p>
        <p class="ma-story__city-line">The heritage</p>
      </div>
    </div>
  </section>

  <!-- ══════════ II · THE BELIEF ══════════ -->
  <section class="ma-story__chapter">
    <p class="ma-story__num ma-story-reveal">II</p>
    <h2 class="ma-story__heading ma-story-reveal">The Belief</h2>
    <div class="ma-story__creed">
      <p class="ma-story__creed-line ma-story-reveal">We believe a fragrance should not overpower.</p>
      <p class="ma-story__creed-line ma-story-reveal">It should enhance.</p>
      <p class="ma-story__creed-line ma-story-reveal">It should become part of you.</p>
    </div>
    <div class="ma-story__body ma-story-reveal">
      <p>Each creation is blended in small batches using premium-grade oils, designed to deliver long-lasting performance with a soft, refined presence.</p>
    </div>
    <p class="ma-story__statement ma-story-reveal">In a world driven by loud and commercial scents,<br>Maison Amiir chooses quiet luxury —<br>subtle, elegant, and deeply personal.</p>
  </section>

  {%- if section.settings.art_mid != blank -%}
    <div class="ma-story__art ma-story__art--mid" aria-hidden="true">
      {{ section.settings.art_mid | image_url: width: 2400 | image_tag: loading: 'lazy', alt: '' }}
    </div>
  {%- endif -%}

  <!-- ══════════ III · THE FOUNDER'S NOTE ══════════ -->
  <section class="ma-story__chapter">
    <p class="ma-story__num ma-story-reveal">III</p>
    <h2 class="ma-story__heading ma-story-reveal">The Founder&rsquo;s Note</h2>
    <div class="ma-story__note ma-story-reveal">
      <p class="ma-story__note-quote">&ldquo;As the perfumer of Maison Amiir, my goal was not to copy a fragrance, but to recreate an emotion. The Iconic Collection is my interpretation of the world&rsquo;s most loved scents — refined, balanced, and blended with premium French and Swiss oils to deliver a familiar richness with a signature Maison Amiir touch.&rdquo;</p>
      <p class="ma-story__note-sign">— A.</p>
      <p class="ma-story__note-role">Founder &amp; Perfumer</p>
    </div>
  </section>

  <!-- ══════════ IV · THE PHILOSOPHY ══════════ -->
  <section class="ma-story__chapter">
    <p class="ma-story__num ma-story-reveal">IV</p>
    <h2 class="ma-story__heading ma-story-reveal">The Philosophy</h2>
    <div class="ma-story__creed">
      <p class="ma-story__creed-line ma-story-reveal">Luxury should be felt, not displayed.</p>
      <p class="ma-story__creed-line ma-story-reveal">Confidence should be effortless, not forced.</p>
      <p class="ma-story__creed-line ma-story-reveal">A fragrance should become part of you — a memory, a moment, a chapter of your identity.</p>
    </div>
    <div class="ma-story__principles">
      <div class="ma-story__principle ma-story-reveal">
        <p class="ma-story__principle-num">01</p>
        <h3>Soft Luxury</h3>
        <p>Crafted to feel expensive, refined, and emotionally deep — never overpowering, always elegant.</p>
      </div>
      <div class="ma-story__principle ma-story-reveal">
        <p class="ma-story__principle-num">02</p>
        <h3>Signature Identity</h3>
        <p>We don&rsquo;t create perfumes. We create signatures — olfactive identities meant to become part of you.</p>
      </div>
      <div class="ma-story__principle ma-story-reveal">
        <p class="ma-story__principle-num">03</p>
        <h3>Emotional Craftsmanship</h3>
        <p>Each blend is developed slowly, thoughtfully, in controlled small batches — purity, performance, and storytelling in every drop.</p>
      </div>
      <div class="ma-story__principle ma-story-reveal">
        <p class="ma-story__principle-num">04</p>
        <h3>Global Vision, Cultural Soul</h3>
        <p>Paris inspires our artistry. Dubai shapes our luxury. India fuels our creativity.</p>
      </div>
    </div>
    <p class="ma-story__statement ma-story-reveal">Maison Amiir does not chase trends.<br>Maison Amiir creates timelessness.</p>
  </section>

  <!-- ══════════ CLOSING ══════════ -->
  <section class="ma-story__chapter ma-story__chapter--closing">
    <span class="ma-story__rule ma-story-reveal" aria-hidden="true"></span>
    <p class="ma-story__coda ma-story-reveal">Luxury crafted with intention</p>
    <a class="ma-story__cta ma-story-reveal" href="/collections/all-perfumes">Discover the Signatures</a>
  </section>

  <!-- ══════════ DISCLAIMER ══════════ -->
  <section class="ma-story__chapter ma-story__chapter--disclaimer">
    <div class="ma-story__disclaimer ma-story-reveal">
      <p class="ma-story__disclaimer-title">Disclaimer</p>
      <p>Maison Amiir is an independent fragrance house. Any references to designer brands (such as Dior, Chanel, Gucci, etc.) are used strictly for descriptive purposes to indicate scent direction. We are not affiliated with, endorsed by, or associated with any of these brands. All fragrances are original interpretations crafted using premium ingredients.</p>
    </div>
  </section>

</div>

<style>
  /* Horizon hides section wrappers at opacity 0 for its own reveal system,
     which never fires for this custom section — force ours visible. */
  #shopify-section-{{ section.id }} { opacity: 1 !important; }

  .ma-story {
    --ms-ink: #171410;
    --ms-cream: #F7F3EA;
    --ms-accent: {{ accent }};
    position: relative;
    overflow: hidden;
    background: var(--ms-cream);
    color: var(--ms-ink);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    padding: clamp(4rem, 9vw, 8rem) 1.5rem clamp(4rem, 8vw, 7rem);
  }
  .ma-story *, .ma-story *::before, .ma-story *::after { box-sizing: border-box; }

  /* ── line-art layers ── */
  .ma-story__art { position: absolute; left: 0; right: 0; pointer-events: none; opacity: .13; z-index: 0; }
  .ma-story__art img { width: 100%; height: auto; display: block; }
  .ma-story__art--top { top: 0; -webkit-mask-image: linear-gradient(to bottom, #000 55%, transparent 100%); mask-image: linear-gradient(to bottom, #000 55%, transparent 100%); }
  .ma-story__art--mid { position: relative; margin: clamp(2.5rem, 6vw, 5rem) auto; max-width: 1200px; opacity: .35; -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 18%, #000 82%, transparent 100%); mask-image: linear-gradient(to bottom, transparent 0%, #000 18%, #000 82%, transparent 100%); }

  .ma-story__hero, .ma-story__chapter { position: relative; z-index: 1; max-width: 760px; margin: 0 auto; text-align: center; }

  /* ── hero ── */
  .ma-story__hero { padding-bottom: clamp(2.5rem, 6vw, 5rem); }
  .ma-story__eyebrow { font-size: .78rem; letter-spacing: .5em; text-indent: .5em; text-transform: uppercase; color: var(--ms-accent); margin: 0 0 2rem; }
  .ma-story__emblem img { width: clamp(180px, 28vw, 260px); height: auto; margin: 0 auto 1.6rem; display: block; }
  .ma-story__title { font-size: clamp(2.7rem, 7vw, 4.6rem); font-weight: 200; letter-spacing: .18em; text-indent: .18em; text-transform: uppercase; margin: .2em 0 .55em; line-height: 1.12; }
  .ma-story__manifesto { font-size: clamp(1.25rem, 2.4vw, 1.7rem); font-weight: 300; line-height: 1.75; letter-spacing: .04em; margin: 0 auto; font-style: italic; }
  .ma-story__rule { display: block; width: 72px; height: 1px; background: var(--ms-accent); margin: clamp(2rem, 4.5vw, 3.2rem) auto 0; }

  /* ── chapters ── */
  .ma-story__chapter { padding: clamp(2.4rem, 5.5vw, 4.5rem) 0; }
  .ma-story__num { font-size: 1rem; letter-spacing: .45em; text-indent: .45em; color: var(--ms-accent); margin: 0 0 1rem; font-weight: 300; }
  .ma-story__num::after { content: ''; display: block; width: 1px; height: 44px; background: linear-gradient(to bottom, var(--ms-accent), transparent); margin: 1.1rem auto 0; }
  .ma-story__heading { font-size: clamp(1.7rem, 3.6vw, 2.5rem); font-weight: 250; letter-spacing: .22em; text-indent: .22em; text-transform: uppercase; margin: 0 0 clamp(1.6rem, 3.5vw, 2.6rem); line-height: 1.25; }

  .ma-story__body { font-size: clamp(1.13rem, 1.55vw, 1.28rem); font-weight: 300; line-height: 2; letter-spacing: .012em; text-align: center; max-width: 640px; margin: 0 auto; }
  .ma-story__body p { margin: 0 0 1.6em; }
  .ma-story__body p:last-child { margin-bottom: 0; }
  .ma-story__lead { font-size: 1.06em; }
  .ma-story__dropcap { font-size: 1.65em; font-weight: 250; line-height: 1; color: var(--ms-accent); letter-spacing: .04em; }

  .ma-story__statement { font-size: clamp(1.1rem, 1.9vw, 1.4rem); letter-spacing: .22em; text-indent: .22em; text-transform: uppercase; font-weight: 300; line-height: 2.15; color: var(--ms-ink); margin: clamp(1.8rem, 4vw, 2.8rem) auto 0; max-width: 680px; }

  .ma-story__cities { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem 1rem; max-width: 640px; margin: clamp(2.2rem, 4.5vw, 3.2rem) auto 0; }
  .ma-story__city-name { font-size: clamp(1.25rem, 2.4vw, 1.7rem); font-weight: 250; letter-spacing: .3em; text-indent: .3em; text-transform: uppercase; margin: 0 0 .5rem; }
  .ma-story__city-line { font-size: .95rem; font-weight: 300; font-style: italic; letter-spacing: .06em; margin: 0; color: rgba(23, 20, 16, .72); }
  .ma-story__city { position: relative; }
  .ma-story__city + .ma-story__city::before { content: ''; position: absolute; left: -0.6rem; top: 12%; height: 76%; width: 1px; background: rgba(23, 20, 16, .16); }

  .ma-story__creed { margin: 0 0 clamp(2rem, 4.5vw, 3.2rem); }
  .ma-story__creed-line { font-size: clamp(1.3rem, 2.6vw, 1.85rem); font-weight: 250; font-style: italic; line-height: 1.8; margin: 0 0 1.1em; }
  .ma-story__creed-line:last-child { margin-bottom: 0; }

  /* ── founder's note: ink card, the centerpiece ── */
  .ma-story__note {
    background: var(--ms-ink);
    color: var(--ms-cream);
    border: 1px solid rgba(168, 137, 78, .45);
    outline: 1px solid rgba(168, 137, 78, .18);
    outline-offset: 6px;
    padding: clamp(2.4rem, 6vw, 4.2rem) clamp(1.6rem, 5vw, 4rem);
    max-width: 680px;
    margin: 0 auto;
  }
  .ma-story__note-quote { font-size: clamp(1.15rem, 1.9vw, 1.4rem); font-weight: 300; font-style: italic; line-height: 2.05; letter-spacing: .015em; margin: 0 0 2rem; color: rgba(247, 243, 234, .94); }
  .ma-story__note-sign { font-size: 1.5rem; font-weight: 250; letter-spacing: .12em; color: #E7C98B; margin: 0 0 .45rem; }
  .ma-story__note-role { font-size: .74rem; letter-spacing: .38em; text-indent: .38em; text-transform: uppercase; color: rgba(247, 243, 234, .6); margin: 0; }

  .ma-story__principles { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 4vw, 3rem) clamp(2rem, 5vw, 4rem); text-align: center; max-width: 720px; margin: 0 auto; }
  .ma-story__principle-num { font-size: .82rem; letter-spacing: .4em; text-indent: .4em; color: var(--ms-accent); margin: 0 0 .7rem; }
  .ma-story__principle h3 { font-size: clamp(1.05rem, 1.7vw, 1.25rem); font-weight: 400; letter-spacing: .2em; text-indent: .2em; text-transform: uppercase; margin: 0 0 .8rem; line-height: 1.5; }
  .ma-story__principle p { font-size: clamp(1rem, 1.4vw, 1.12rem); font-weight: 300; line-height: 1.9; margin: 0; color: rgba(23, 20, 16, .82); }

  /* ── closing ── */
  .ma-story__chapter--closing { padding-bottom: clamp(1.6rem, 3.5vw, 2.6rem); }
  .ma-story__chapter--closing .ma-story__rule { margin-top: 0; }
  .ma-story__coda { font-size: .85rem; letter-spacing: .5em; text-indent: .5em; text-transform: uppercase; color: var(--ms-accent); margin: 1.8rem 0 2.2rem; }
  .ma-story__cta {
    display: inline-block; font-size: .76rem; letter-spacing: .3em; text-indent: .3em; text-transform: uppercase;
    color: var(--ms-ink); border: 1px solid var(--ms-ink); padding: 1.05em 2.2em; text-decoration: none;
    transition: background .35s ease, color .35s ease;
  }
  .ma-story__cta:hover { background: var(--ms-ink); color: var(--ms-cream); }

  .ma-story__chapter--disclaimer { padding-top: clamp(1.6rem, 3.5vw, 2.6rem); }
  .ma-story__disclaimer { max-width: 560px; margin: 0 auto; font-size: .82rem; font-weight: 300; line-height: 1.9; letter-spacing: .03em; color: rgba(23, 20, 16, .55); }
  .ma-story__disclaimer-title { letter-spacing: .35em; text-indent: .35em; text-transform: uppercase; font-size: .72rem; margin: 0 0 .8rem; color: rgba(23, 20, 16, .6); }
  .ma-story__disclaimer p { margin: 0; }

  /* ── cinematic reveal (content stays visible unless JS enables hiding) ── */
  .ma-story--js .ma-story-reveal { opacity: 0; transform: translateY(28px); transition: opacity 1.05s cubic-bezier(.16, 1, .3, 1), transform 1.05s cubic-bezier(.16, 1, .3, 1); will-change: opacity, transform; }
  .ma-story--js .ma-story-reveal.is-in { opacity: 1; transform: none; }
  .ma-story--js .ma-story__city.ma-story-reveal, .ma-story--js .ma-story__principle.ma-story-reveal { transition-delay: calc(var(--ms-i, 0) * 150ms); }

  @media (prefers-reduced-motion: reduce) {
    .ma-story-reveal { opacity: 1 !important; transform: none !important; transition: none !important; }
  }

  @media (max-width: 749px) {
    .ma-story { padding-left: 1.15rem; padding-right: 1.15rem; }
    .ma-story__body { text-align: left; }
    .ma-story__principles { grid-template-columns: 1fr; }
    .ma-story__cities { grid-template-columns: 1fr; gap: 1.7rem; max-width: 300px; }
    .ma-story__city + .ma-story__city::before { display: none; }
    .ma-story__art--top { opacity: .1; }
  }
</style>


{% schema %}
{
  "name": "MA Our Story",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "emblem", "label": "Emblem (defaults to store logo)" },
    { "type": "image_picker", "id": "art_top", "label": "Line-art background — top" },
    { "type": "image_picker", "id": "art_mid", "label": "Line-art divider — middle" },
    { "type": "color", "id": "accent", "label": "Accent color", "default": "#A8894E" }
  ],
  "presets": [{ "name": "MA Our Story" }]
}
{% endschema %}
