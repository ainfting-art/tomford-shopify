{% comment %} MAISON AMIIR — Our Story (cinematic editorial) {% endcomment %}

{%- assign accent = section.settings.accent | default: '#A8894E' -%}

<div class="ma-story" id="ma-story-{{ section.id }}">

  {%- if section.settings.art_top != blank -%}
    <div class="ma-story__art ma-story__art--top" aria-hidden="true">
      {{ section.settings.art_top | image_url: width: 2400 | image_tag: loading: 'lazy', alt: '' }}
    </div>
  {%- endif -%}

  <!-- ══════════ HERO ══════════ -->
  <header class="ma-story__hero">
    <p class="ma-story__eyebrow ma-story-reveal">Maison Amiir</p>
    {%- if section.settings.emblem != blank -%}
      <div class="ma-story__emblem ma-story-reveal">{{ section.settings.emblem | image_url: width: 560 | image_tag: loading: 'eager', alt: 'Maison Amiir emblem' }}</div>
    {%- elsif settings.logo != blank -%}
      <div class="ma-story__emblem ma-story-reveal">{{ settings.logo | image_url: width: 560 | image_tag: loading: 'eager', alt: 'Maison Amiir emblem' }}</div>
    {%- endif -%}
    <h1 class="ma-story__title ma-story-reveal">Our Story</h1>
    <p class="ma-story__manifesto ma-story-reveal">Luxury is not noise.<br>Luxury is presence.</p>
    <span class="ma-story__rule ma-story-reveal" aria-hidden="true"></span>
  </header>

  <!-- ══════════ I · THE VISION ══════════ -->
  <section class="ma-story__chapter">
    <p class="ma-story__num ma-story-reveal">I</p>
    <h2 class="ma-story__heading ma-story-reveal">The Vision</h2>
    <div class="ma-story__body ma-story-reveal">
      <p class="ma-story__lead"><span class="ma-story__dropcap">M</span>AISON AMIIR was created with a singular vision — to bring modern perfumery back to its roots: <em>craftsmanship, elegance, and storytelling.</em></p>
      <p>Inspired by the great French perfume houses, our philosophy is simple yet timeless: a fragrance should enhance the wearer, not overpower the world around them. True luxury is soft, intimate, and deeply personal.</p>
    </div>
  </section>

  <!-- ══════════ II · THE JOURNEY ══════════ -->
  <section class="ma-story__chapter">
    <p class="ma-story__num ma-story-reveal">II</p>
    <h2 class="ma-story__heading ma-story-reveal">The Journey</h2>
    <div class="ma-story__body ma-story-reveal">
      <p>The Maison was founded by <strong>Mohammed Noman Amire</strong>, whose journey took him from India&rsquo;s historic attar distilleries to the cobblestone perfume houses of France and Dubai. There, he studied the architecture of scent, ingredient engineering, and the precision behind French haute parfumerie.</p>
      <p>His travels sparked a realization:</p>
    </div>
    <blockquote class="ma-story__quote ma-story-reveal">India is the birthplace of some of the world&rsquo;s most precious oils — yet it lacked a globally recognized luxury perfume house.</blockquote>
    <p class="ma-story__statement ma-story-reveal">Maison Amiir was created to change that.</p>
  </section>

  <!-- ══════════ III · A HOUSE BUILT ON CRAFT ══════════ -->
  <section class="ma-story__chapter">
    <p class="ma-story__num ma-story-reveal">III</p>
    <h2 class="ma-story__heading ma-story-reveal">A House Built on Craft</h2>
    <div class="ma-story__body ma-story-reveal">
      <p>Every MAISON AMIIR creation is blended slowly in controlled small batches using premium-grade oils, ensuring exceptional clarity, purity, and long-lasting performance.</p>
    </div>
    <blockquote class="ma-story__quote ma-story__quote--major ma-story-reveal">We don&rsquo;t create scents —<br>we create signatures.</blockquote>
    <ul class="ma-story__pillars" role="list">
      <li class="ma-story-reveal">Deep emotional storytelling</li>
      <li class="ma-story-reveal">French-inspired luxury</li>
      <li class="ma-story-reveal">Modern minimal elegance</li>
      <li class="ma-story-reveal">Precision blending</li>
      <li class="ma-story-reveal">High performance with softness</li>
    </ul>
    <div class="ma-story__body ma-story-reveal">
      <p>In a world filled with loud, synthetic, commercial perfumes, MAISON AMIIR chose a different path — a return to intimacy, refinement, and true artisanal quality.</p>
    </div>
  </section>

  <!-- ══════════ IV · A GLOBAL IDENTITY ══════════ -->
  <section class="ma-story__chapter">
    <p class="ma-story__num ma-story-reveal">IV</p>
    <h2 class="ma-story__heading ma-story-reveal">A Global Identity</h2>
    <div class="ma-story__body ma-story-reveal">
      <p>MAISON AMIIR operates globally from its <strong>Head Office in Dubai</strong>, a city synonymous with luxury, modernity, and global presence. Our <strong>Creative Studio in India</strong> serves as the private space where ideas, formulations, and fragrance development come to life with artistic focus and precision.</p>
    </div>
    <div class="ma-story__cities">
      <div class="ma-story__city ma-story-reveal">
        <p class="ma-story__city-name">Paris</p>
        <p class="ma-story__city-line">The elegance</p>
      </div>
      <div class="ma-story__city ma-story-reveal">
        <p class="ma-story__city-name">Dubai</p>
        <p class="ma-story__city-line">The luxury</p>
      </div>
      <div class="ma-story__city ma-story-reveal">
        <p class="ma-story__city-name">India</p>
        <p class="ma-story__city-line">The soul &amp; heritage</p>
      </div>
    </div>
  </section>

  {%- if section.settings.art_mid != blank -%}
    <div class="ma-story__art ma-story__art--mid" aria-hidden="true">
      {{ section.settings.art_mid | image_url: width: 2400 | image_tag: loading: 'lazy', alt: '' }}
    </div>
  {%- endif -%}

  <!-- ══════════ V · OUR PHILOSOPHY ══════════ -->
  <section class="ma-story__chapter">
    <p class="ma-story__num ma-story-reveal">V</p>
    <h2 class="ma-story__heading ma-story-reveal">Our Philosophy</h2>
    <div class="ma-story__creed">
      <p class="ma-story__creed-line ma-story-reveal">Luxury should be felt, not displayed.</p>
      <p class="ma-story__creed-line ma-story-reveal">Confidence should be effortless, not forced.</p>
      <p class="ma-story__creed-line ma-story-reveal">A fragrance should become part of you — a memory, a moment, a chapter of your identity.</p>
    </div>
    <div class="ma-story__principles">
      <div class="ma-story__principle ma-story-reveal">
        <p class="ma-story__principle-num">01</p>
        <h3>Soft Luxury</h3>
        <p>Crafted to feel expensive, refined, and emotionally deep — never overpowering, always elegant.</p>
      </div>
      <div class="ma-story__principle ma-story-reveal">
        <p class="ma-story__principle-num">02</p>
        <h3>Signature Identity</h3>
        <p>We don&rsquo;t create perfumes. We create signatures — olfactive identities meant to become part of you.</p>
      </div>
      <div class="ma-story__principle ma-story-reveal">
        <p class="ma-story__principle-num">03</p>
        <h3>Emotional Craftsmanship</h3>
        <p>Each blend is developed slowly, thoughtfully, in controlled small batches — purity, performance, and storytelling in every drop.</p>
      </div>
      <div class="ma-story__principle ma-story-reveal">
        <p class="ma-story__principle-num">04</p>
        <h3>Global Vision, Cultural Soul</h3>
        <p>Paris inspires our artistry. Dubai shapes our luxury. India fuels our creativity.</p>
      </div>
    </div>
    <p class="ma-story__statement ma-story-reveal">Maison Amiir does not chase trends.<br>Maison Amiir creates timelessness.</p>
  </section>

  <!-- ══════════ VI · FROM THE FOUNDER ══════════ -->
  <section class="ma-story__chapter ma-story__chapter--letter">
    <p class="ma-story__num ma-story-reveal">VI</p>
    <h2 class="ma-story__heading ma-story-reveal">A Message from the Founder</h2>
    <div class="ma-story__letter ma-story-reveal">
      <p>MAISON AMIIR began as a dream — a belief that luxury should be intimate, meaningful, and felt in the soul.</p>
      <p>My journey took me from India&rsquo;s ancient attar houses to the cobblestone streets of France, where I discovered the elegance and artistry behind true perfumery.</p>
      <p class="ma-story__letter-creed">I realized that fragrance is not just scent.<br>It is identity.<br>It is memory.<br>It is presence.</p>
      <p>MAISON AMIIR exists to bring this experience to the world — a fusion of French-inspired artistry, Dubai&rsquo;s modern luxury, and India&rsquo;s timeless soul.</p>
      <p>Every fragrance is crafted with intention, emotion, and the belief that your presence deserves a signature.</p>
      <p class="ma-story__letter-welcome">Welcome to the Maison.</p>
      <p class="ma-story__signature">— Mohammed Noman Amire</p>
    </div>
  </section>

  <!-- ══════════ VII · OUR PROMISE ══════════ -->
  <section class="ma-story__chapter ma-story__chapter--promise">
    <p class="ma-story__num ma-story-reveal">VII</p>
    <h2 class="ma-story__heading ma-story-reveal">Our Promise</h2>
    <ul class="ma-story__pillars ma-story__pillars--promise" role="list">
      <li class="ma-story-reveal">Soft, expensive-smelling luxury</li>
      <li class="ma-story-reveal">Confidence in every drop</li>
      <li class="ma-story-reveal">Emotional, signature-worthy fragrances</li>
      <li class="ma-story-reveal">A refined experience inspired by French perfume heritage</li>
    </ul>
    <div class="ma-story__body ma-story__body--closing ma-story-reveal">
      <p>MAISON AMIIR represents a new era of perfumery — where craftsmanship meets identity, and where every fragrance tells a story worth remembering.</p>
    </div>
    <span class="ma-story__rule ma-story-reveal" aria-hidden="true"></span>
    <p class="ma-story__coda ma-story-reveal">Luxury crafted with intention</p>
  </section>

  <!-- ══════════ DISCLAIMER ══════════ -->
  <section class="ma-story__chapter ma-story__chapter--disclaimer">
    <div class="ma-story__disclaimer ma-story-reveal">
      <p class="ma-story__disclaimer-title">Disclaimer</p>
      <p>Maison Amiir is an independent fragrance house. Any references to designer brands (such as Dior, Chanel, Gucci, etc.) are used strictly for descriptive purposes to indicate scent direction. We are not affiliated with, endorsed by, or associated with any of these brands. All fragrances are original interpretations crafted using premium ingredients.</p>
    </div>
  </section>

</div>

<style>
  .ma-story {
    --ms-ink: #171410;
    --ms-cream: #F7F3EA;
    --ms-accent: {{ accent }};
    position: relative;
    overflow: hidden;
    background: var(--ms-cream);
    color: var(--ms-ink);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    padding: clamp(4rem, 9vw, 8.5rem) 1.5rem clamp(5rem, 10vw, 9rem);
  }
  .ma-story *, .ma-story *::before, .ma-story *::after { box-sizing: border-box; }

  /* ── line-art layers ── */
  .ma-story__art { position: absolute; left: 0; right: 0; pointer-events: none; opacity: .13; z-index: 0; }
  .ma-story__art img { width: 100%; height: auto; display: block; }
  .ma-story__art--top { top: 0; -webkit-mask-image: linear-gradient(to bottom, #000 55%, transparent 100%); mask-image: linear-gradient(to bottom, #000 55%, transparent 100%); }
  .ma-story__art--mid { position: relative; margin: clamp(3rem, 7vw, 6rem) auto; max-width: 1200px; opacity: .35; -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 18%, #000 82%, transparent 100%); mask-image: linear-gradient(to bottom, transparent 0%, #000 18%, #000 82%, transparent 100%); }

  .ma-story__hero, .ma-story__chapter { position: relative; z-index: 1; max-width: 760px; margin: 0 auto; text-align: center; }

  /* ── hero ── */
  .ma-story__hero { padding-bottom: clamp(3rem, 7vw, 6rem); }
  .ma-story__eyebrow { font-size: .78rem; letter-spacing: .5em; text-indent: .5em; text-transform: uppercase; color: var(--ms-accent); margin: 0 0 2rem; }
  .ma-story__emblem img { width: clamp(200px, 32vw, 300px); height: auto; margin: 0 auto 1.6rem; display: block; }
  .ma-story__title { font-size: clamp(2.7rem, 7vw, 4.6rem); font-weight: 200; letter-spacing: .18em; text-indent: .18em; text-transform: uppercase; margin: .2em 0 .55em; line-height: 1.12; }
  .ma-story__manifesto { font-size: clamp(1.25rem, 2.4vw, 1.7rem); font-weight: 300; line-height: 1.75; letter-spacing: .04em; margin: 0 auto; font-style: italic; }
  .ma-story__rule { display: block; width: 72px; height: 1px; background: var(--ms-accent); margin: clamp(2.2rem, 5vw, 3.5rem) auto 0; }

  /* ── chapters ── */
  .ma-story__chapter { padding: clamp(2.6rem, 6vw, 5rem) 0; }
  .ma-story__num { font-size: 1rem; letter-spacing: .45em; text-indent: .45em; color: var(--ms-accent); margin: 0 0 1rem; font-weight: 300; }
  .ma-story__num::after { content: ''; display: block; width: 1px; height: 44px; background: linear-gradient(to bottom, var(--ms-accent), transparent); margin: 1.1rem auto 0; }
  .ma-story__heading { font-size: clamp(1.7rem, 3.6vw, 2.5rem); font-weight: 250; letter-spacing: .22em; text-indent: .22em; text-transform: uppercase; margin: 0 0 clamp(1.6rem, 3.5vw, 2.6rem); line-height: 1.25; }

  .ma-story__body { font-size: clamp(1.13rem, 1.55vw, 1.28rem); font-weight: 300; line-height: 2; letter-spacing: .012em; text-align: center; }
  .ma-story__body p { margin: 0 0 1.6em; }
  .ma-story__body p:last-child { margin-bottom: 0; }
  .ma-story__body strong { font-weight: 500; }
  .ma-story__lead { font-size: 1.06em; }
  .ma-story__dropcap { float: none; font-size: 1.65em; font-weight: 250; line-height: 1; color: var(--ms-accent); letter-spacing: .04em; }

  .ma-story__quote { font-size: clamp(1.3rem, 2.6vw, 1.8rem); font-weight: 250; font-style: italic; line-height: 1.7; letter-spacing: .02em; max-width: 620px; margin: clamp(2rem, 4.5vw, 3.2rem) auto; padding: 0 1rem; position: relative; }
  .ma-story__quote::before, .ma-story__quote::after { content: ''; display: block; width: 40px; height: 1px; background: var(--ms-accent); margin: 0 auto; }
  .ma-story__quote::before { margin-bottom: 1.6rem; }
  .ma-story__quote::after { margin-top: 1.6rem; }
  .ma-story__quote--major { font-size: clamp(1.55rem, 3.4vw, 2.3rem); font-style: normal; text-transform: uppercase; letter-spacing: .14em; font-weight: 200; }

  .ma-story__statement { font-size: clamp(1.18rem, 2.1vw, 1.5rem); letter-spacing: .3em; text-indent: .3em; text-transform: uppercase; font-weight: 300; line-height: 2.1; color: var(--ms-ink); margin: clamp(1.8rem, 4vw, 2.8rem) 0 0; }

  .ma-story__pillars { list-style: none; margin: clamp(2rem, 4.5vw, 3rem) auto; padding: 0; max-width: 540px; }
  .ma-story__pillars li { font-size: clamp(1.02rem, 1.5vw, 1.18rem); font-weight: 300; letter-spacing: .22em; text-indent: .22em; text-transform: uppercase; padding: 1.05em 0; border-bottom: 1px solid rgba(23, 20, 16, .14); }
  .ma-story__pillars li:first-child { border-top: 1px solid rgba(23, 20, 16, .14); }

  .ma-story__cities { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem 1rem; max-width: 640px; margin: clamp(2.4rem, 5vw, 3.6rem) auto 0; }
  .ma-story__city-name { font-size: clamp(1.25rem, 2.4vw, 1.7rem); font-weight: 250; letter-spacing: .3em; text-indent: .3em; text-transform: uppercase; margin: 0 0 .5rem; }
  .ma-story__city-line { font-size: .95rem; font-weight: 300; font-style: italic; letter-spacing: .06em; margin: 0; color: rgba(23, 20, 16, .72); }
  .ma-story__city { position: relative; }
  .ma-story__city + .ma-story__city::before { content: ''; position: absolute; left: -0.6rem; top: 12%; height: 76%; width: 1px; background: rgba(23, 20, 16, .16); }

  .ma-story__creed { margin: 0 0 clamp(2.4rem, 5vw, 3.6rem); }
  .ma-story__creed-line { font-size: clamp(1.3rem, 2.6vw, 1.85rem); font-weight: 250; font-style: italic; line-height: 1.8; margin: 0 0 1.1em; }

  .ma-story__principles { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 4vw, 3rem) clamp(2rem, 5vw, 4rem); text-align: center; max-width: 720px; margin: 0 auto; }
  .ma-story__principle-num { font-size: .82rem; letter-spacing: .4em; text-indent: .4em; color: var(--ms-accent); margin: 0 0 .7rem; }
  .ma-story__principle h3 { font-size: clamp(1.05rem, 1.7vw, 1.25rem); font-weight: 400; letter-spacing: .2em; text-indent: .2em; text-transform: uppercase; margin: 0 0 .8rem; line-height: 1.5; }
  .ma-story__principle p { font-size: clamp(1rem, 1.4vw, 1.12rem); font-weight: 300; line-height: 1.9; margin: 0; color: rgba(23, 20, 16, .82); }

  .ma-story__letter { background: rgba(255, 255, 255, .5); border: 1px solid rgba(23, 20, 16, .1); padding: clamp(2.2rem, 5.5vw, 4rem) clamp(1.4rem, 4.5vw, 3.6rem); font-size: clamp(1.1rem, 1.55vw, 1.25rem); font-weight: 300; line-height: 2.05; text-align: center; }
  .ma-story__letter p { margin: 0 0 1.5em; }
  .ma-story__letter-creed { font-style: italic; font-size: 1.12em; line-height: 2.2; }
  .ma-story__letter-welcome { letter-spacing: .26em; text-indent: .26em; text-transform: uppercase; font-size: .95em; }
  .ma-story__signature { font-size: 1.15em; font-style: italic; letter-spacing: .08em; color: var(--ms-accent); margin-bottom: 0 !important; }

  .ma-story__body--closing { max-width: 620px; margin: 0 auto; }
  .ma-story__coda { font-size: .85rem; letter-spacing: .5em; text-indent: .5em; text-transform: uppercase; color: var(--ms-accent); margin: 1.8rem 0 0; }

  .ma-story__chapter--disclaimer { padding-top: 0; }
  .ma-story__disclaimer { max-width: 560px; margin: 0 auto; font-size: .82rem; font-weight: 300; line-height: 1.9; letter-spacing: .03em; color: rgba(23, 20, 16, .55); }
  .ma-story__disclaimer-title { letter-spacing: .35em; text-indent: .35em; text-transform: uppercase; font-size: .72rem; margin: 0 0 .8rem; color: rgba(23, 20, 16, .6); }
  .ma-story__disclaimer p { margin: 0; }

  /* ── cinematic reveal ── */
  .ma-story-reveal { opacity: 0; transform: translateY(28px); transition: opacity 1.05s cubic-bezier(.16, 1, .3, 1), transform 1.05s cubic-bezier(.16, 1, .3, 1); will-change: opacity, transform; }
  .ma-story-reveal.is-in { opacity: 1; transform: none; }
  .ma-story__pillars li.ma-story-reveal { transition-delay: calc(var(--ms-i, 0) * 120ms); }
  .ma-story__city.ma-story-reveal, .ma-story__principle.ma-story-reveal { transition-delay: calc(var(--ms-i, 0) * 150ms); }

  @media (prefers-reduced-motion: reduce) {
    .ma-story-reveal { opacity: 1 !important; transform: none !important; transition: none !important; }
  }

  @media (max-width: 749px) {
    .ma-story { padding-left: 1.15rem; padding-right: 1.15rem; }
    .ma-story__body, .ma-story__letter { text-align: left; }
    .ma-story__principles { grid-template-columns: 1fr; }
    .ma-story__cities { grid-template-columns: 1fr; gap: 1.7rem; max-width: 300px; }
    .ma-story__city + .ma-story__city::before { display: none; }
    .ma-story__art--top { opacity: .1; }
  }
</style>

<script>
  (function () {
    var root = document.getElementById('ma-story-{{ section.id }}');
    if (!root) return;
    var items = root.querySelectorAll('.ma-story-reveal');
    /* stagger index within each group */
    ['.ma-story__pillars', '.ma-story__cities', '.ma-story__principles'].forEach(function (sel) {
      root.querySelectorAll(sel).forEach(function (group) {
        Array.prototype.forEach.call(group.children, function (child, i) { child.style.setProperty('--ms-i', i); });
      });
    });
    if (!('IntersectionObserver' in window)) {
      items.forEach(function (el) { el.classList.add('is-in'); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
      });
    }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
    items.forEach(function (el) { io.observe(el); });
  })();
</script>

{% schema %}
{
  "name": "MA Our Story",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "emblem", "label": "Emblem (defaults to store logo)" },
    { "type": "image_picker", "id": "art_top", "label": "Line-art background — top" },
    { "type": "image_picker", "id": "art_mid", "label": "Line-art divider — middle" },
    { "type": "color", "id": "accent", "label": "Accent color", "default": "#A8894E" }
  ],
  "presets": [{ "name": "MA Our Story" }]
}
{% endschema %}
