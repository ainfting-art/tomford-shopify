{% comment %} Find Your Signature — Maison Amiir fragrance quiz {% endcomment %}

{%- comment %} Only lock the page (hide header/nav) on a dedicated page template, NEVER on the homepage {% endcomment -%}
{%- assign maq_is_page = false -%}
{%- if request.page_type == 'page' -%}{%- assign maq_is_page = true -%}{%- endif -%}

{%- assign quiz_col = section.settings.collection -%}
{%- if quiz_col != blank -%}
  {%- assign quiz_products = quiz_col.products -%}
{%- else -%}
  {%- assign quiz_products = collections.all.products -%}
{%- endif -%}

{%- assign q2_img1_url = '' -%}{%- if section.settings.q2_img1 != blank -%}{%- assign q2_img1_url = section.settings.q2_img1 | image_url: width: 600 -%}{%- endif -%}
{%- assign q2_img2_url = '' -%}{%- if section.settings.q2_img2 != blank -%}{%- assign q2_img2_url = section.settings.q2_img2 | image_url: width: 600 -%}{%- endif -%}
{%- assign q2_img3_url = '' -%}{%- if section.settings.q2_img3 != blank -%}{%- assign q2_img3_url = section.settings.q2_img3 | image_url: width: 600 -%}{%- endif -%}
{%- assign q2_img4_url = '' -%}{%- if section.settings.q2_img4 != blank -%}{%- assign q2_img4_url = section.settings.q2_img4 | image_url: width: 600 -%}{%- endif -%}
{%- assign q2_img5_url = '' -%}{%- if section.settings.q2_img5 != blank -%}{%- assign q2_img5_url = section.settings.q2_img5 | image_url: width: 600 -%}{%- endif -%}
{%- assign q6_img1_url = '' -%}{%- if section.settings.q6_img1 != blank -%}{%- assign q6_img1_url = section.settings.q6_img1 | image_url: width: 600 -%}{%- endif -%}
{%- assign q6_img2_url = '' -%}{%- if section.settings.q6_img2 != blank -%}{%- assign q6_img2_url = section.settings.q6_img2 | image_url: width: 600 -%}{%- endif -%}
{%- assign q6_img3_url = '' -%}{%- if section.settings.q6_img3 != blank -%}{%- assign q6_img3_url = section.settings.q6_img3 | image_url: width: 600 -%}{%- endif -%}
{%- assign q6_img4_url = '' -%}{%- if section.settings.q6_img4 != blank -%}{%- assign q6_img4_url = section.settings.q6_img4 | image_url: width: 600 -%}{%- endif -%}
{%- assign q6_img5_url = '' -%}{%- if section.settings.q6_img5 != blank -%}{%- assign q6_img5_url = section.settings.q6_img5 | image_url: width: 600 -%}{%- endif -%}
{%- assign q6_img6_url = '' -%}{%- if section.settings.q6_img6 != blank -%}{%- assign q6_img6_url = section.settings.q6_img6 | image_url: width: 600 -%}{%- endif -%}

{%- assign maq_bg_url = '' -%}
{%- if section.settings.bg_image != blank -%}{%- assign maq_bg_url = section.settings.bg_image | image_url: width: 2000 -%}{%- endif -%}

<style>
  {%- if maq_is_page -%}
  /* ─── LOCK THE PAGE: hide header instantly via CSS (no flash on refresh) ──── */
  .ma-header-wrap,
  .ma-announcement,
  .custom-header,
  .ma-search-overlay,
  .ma-drawer,
  .ma-search,
  .header-section,
  #header-group,
  #header-component,
  [class*="announcement"],
  .custom-liquid,
  /* hide the site footer on the locked quiz page */
  footer,
  .footer,
  .footer-section,
  #footer-group,
  .shopify-section-group-footer-group,
  [class*="site-footer"],
  [id*="shopify-section-footer"] { display: none !important; }

  /* make the page itself a deep premium backdrop and kill the header's body offset */
  html, body {
    background: #14181d !important;
    margin: 0 !important;
    padding-top: 0 !important;
  }

  /* hide any other section on this page (e.g. the page-title heading) — instant, no flash */
  main .shopify-section:not(:has(#maq-{{ section.id }})),
  #MainContent .shopify-section:not(:has(#maq-{{ section.id }})),
  [role="main"] .shopify-section:not(:has(#maq-{{ section.id }})) { display: none !important; }

  /* the quiz page wraps everything */
  .maq-page-wrap {
    background: #14181d;
    min-height: 100vh;
  }

  /* custom brand bar replaces the header nav */
  .maq-page-topbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 9999;
    background: rgba(240,235,227,0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(184,151,102,0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px 24px;
  }
  .maq-page-topbar a {
    font-family: var(--font-heading--family, serif);
    font-size: 18px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #1a1714;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .maq-page-topbar a:hover { opacity: 0.55; }

  /* push page content below fixed topbar */
  .maq-page-content { padding-top: 58px; }

  /* On the locked page the topbar + progress bar are fixed; anchor the quiz to the
     top and clear them so the question heading is never hidden behind the bars. */
  #maq-{{ section.id }} { justify-content: flex-start !important; }
  #maq-{{ section.id }} .maq__inner { padding-top: 118px; }
  @media (max-width: 767px) {
    #maq-{{ section.id }} .maq__inner { padding-top: 126px; }
  }
  {%- endif -%}

  /* ─── Quiz section variables ─────────────────────── */
  #maq-{{ section.id }} {
    --maq-bg:   #c2ccd4;
    --maq-bg2:  #aab6c0;
    --maq-ink:  #1c2530;
    --maq-mut:  rgba(28,37,48,0.56);
    --maq-gold: {{ section.settings.accent_color | default: '#B89766' }};
    --maq-line: rgba(28,37,48,0.16);
    --maq-orb:  var(--maq-gold);
    --maq-card: rgba(255,255,255,0.86);
    background: transparent;
    color: var(--maq-ink);
    position: relative;
    overflow: hidden;
    min-height: {% if maq_is_page %}100vh{% else %}600px{% endif %};
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  #maq-{{ section.id }} * { box-sizing: border-box; }

  /* readability veil — keeps the GIF visible but makes the layover text legible */
  #maq-{{ section.id }}::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(70% 55% at 50% 38%, rgba(0,0,0,0.40), transparent 78%),
      linear-gradient(to bottom, rgba(0,0,0,0.50) 0%, rgba(0,0,0,0.34) 30%, rgba(0,0,0,0.34) 70%, rgba(0,0,0,0.52) 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* ─── Background media (image / GIF / video) ─────── */
  .maq__media {
    position: absolute; inset: 0; z-index: 0; overflow: hidden; pointer-events: none;
  }
  .maq__media img, .maq__media video {
    width: 100%; height: 100%; object-fit: cover;
    opacity: {{ section.settings.media_opacity | default: 100 | divided_by: 100.0 }};
    transform: scale(1.04);
    animation: maqKen 30s ease-in-out infinite alternate;
  }
  @keyframes maqKen {
    from { transform: scale(1.04) translate3d(0,0,0); }
    to   { transform: scale(1.11) translate3d(-1%, -1.4%, 0); }
  }
  /* ─── Inner layout ───────────────────────────────── */
  .maq__inner {
    position: relative; z-index: 2;
    width: 100%; max-width: 920px;
    margin: 0 auto;
    padding: 30px 24px 34px;
    text-align: center;
  }

  /* ─── Progress bar ───────────────────────────────── */
  .maq__progress {
    position: {% if maq_is_page %}fixed; top: 57px;{% else %}absolute; top: 16px;{% endif %}
    left: 0; right: 0;
    z-index: 9998;
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    padding: 12px 24px 8px;
    background: rgba(240,235,227,0.88);
    backdrop-filter: blur(8px);
    opacity: 0; transition: opacity 0.4s ease;
    border-bottom: 1px solid rgba(184,151,102,0.14);
  }
  .maq__progress.is-on { opacity: 1; }
  .maq__progress-label {
    font-family: var(--font-body--family, sans-serif);
    font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--maq-mut);
  }
  .maq__progress-track {
    width: 180px; height: 1px; background: rgba(26,23,20,0.15); position: relative;
  }
  .maq__progress-fill {
    position: absolute; left: 0; top: 0; height: 100%; width: 0%;
    background: var(--maq-gold); transition: width 0.5s ease;
    box-shadow: 0 0 8px color-mix(in srgb, var(--maq-gold) 60%, transparent);
  }

  /* ─── Intro text ─────────────────────────────────── */
  .maq__eyebrow {
    font-family: var(--font-body--family, sans-serif);
    font-size: 11px; letter-spacing: 0.32em; text-transform: uppercase;
    color: var(--maq-gold); margin: 0 0 16px;
    text-shadow: 0 1px 8px rgba(0,0,0,0.5);
  }
  .maq__title {
    font-family: var(--font-heading--family, serif);
    font-weight: 400; font-size: clamp(22px, 3.4vw, 38px);
    line-height: 1.12; letter-spacing: 0.05em; margin: 0 0 12px; color: #ffffff;
    text-transform: uppercase;
    text-shadow: 0 2px 18px rgba(0,0,0,0.55), 0 1px 3px rgba(0,0,0,0.5);
  }
  .maq__title em { font-style: italic; color: var(--maq-gold); }
  .maq__sub {
    font-family: var(--font-body--family, sans-serif);
    font-weight: 400; font-size: 12px; line-height: 1.6; letter-spacing: 0.1em;
    color: rgba(255,255,255,0.85); max-width: 420px; margin: 0 auto 24px;
    text-transform: uppercase;
    text-shadow: 0 1px 10px rgba(0,0,0,0.5);
  }

  /* ─── Begin button ───────────────────────────────── */
  .maq__begin {
    position: relative; overflow: hidden;
    display: inline-block;
    font-family: var(--font-body--family, sans-serif);
    font-size: 12px; font-weight: 500; letter-spacing: 0.26em; text-transform: uppercase;
    color: #f4efe7; background: #1a1714;
    border: none; padding: 16px 48px; cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 10px 34px -14px rgba(26,23,20,0.6);
  }
  .maq__begin:hover { transform: translateY(-2px); box-shadow: 0 18px 40px -16px rgba(26,23,20,0.7); }
  .maq__begin::after {
    content: ''; position: absolute; top: 0; left: -130%; width: 55%; height: 100%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.35), transparent);
    transform: skewX(-20deg); transition: left 0.6s ease;
  }
  .maq__begin:hover::after { left: 150%; }

  /* ─── Answer grids ───────────────────────────────── */
  .maq__opts { display: grid; gap: 13px; width: 100%; margin: 4px auto 0; perspective: 900px; }
  .maq__opts--text     { grid-template-columns: repeat(2, 1fr); max-width: 540px; }
  .maq__opts--text.maq__opts--3 { grid-template-columns: repeat(3, 1fr); max-width: 660px; }
  .maq__opts--img      { grid-template-columns: repeat(3, 1fr); max-width: 860px; }

  .maq__opt {
    position: relative;
    border: 1px solid var(--maq-line);
    background: var(--maq-card);
    color: var(--maq-ink);
    cursor: pointer; padding: 16px 16px; text-align: center;
    transition: border-color 0.25s, background 0.25s, box-shadow 0.25s, transform 0.18s;
    overflow: hidden; transform-style: preserve-3d; will-change: transform;
    backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
  }
  /* gold spotlight follows cursor */
  .maq__opt::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(160px 120px at var(--mx,50%) var(--my,50%), color-mix(in srgb, var(--maq-gold) 24%, transparent), transparent 70%);
    opacity: 0; transition: opacity 0.25s ease; pointer-events: none;
  }
  .maq__opt:hover { border-color: var(--maq-gold); background: rgba(255,255,255,0.78); box-shadow: 0 16px 34px -18px color-mix(in srgb, var(--maq-gold) 55%, rgba(28,37,48,0.5)); }
  .maq__opt:hover::before { opacity: 1; }
  .maq__opt.is-sel {
    border-color: var(--maq-gold);
    background: color-mix(in srgb, var(--maq-gold) 16%, #fff);
    box-shadow: 0 0 0 2px var(--maq-gold), 0 16px 34px -16px color-mix(in srgb, var(--maq-gold) 70%, rgba(28,37,48,0.4));
  }
  .maq__opt-label {
    font-family: var(--font-heading--family, serif);
    font-size: 14px; letter-spacing: 0.12em; margin: 0; position: relative; z-index: 2; color: var(--maq-ink);
    text-transform: uppercase;
  }
  .maq__opt-sub {
    font-family: var(--font-body--family, sans-serif);
    font-size: 10px; font-weight: 400; color: var(--maq-mut);
    margin: 5px 0 0; letter-spacing: 0.16em; position: relative; z-index: 2;
    text-transform: uppercase;
  }

  /* image answer tiles */
  .maq__opt--img {
    padding: 0; aspect-ratio: 3 / 4;
    display: flex; align-items: flex-end; justify-content: center;
    background-size: cover; background-position: center;
    background-color: #d6cfc4;
  }
  .maq__opt--img::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(26,23,20,0.80) 0%, rgba(26,23,20,0.08) 58%, rgba(26,23,20,0.28) 100%);
    transition: background 0.3s ease; z-index: 1;
  }
  .maq__opt--img:hover::after { background: linear-gradient(to top, rgba(26,23,20,0.72) 0%, rgba(26,23,20,0.02) 62%, rgba(26,23,20,0.18) 100%); }
  .maq__opt--img .maq__opt-cap { position: relative; z-index: 3; padding: 0 12px 16px; width: 100%; }
  .maq__opt--img .maq__opt-label { font-size: 15px; color: #f4efe7; }
  .maq__opt--img .maq__opt-sub { color: rgba(244,239,231,0.85); }

  /* gradient fallbacks */
  .maq__opt--g0 { background-image: linear-gradient(150deg, #c4b8a4, #9a8e7c); }
  .maq__opt--g1 { background-image: linear-gradient(150deg, #a4b8c4, #7c9aaa); }
  .maq__opt--g2 { background-image: linear-gradient(150deg, #c4a898, #a07864); }
  .maq__opt--g3 { background-image: linear-gradient(150deg, #a4c4ac, #7a9a80); }
  .maq__opt--g4 { background-image: linear-gradient(150deg, #b4a8c4, #8878a0); }
  .maq__opt--g5 { background-image: linear-gradient(150deg, #c4a4a8, #a07078); }

  /* ─── Back / nav ─────────────────────────────────── */
  .maq__nav { margin-top: 26px; display: flex; align-items: center; gap: 26px; justify-content: center; }
  .maq__back {
    background: none; border: none; color: rgba(255,255,255,0.78);
    font-family: var(--font-body--family, sans-serif);
    font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
    cursor: pointer; padding: 6px 2px; transition: color 0.2s ease;
    text-shadow: 0 1px 8px rgba(0,0,0,0.45);
  }
  .maq__back:hover { color: #ffffff; }

  /* ─── Screen transitions (3D flip) ──────────────── */
  .maq__screens { perspective: 1100px; }
  .maq__screen  { width: 100%; }
  .maq__fade { animation: maqIn 0.55s cubic-bezier(.22,.61,.36,1) both; transform-origin: 50% 0; }
  @keyframes maqIn {
    from { opacity: 0; transform: translateY(22px) rotateX(6deg) scale(0.988); }
    to   { opacity: 1; transform: translateY(0)    rotateX(0)    scale(1); }
  }

  /* ─── Result screen ──────────────────────────────── */
  .maq__result { width: 100%; }
  .maq__result-eyebrow {
    font-family: var(--font-body--family, sans-serif);
    font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--maq-gold); margin: 0 0 12px;
  }
  .maq__result-eyebrow { text-shadow: 0 1px 8px rgba(0,0,0,0.5); }
  .maq__result-title {
    font-family: var(--font-heading--family, serif);
    font-weight: 400; font-size: clamp(24px, 3.6vw, 40px);
    margin: 0 0 26px; color: #ffffff;
    text-shadow: 0 2px 18px rgba(0,0,0,0.55), 0 1px 3px rgba(0,0,0,0.5);
  }
  .maq__hero {
    display: flex; gap: 36px; align-items: center; text-align: left;
    max-width: 720px; margin: 0 auto 28px; flex-wrap: wrap; justify-content: center;
  }
  .maq__hero-img {
    width: 220px; flex: 0 0 220px; aspect-ratio: 3/4;
    background: #d6cfc4; object-fit: cover; border-radius: 2px;
    box-shadow: 0 30px 70px -20px color-mix(in srgb, var(--maq-orb) 45%, rgba(26,23,20,0.3)), 0 0 40px 2px color-mix(in srgb, var(--maq-orb) 14%, transparent);
    transition: transform 0.4s ease;
  }
  .maq__hero-img:hover { transform: translateY(-4px) rotate(-0.4deg); }
  .maq__hero-info { flex: 1; min-width: 240px; }
  .maq__hero-badge {
    font-family: var(--font-body--family, sans-serif);
    font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.75); margin: 0 0 8px;
  }
  .maq__hero-name {
    font-family: var(--font-heading--family, serif);
    font-size: 24px; letter-spacing: 0.04em; text-transform: uppercase;
    margin: 0 0 8px; color: #ffffff;
    text-shadow: 0 2px 14px rgba(0,0,0,0.5);
  }
  .maq__hero-reason {
    font-family: var(--font-body--family, sans-serif);
    font-size: 14px; font-weight: 300; line-height: 1.55;
    color: rgba(255,255,255,0.85); margin: 0 0 14px;
    text-shadow: 0 1px 8px rgba(0,0,0,0.45);
  }
  .maq__stars { color: var(--maq-gold); letter-spacing: 2px; font-size: 15px; margin: 0 0 12px; }
  .maq__stars span { color: rgba(255,255,255,0.3); }
  .maq__hero-price {
    font-family: var(--font-body--family, sans-serif);
    font-size: 20px; margin: 0 0 18px; color: #ffffff;
    text-shadow: 0 1px 8px rgba(0,0,0,0.45);
  }
  .maq__bag {
    position: relative; overflow: hidden;
    font-family: var(--font-body--family, sans-serif);
    font-size: 12px; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase;
    color: #f4efe7; background: #1a1714;
    border: none; padding: 14px 34px; cursor: pointer; transition: transform 0.2s ease;
  }
  .maq__bag:hover { transform: translateY(-2px); }
  .maq__bag::after {
    content: ''; position: absolute; top: 0; left: -130%; width: 55%; height: 100%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.35), transparent);
    transform: skewX(-20deg); transition: left 0.6s ease;
  }
  .maq__bag:hover::after { left: 150%; }
  .maq__bag:disabled { opacity: 0.55; cursor: default; }

  .maq__also-title {
    font-family: var(--font-body--family, sans-serif);
    font-size: 11px; letter-spacing: 0.24em; text-transform: uppercase;
    color: rgba(255,255,255,0.8); margin: 32px 0 16px;
    text-shadow: 0 1px 8px rgba(0,0,0,0.45);
  }
  .maq__also {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 18px; max-width: 540px; margin: 0 auto;
  }
  .maq__also-card { text-decoration: none; color: inherit; display: block; transition: transform 0.3s ease; }
  .maq__also-card:hover { transform: translateY(-4px); }
  .maq__also-card img { width: 100%; aspect-ratio: 3/4; object-fit: cover; background: #d6cfc4; border-radius: 2px; }
  .maq__also-name {
    font-family: var(--font-heading--family, serif);
    font-size: 14px; letter-spacing: 0.04em; text-transform: uppercase; margin: 10px 0 4px;
    color: #ffffff; text-shadow: 0 1px 8px rgba(0,0,0,0.45);
  }
  .maq__also-price { font-family: var(--font-body--family, sans-serif); font-size: 14px; color: rgba(255,255,255,0.8); }

  .maq__save {
    margin: 38px auto 0; max-width: 420px;
    border-top: 1px solid var(--maq-line); padding-top: 24px;
  }
  .maq__save p {
    font-family: var(--font-body--family, sans-serif);
    font-size: 12px; letter-spacing: 0.04em; color: rgba(255,255,255,0.82); margin: 0 0 14px;
    text-shadow: 0 1px 8px rgba(0,0,0,0.45);
  }
  .maq__save-row { display: flex; gap: 8px; }
  .maq__save input {
    flex: 1; background: rgba(255,255,255,0.7); border: 1px solid var(--maq-line);
    color: var(--maq-ink); padding: 12px 14px; font-size: 13px;
    font-family: var(--font-body--family, sans-serif);
  }
  .maq__save input::placeholder { color: rgba(26,23,20,0.38); }
  .maq__save button {
    background: var(--maq-gold); color: #1a1714; border: none;
    padding: 0 22px; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    cursor: pointer; font-family: var(--font-body--family, sans-serif);
  }
  .maq__retake {
    margin-top: 24px; display: inline-block;
    font-family: var(--font-body--family, sans-serif);
    font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(255,255,255,0.75); background: none; border: none; cursor: pointer;
    text-shadow: 0 1px 8px rgba(0,0,0,0.45);
  }
  .maq__retake:hover { color: #ffffff; }
  .maq__explore {
    display: block; margin-top: 14px;
    font-family: var(--font-body--family, sans-serif);
    font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--maq-gold); text-decoration: none;
  }
  .maq__empty { color: var(--maq-mut); font-family: var(--font-body--family, sans-serif); }

  /* ─── Mobile ─────────────────────────────────────── */
  @media (max-width: 767px) {
    .maq__inner { padding: 22px 16px 26px; }
    .maq__eyebrow { margin-bottom: 10px; }
    .maq__opts { gap: 9px; }
    .maq__opts--text { grid-template-columns: 1fr; max-width: 340px; gap: 9px; }
    .maq__opts--text.maq__opts--3 { grid-template-columns: 1fr; }
    .maq__opts--img { grid-template-columns: repeat(2, 1fr); max-width: 420px; gap: 9px; }
    .maq__opt { padding: 13px 14px; }
    .maq__opt--img { aspect-ratio: 1 / 1; }
    .maq__title { font-size: clamp(19px, 6vw, 26px); margin-bottom: 10px; }
    .maq__sub { font-size: 11px; margin-bottom: 18px; }
    .maq__nav { margin-top: 18px; }
    .maq__hero { flex-direction: column; text-align: center; gap: 16px; }
    .maq__hero-info { text-align: center; }
    .maq__hero-img { width: 150px; flex-basis: 150px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .maq__fade { animation: none; }
  }
</style>

{%- if maq_is_page -%}
<!-- Fixed minimal topbar replacing site navigation (page only) -->
<div class="maq-page-topbar">
  <a href="/">{{ section.settings.page_brand | default: 'Maison Amiir' }}</a>
</div>
{%- endif -%}

<div class="maq-page-wrap">
<section id="maq-{{ section.id }}" class="maq">

  <div class="maq__media">
    {%- if section.settings.bg_video != blank -%}
      {{ section.settings.bg_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, preload: 'metadata' }}
    {%- elsif maq_bg_url != '' -%}
      <img src="{{ maq_bg_url }}" alt="" loading="eager" fetchpriority="high">
    {%- endif -%}
  </div>

  <script type="application/json" id="maq-data-{{ section.id }}">
  [
    {%- for product in quiz_products -%}
      {
        "id": {{ product.id }},
        "title": {{ product.title | json }},
        "url": {{ product.url | json }},
        "available": {{ product.available | json }},
        "price": {{ product.price | money_without_currency | json }},
        {%- assign p_img_url = '' -%}{%- if product.featured_image != blank -%}{%- assign p_img_url = product.featured_image | image_url: width: 700 -%}{%- endif -%}
        "image": {{ p_img_url | json }},
        "variantId": {{ product.selected_or_first_available_variant.id | default: product.variants.first.id | json }},
        "tags": {{ product.tags | json }},
        "type": {{ product.type | json }},
        "rating": {{ product.metafields.reviews.rating.value.rating | default: 0 | json }},
        "ratingCount": {{ product.metafields.reviews.rating_count.value | default: 0 | json }},
        "inspired": {{ product.metafields.custom.inspired_by.value | default: '' | json }},
        "collections": {{ product.collections | map: 'handle' | json }}
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
  </script>

  <div class="maq__progress" id="maq-prog-{{ section.id }}">
    <span class="maq__progress-label" id="maq-prog-label-{{ section.id }}">Question 1 / 6</span>
    <div class="maq__progress-track"><div class="maq__progress-fill" id="maq-prog-fill-{{ section.id }}"></div></div>
  </div>

  <div class="maq__inner">
    <div class="maq__screens" id="maq-screens-{{ section.id }}">
      <div class="maq__screen maq__fade" id="maq-intro-{{ section.id }}">
        <p class="maq__eyebrow">{{ section.settings.eyebrow | default: 'Maison Amiir' }}</p>
        <h2 class="maq__title">{{ section.settings.headline | default: 'Find Your <em>Signature</em>' }}</h2>
        <p class="maq__sub">{{ section.settings.subtext | default: 'Six questions. The house already knows you — let it choose your scent.' }}</p>
        <button class="maq__begin" id="maq-begin-{{ section.id }}">{{ section.settings.begin_label | default: 'Begin' }}</button>
      </div>
    </div>
  </div>

  <script>
  (function(){
    /* lock page — hide site nav, show only our topbar (page template only) */
    {%- if maq_is_page %}
    document.body.classList.add('maq-page-locked');
    /* theme-agnostic header hide: works whatever the theme calls its header/announcement */
    (function(){
      var sels = [
        '.ma-header-wrap', '.ma-announcement', '.custom-header',
        '.ma-search-overlay', '.ma-drawer', '.ma-search',
        '#header-group', '.header-section', 'header-component', '#header-component',
        '.shopify-section-group-header-group',
        'header', '.header', '[class*="site-header"]', '[class*="page-header"]',
        '[class*="announcement"]',
        'footer', '.footer', '.footer-section', '#footer-group',
        '.shopify-section-group-footer-group', '[class*="site-footer"]', '[id*="shopify-section-footer"]'
      ];
      function hideAll(){
        sels.forEach(function(s){
          document.querySelectorAll(s).forEach(function(el){
            /* never hide our own quiz section / topbar */
            if (el.closest('#maq-' + SID) || el.classList.contains('maq-page-topbar')) return;
            el.style.setProperty('display', 'none', 'important');
          });
        });
        /* the custom header's script pads the body to clear its fixed bar — undo it */
        document.body.style.setProperty('padding-top', '0', 'important');
        document.documentElement.style.setProperty('--ma-header-h', '0px');
      }
      /* hide every OTHER section on this page (e.g. the page-title heading) so only the quiz shows */
      function hideSiblings(){
        var mySec = document.getElementById('maq-' + SID);
        if (!mySec) return;
        var mine = mySec.closest('.shopify-section') || mySec;
        document.querySelectorAll('main .shopify-section, #MainContent .shopify-section, [role="main"] .shopify-section').forEach(function(s){
          if (s === mine || s.contains(mine) || mine.contains(s)) return;
          s.style.setProperty('display', 'none', 'important');
        });
      }
      hideAll(); hideSiblings();
      /* the header script runs after load and re-adds body padding; re-clear a few times */
      var n = 0, iv = setInterval(function(){ hideAll(); hideSiblings(); if (++n > 10) clearInterval(iv); }, 200);
    })();
    {%- endif %}

    var SID = '{{ section.id }}';
    var ROOT = document.getElementById('maq-' + SID);
    if (!ROOT) return;

    var DATA;
    try { DATA = JSON.parse(document.getElementById('maq-data-' + SID).textContent); }
    catch (e) { DATA = []; }

    var IMG = {
      q2: [
        {{ q2_img1_url | json }},
        {{ q2_img2_url | json }},
        {{ q2_img3_url | json }},
        {{ q2_img4_url | json }},
        {{ q2_img5_url | json }}
      ],
      q6: [
        {{ q6_img1_url | json }},
        {{ q6_img2_url | json }},
        {{ q6_img3_url | json }},
        {{ q6_img4_url | json }},
        {{ q6_img5_url | json }},
        {{ q6_img6_url | json }}
      ]
    };

    var CFG = {
      accent: {{ section.settings.accent_color | default: '#B89766' | json }},
      resultEyebrow: {{ section.settings.result_eyebrow | default: 'Your Signature' | json }},
      resultTitle: {{ section.settings.result_title | default: 'We found your scent.' | json }},
      saveText: {{ section.settings.save_text | default: 'Save your result - we will send it to your inbox.' | json }},
      exploreLink: {{ section.settings.explore_link | default: '/collections/all-perfumes' | json }}
    };

    var REDUCED = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    var FAMILY_COLOR = {
      woody:'#8b6f3e', smoky:'#7a7060', marine:'#4a7a96', fresh:'#5a9080', aquatic:'#4a8090',
      floral:'#c07890', amber:'#c98a3a', sweet:'#b07a4a', leather:'#7a5a36', citrus:'#b89a2a',
      spicy:'#b06040', powdery:'#c0a0b0', gourmand:'#a07840', musky:'#907a60', creamy:'#c0a060'
    };

    var QUESTIONS = [
      { eyebrow:'Question 1', title:'Who are you choosing for?', kind:'text', cols:3, options:[
        { label:'Masculine', gender:'masculine', w:{} },
        { label:'Feminine', gender:'feminine', w:{} },
        { label:"It does not matter", sub:'Unisex', gender:'any', w:{} }
      ]},
      { eyebrow:'Question 2', title:"Choose the world you'd disappear into.", kind:'img', set:'q2', options:[
        { label:'Desert at dusk',      w:{ family:{ woody:2, smoky:2, amber:1 } } },
        { label:'Mediterranean coast', w:{ family:{ marine:3, fresh:2, citrus:1, aquatic:2 } } },
        { label:'Candlelit interior',  w:{ family:{ amber:2, sweet:2, woody:1 } } },
        { label:'Rain-soaked forest',  w:{ family:{ woody:2, fresh:1, smoky:1 }, mood:{ calm:1 } } },
        { label:'City after midnight', w:{ family:{ leather:2, smoky:2, spicy:1 }, mood:{ mysterious:1 } } }
      ]},
      { eyebrow:'Question 3', title:'Your scent should feel...', kind:'text', cols:2, options:[
        { label:'Fresh & luminous',  w:{ family:{ fresh:3, marine:1, citrus:1 }, mood:{ calm:1 } } },
        { label:'Warm & enveloping', w:{ family:{ amber:2, sweet:2, woody:1 }, mood:{ comforting:1, warm:1 } } },
        { label:'Dark & mysterious', w:{ family:{ smoky:2, woody:2, leather:1 }, mood:{ mysterious:2, dark:1 } } },
        { label:'Soft & romantic',   w:{ family:{ floral:2, sweet:1, powdery:1 }, mood:{ romantic:2, sensual:1 } } }
      ]},
      { eyebrow:'Question 4', title:'When will you wear it most?', kind:'text', cols:2, options:[
        { label:'Daytime & work',        w:{ occasion:{ office:2, day:2 }, intensity:{ soft:1, moderate:1 } } },
        { label:'Summer & open air',     w:{ season:{ summer:3 }, occasion:{ sport:1, day:1 }, family:{ fresh:1 } } },
        { label:'Evenings & occasions',  w:{ occasion:{ evening:2, special:1 }, intensity:{ strong:1 } } },
        { label:'Cold-weather intimacy', w:{ season:{ winter:3 }, occasion:{ evening:1 }, mood:{ intimate:1 }, family:{ amber:1 } } }
      ]},
      { eyebrow:'Question 5', title:'How loud should your trail be?', kind:'text', cols:3, options:[
        { label:'A quiet whisper',           sub:'Intimate', w:{ intensity:{ soft:3 } } },
        { label:'A confident presence',      sub:'Balanced', w:{ intensity:{ moderate:3 } } },
        { label:'An unforgettable statement',sub:'Bold',     w:{ intensity:{ strong:3 }, mood:{ bold:1 } } }
      ]},
      { eyebrow:'Question 6', title:'Choose the note that calls you.', kind:'img', set:'q6', options:[
        { label:'Oud',     w:{ family:{ woody:3, smoky:2 } } },
        { label:'Rose',    w:{ family:{ floral:3, powdery:1 } } },
        { label:'Vanilla', w:{ family:{ sweet:3, amber:1 } } },
        { label:'Citrus',  w:{ family:{ fresh:2, citrus:3, marine:1 } } },
        { label:'Leather', w:{ family:{ leather:3, smoky:1, woody:1 } } },
        { label:'Amber',   w:{ family:{ amber:3, sweet:1, warm:1 } } }
      ]}
    ];

    function enrich(p){
      var ts = new Set();
      (p.tags || []).forEach(function(t){
        t = String(t).toLowerCase().trim();
        if (!t) return;
        ts.add(t);
        if (t.indexOf(':') > -1) ts.add(t.split(':').pop().trim());
      });
      if (p.type) ts.add(String(p.type).toLowerCase().trim());
      var cols = (p.collections || []).join(' ').toLowerCase();
      if (cols.indexOf('summer') > -1) ts.add('summer');
      if (cols.indexOf('winter') > -1) ts.add('winter');
      var gender = 'unisex';
      if (ts.has('feminine') || ts.has('gender:feminine') || /women|feminine|ladies/.test(cols)) gender = 'feminine';
      else if (ts.has('masculine') || ts.has('gender:masculine') || /(^|[^o])men|masculine|homme/.test(cols)) gender = 'masculine';
      else if (ts.has('unisex') || /unisex/.test(cols)) gender = 'unisex';
      return Object.assign({}, p, { tagset: ts, gender: gender, _score: 0 });
    }
    var PRODUCTS = DATA.map(enrich);

    var answers = {};
    var profile = {};
    var genderChoice = null;
    var cur = -1;
    var screens = document.getElementById('maq-screens-' + SID);
    var prog = document.getElementById('maq-prog-' + SID);
    var progLabel = document.getElementById('maq-prog-label-' + SID);
    var progFill = document.getElementById('maq-prog-fill-' + SID);

    var INTRO_HTML = screens.innerHTML;

    function rebuildProfile(){
      profile = {};
      genderChoice = null;
      var lastFamColor = null;
      Object.keys(answers).forEach(function(qi){
        var q = QUESTIONS[qi];
        var opt = q.options[answers[qi]];
        if (opt.gender) genderChoice = opt.gender;
        var w = opt.w || {};
        for (var dim in w){
          if (!profile[dim]) profile[dim] = {};
          for (var tag in w[dim]) profile[dim][tag] = (profile[dim][tag] || 0) + w[dim][tag];
        }
        var fam = dominantFamily(w);
        if (fam && FAMILY_COLOR[fam]) lastFamColor = FAMILY_COLOR[fam];
      });
    }

    function dominantFamily(w){
      if (!w.family) return null;
      var best = null, bv = -1;
      for (var k in w.family){ if (w.family[k] > bv){ bv = w.family[k]; best = k; } }
      return best;
    }

    function setProgress(i){
      if (i < 0){ prog.classList.remove('is-on'); return; }
      prog.classList.add('is-on');
      progLabel.textContent = 'Question ' + (i + 1) + ' / ' + QUESTIONS.length;
      progFill.style.width = ((i + 1) / QUESTIONS.length * 100) + '%';
    }

    function attachTilt(){
      if (REDUCED) return;
      screens.querySelectorAll('.maq__opt').forEach(function(card){
        card.addEventListener('pointermove', function(e){
          var r = card.getBoundingClientRect();
          var px = (e.clientX - r.left) / r.width;
          var py = (e.clientY - r.top) / r.height;
          var rx = (0.5 - py) * 8;
          var ry = (px - 0.5) * 8;
          card.style.transform = 'perspective(800px) rotateX(' + rx.toFixed(2) + 'deg) rotateY(' + ry.toFixed(2) + 'deg) translateZ(6px)';
          card.style.setProperty('--mx', (px * 100) + '%');
          card.style.setProperty('--my', (py * 100) + '%');
        });
        card.addEventListener('pointerleave', function(){ card.style.transform = ''; });
      });
    }

    function renderQuestion(i){
      cur = i;
      setProgress(i);
      try { window.scrollTo({ top: 0, behavior: 'smooth' }); } catch(e){ window.scrollTo(0,0); }
      var q = QUESTIONS[i];
      var html = '<div class="maq__screen maq__fade">';
      html += '<p class="maq__eyebrow">' + q.eyebrow + '</p>';
      html += '<h2 class="maq__title">' + q.title + '</h2>';

      var gridCls = 'maq__opts ';
      if (q.kind === 'img') gridCls += 'maq__opts--img';
      else gridCls += 'maq__opts--text' + (q.cols === 3 ? ' maq__opts--3' : '');
      html += '<div class="' + gridCls + '">';

      q.options.forEach(function(opt, oi){
        var sel = (answers[i] === oi) ? ' is-sel' : '';
        if (q.kind === 'img'){
          var url = IMG[q.set] && IMG[q.set][oi] ? IMG[q.set][oi] : '';
          var style = url ? ' style="background-image:url(' + url + ')"' : '';
          var gcls = url ? '' : ' maq__opt--g' + oi;
          html += '<button class="maq__opt maq__opt--img' + gcls + sel + '" data-oi="' + oi + '"' + style + '>'
                + '<span class="maq__opt-cap"><p class="maq__opt-label">' + opt.label + '</p>'
                + (opt.sub ? '<p class="maq__opt-sub">' + opt.sub + '</p>' : '') + '</span></button>';
        } else {
          html += '<button class="maq__opt' + sel + '" data-oi="' + oi + '">'
                + '<p class="maq__opt-label">' + opt.label + '</p>'
                + (opt.sub ? '<p class="maq__opt-sub">' + opt.sub + '</p>' : '') + '</button>';
        }
      });
      html += '</div>';
      html += '<div class="maq__nav"><button class="maq__back" data-back="1">&larr; Back</button></div>';
      html += '</div>';
      screens.innerHTML = html;

      screens.querySelectorAll('.maq__opt').forEach(function(btn){
        btn.addEventListener('click', function(){
          select(i, parseInt(btn.getAttribute('data-oi'), 10));
        });
      });
      attachTilt();
      var back = screens.querySelector('[data-back]');
      if (back) back.addEventListener('click', function(){
        if (cur === 0) showIntro();
        else renderQuestion(cur - 1);
      });
    }

    function select(qi, oi){
      answers[qi] = oi;
      rebuildProfile();
      screens.querySelectorAll('.maq__opt').forEach(function(b){ b.classList.remove('is-sel'); });
      var chosen = screens.querySelector('.maq__opt[data-oi="' + oi + '"]');
      if (chosen) chosen.classList.add('is-sel');
      setTimeout(function(){
        if (qi >= QUESTIONS.length - 1) showResult();
        else renderQuestion(qi + 1);
      }, 360);
    }

    function showIntro(){
      cur = -1;
      setProgress(-1);
      screens.innerHTML = INTRO_HTML;
      var b = document.getElementById('maq-begin-' + SID);
      if (b) b.addEventListener('click', start);
    }

    function scoreProduct(p){
      var s = 0;
      for (var dim in profile){
        var w = profile[dim];
        for (var tag in w){ if (p.tagset.has(tag)) s += w[tag]; }
      }
      return s;
    }

    function reason(p){
      var fams = [], fw = profile.family || {};
      Object.keys(fw).sort(function(a,b){ return fw[b] - fw[a]; }).forEach(function(k){
        if (p.tagset.has(k) && fams.length < 2) fams.push(k);
      });
      var mood = null, mw = profile.mood || {};
      Object.keys(mw).sort(function(a,b){ return mw[b] - mw[a]; }).some(function(k){
        if (p.tagset.has(k)){ mood = k; return true; } return false;
      });
      if (fams.length){
        return 'Chosen for your love of ' + fams.join(' & ') + (mood ? ', with a ' + mood + ' character.' : '.');
      }
      return 'A standout match for your signature profile.';
    }

    function stars(rating){
      var r = Math.round(parseFloat(rating) || 0);
      var out = '';
      for (var i = 1; i <= 5; i++) out += (i <= r) ? '&#9733;' : '<span>&#9733;</span>';
      return out;
    }
    function price(p){ return '&#8377;' + String(p.price || '').replace(/\.00$/, ''); }

    function showResult(){
      setProgress(-1);

      var avail = PRODUCTS.filter(function(p){ return p.available !== false && p.variantId; });
      if (!avail.length){
        screens.innerHTML = '<div class="maq__screen maq__fade"><p class="maq__empty">No products are available right now.</p>'
          + '<button class="maq__retake">Retake the quiz</button></div>';
        screens.querySelector('.maq__retake').addEventListener('click', reset);
        return;
      }

      avail.forEach(function(p){
        p._score = scoreProduct(p);
        if (genderChoice && genderChoice !== 'any' && p.gender === genderChoice) p._score += 1000;
      });
      avail.sort(function(a, b){
        return (b._score - a._score) || ((parseFloat(b.rating)||0) - (parseFloat(a.rating)||0));
      });
      var top = avail.slice(0, 3);
      var primary = top[0];
      var also = top.slice(1);

      var html = '<div class="maq__result maq__fade">';
      html += '<p class="maq__result-eyebrow">' + esc(CFG.resultEyebrow) + '</p>';
      html += '<h2 class="maq__result-title">' + esc(CFG.resultTitle) + '</h2>';

      html += '<div class="maq__hero">';
      html += '<a href="' + primary.url + '">' + (primary.image ? '<img class="maq__hero-img" src="' + primary.image + '" alt="' + esc(primary.title) + '">' : '<div class="maq__hero-img"></div>') + '</a>';
      html += '<div class="maq__hero-info">';
      if (primary.inspired) html += '<p class="maq__hero-badge">' + esc(primary.inspired) + '</p>';
      html += '<h3 class="maq__hero-name"><a href="' + primary.url + '" style="color:inherit;text-decoration:none;">' + esc(primary.title) + '</a></h3>';
      html += '<p class="maq__hero-reason">' + reason(primary) + '</p>';
      if ((parseFloat(primary.rating)||0) > 0) html += '<p class="maq__stars">' + stars(primary.rating) + '</p>';
      html += '<p class="maq__hero-price">' + price(primary) + '</p>';
      html += '<button class="maq__bag" data-vid="' + primary.variantId + '">Add to Bag</button>';
      html += '</div></div>';

      if (also.length){
        html += '<p class="maq__also-title">You may also love</p><div class="maq__also">';
        also.forEach(function(p){
          html += '<a class="maq__also-card" href="' + p.url + '">'
            + (p.image ? '<img src="' + p.image + '" alt="' + esc(p.title) + '">' : '<div style="aspect-ratio:3/4;background:#d6cfc4;border-radius:2px;"></div>')
            + '<p class="maq__also-name">' + esc(p.title) + '</p>'
            + '<p class="maq__also-price">' + price(p) + '</p></a>';
        });
        html += '</div>';
      }

      html += '<div class="maq__save">'
        + '<p>' + esc(CFG.saveText) + '</p>'
        + '<form method="post" action="/contact#contact_form" class="maq__save-row">'
        + '<input type="hidden" name="form_type" value="customer">'
        + '<input type="hidden" name="utf8" value="&#10003;">'
        + '<input type="hidden" name="contact[tags]" value="newsletter, find-your-signature">'
        + '<input type="email" name="contact[email]" placeholder="Your email" required>'
        + '<button type="submit">Save</button>'
        + '</form></div>';

      html += '<button class="maq__retake">Retake the quiz</button>';
      html += '<a class="maq__explore" href="' + esc(CFG.exploreLink) + '">Explore the full collection</a>';
      html += '</div>';

      screens.innerHTML = html;

      var bag = screens.querySelector('.maq__bag');
      if (bag) bag.addEventListener('click', function(){ addToBag(bag.getAttribute('data-vid'), bag); });
      screens.querySelector('.maq__retake').addEventListener('click', reset);
    }

    function addToBag(vid, btn){
      btn.disabled = true; btn.textContent = 'Adding...';
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: parseInt(vid, 10), quantity: 1 }] })
      }).then(function(r){ return r.json(); })
        .then(function(){ window.location.href = '/cart'; })
        .catch(function(){ btn.disabled = false; btn.textContent = 'Add to Bag'; });
    }

    function esc(s){ return String(s == null ? '' : s).replace(/[&<>"]/g, function(c){
      return { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[c]; }); }

    function start(){ answers = {}; renderQuestion(0); }
    function reset(){ answers = {}; rebuildProfile(); showIntro(); }

    var beginBtn = document.getElementById('maq-begin-' + SID);
    if (beginBtn) beginBtn.addEventListener('click', start);
  })();
  </script>

</section>
</div>

{% schema %}
{
  "name": "Find Your Signature",
  "tag": "section",
  "class": "ma-find-signature",
  "settings": [
    { "type": "header", "content": "Page brand name" },
    { "type": "text", "id": "page_brand", "label": "Brand name at top of page (links to homepage)", "default": "Maison Amiir" },
    { "type": "header", "content": "Source" },
    { "type": "collection", "id": "collection", "label": "Products to draw from", "info": "Leave empty to use every product in the store." },
    { "type": "header", "content": "Background media (optional)" },
