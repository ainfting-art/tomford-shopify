{% comment %} Most Wanted — Maison Amiir {% endcomment %}

<style>
  .ma-picks {
    background: #ffffff;
    padding: 60px 48px 80px;
  }

  .ma-picks__header {
    margin-bottom: 28px;
  }

  .ma-picks__eyebrow {
    font-family: var(--font-body--family, sans-serif);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #a89566;
    margin: 0 0 10px;
    line-height: 1;
  }

  .ma-picks__title {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 28px;
    font-weight: 400 !important;
    letter-spacing: 0.14em !important;
    text-transform: uppercase;
    color: #1a1a1a;
    margin: 0 0 12px;
    line-height: 1.15;
  }

  .ma-picks__cta-link {
    display: inline-block;
    font-family: var(--font-body--family, sans-serif);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #1a1a1a;
    text-decoration: none;
    border-bottom: 1px solid #a89566;
    padding-bottom: 3px;
    transition: opacity 0.2s ease;
  }
  .ma-picks__cta-link:hover { opacity: 0.4; }

  .ma-picks__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .ma-picks__card a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .ma-picks__img-wrap {
    position: relative;
    background: #f5f5f3;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  .ma-picks__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.55s ease;
  }

  .ma-picks__card:hover .ma-picks__img-wrap img {
    transform: scale(1.04);
  }

  .ma-picks__badge {
    position: absolute;
    top: 20px;
    left: 2px;
    background: rgba(255, 255, 255, 0.92);
    font-family: var(--font-body--family, sans-serif);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #1a1a1a;
    padding: 5px 9px;
    z-index: 2;
    line-height: 1;
    pointer-events: none;
  }

  .ma-picks__overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 18, 32, 0.42);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 3;
  }
  .ma-picks__card:hover .ma-picks__overlay { opacity: 1; }

  .ma-picks__overlay-btn {
    font-family: var(--font-body--family, sans-serif);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #ffffff;
    border-bottom: 1px solid rgba(255,255,255,0.85);
    padding-bottom: 4px;
  }

  .ma-picks__info {
    padding: 14px 0 0;
  }

  .ma-picks__name {
    font-family: var(--font-heading--family, serif);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1a1a1a;
    margin: 0 0 6px;
    line-height: 1.3;
  }

  .ma-picks__interp {
    font-family: var(--font-body--family, sans-serif);
    font-size: 16px;
    font-weight: 300;
    color: #888;
    margin: 0 0 10px;
    line-height: 1.45;
  }

  .ma-picks__stars {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 9px;
  }

  .ma-picks__stars-icons {
    display: flex;
    gap: 3px;
  }

  .ma-picks__star {
    font-size: 22px;
    line-height: 1;
    color: #d0d0d0;
  }

  .ma-picks__star--filled {
    color: #1a1a1a;
  }

  .ma-picks__stars-count {
    font-family: var(--font-body--family, sans-serif);
    font-size: 12px;
    color: #888;
    font-weight: 300;
  }

  .ma-picks__price {
    font-family: var(--font-body--family, sans-serif);
    font-size: 20px;
    font-weight: 400;
    color: #1a1a1a;
    margin: 0;
  }

  .ma-picks__dots { display: none; }

  /* MOBILE */
  @media (max-width: 767px) {
    .ma-picks {
      padding: 36px 0 48px;
    }
    .ma-picks__header {
      padding: 0 16px;
      margin-bottom: 20px;
    }
    .ma-picks__title { font-size: 20px; }
    .ma-picks__grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 10px;
      padding: 0 16px 4px;
      scroll-padding-left: 16px;
    }
    .ma-picks__grid::-webkit-scrollbar { display: none; }
    .ma-picks__card {
      flex: 0 0 72vw;
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }
    .ma-picks__overlay { display: none; }
    .ma-picks__name    { font-size: 16px; }
    .ma-picks__interp  { font-size: 14px; }
    .ma-picks__star    { font-size: 18px; }
    .ma-picks__price   { font-size: 16px; }

    .ma-picks__dots {
      display: flex;
      justify-content: center;
      gap: 7px;
      margin-top: 18px;
    }
    .ma-picks__dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #d0d0d0;
      border: none;
      padding: 0;
      cursor: pointer;
      transition: background 0.25s ease, width 0.25s ease;
    }
    .ma-picks__dot--active {
      background: #1a1a1a;
      width: 20px;
      border-radius: 4px;
    }
  }
</style>

{%- assign col = section.settings.collection -%}

<section class="ma-picks">
  <div class="ma-picks__header">
    {%- if section.settings.eyebrow != blank -%}
      <p class="ma-picks__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    <h2 class="ma-picks__title">{{ section.settings.heading | default: 'Most Wanted' }}</h2>
    <a class="ma-picks__cta-link" href="{{ section.settings.cta_link | default: '/collections/all' }}">
      {{ section.settings.cta_label | default: 'Shop Now' }}
    </a>
  </div>

  <div class="ma-picks__grid" id="ma-picks-{{ section.id }}">
    {%- for product in col.products limit: 4 -%}

      {%- assign inspired_by = product.metafields.custom.inspired_by.value | default: '' -%}
      {%- assign interp_text = product.metafields.custom.interpretation.value -%}
      {%- if interp_text == blank -%}
        {%- assign interp_text = product.description | strip_html | truncate: 65 -%}
      {%- endif -%}

      {%- assign rating_val   = product.metafields.reviews.rating.value.rating | default: 0 -%}
      {%- assign rating_count = product.metafields.reviews.rating_count.value | default: 0 -%}
      {%- assign rating_filled = rating_val | round -%}

      {%- assign price_raw = product.price | money_without_currency -%}
      {%- assign price_clean = price_raw | remove: '.00' -%}

      <div class="ma-picks__card" data-index="{{ forloop.index0 }}">
        <a href="{{ product.url }}">
          <div class="ma-picks__img-wrap">

            {%- if inspired_by != '' -%}
              <span class="ma-picks__badge">{{ inspired_by }}</span>
            {%- endif -%}

            {%- if product.featured_image -%}
              {{
                product.featured_image
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  widths: '300, 400, 600, 800',
                  sizes: '(max-width: 767px) 72vw, 25vw',
                  width: product.featured_image.width,
                  height: product.featured_image.height,
                  alt: product.title | escape
              }}
            {%- endif -%}

            <div class="ma-picks__overlay">
              <span class="ma-picks__overlay-btn">View Product</span>
            </div>
          </div>

          <div class="ma-picks__info">
            <p class="ma-picks__name">{{ product.title }}</p>

            {%- if interp_text != blank -%}
              <p class="ma-picks__interp">{{ interp_text }}</p>
            {%- endif -%}

            <div class="ma-picks__stars">
              <div class="ma-picks__stars-icons">
                {%- for i in (1..5) -%}
                  {%- if i <= rating_filled -%}
                    <span class="ma-picks__star ma-picks__star--filled">★</span>
                  {%- else -%}
                    <span class="ma-picks__star">☆</span>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              {%- if rating_count > 0 -%}
                <span class="ma-picks__stars-count">({{ rating_count }})</span>
              {%- endif -%}
            </div>

            <p class="ma-picks__price">₹{{ price_clean }}</p>
          </div>
        </a>
      </div>

    {%- else -%}
      <p style="color:#999;font-size:13px;padding:0 16px;">Select a collection in section settings.</p>
    {%- endfor -%}
  </div>

  <div class="ma-picks__dots" id="ma-picks-dots-{{ section.id }}">
    {%- for product in col.products limit: 4 -%}
      <button class="ma-picks__dot{% if forloop.first %} ma-picks__dot--active{% endif %}" data-index="{{ forloop.index0 }}"></button>
    {%- endfor -%}
  </div>
</section>

<script>
(function(){
  var grid = document.getElementById('ma-picks-{{ section.id }}');
  var dotsWrap = document.getElementById('ma-picks-dots-{{ section.id }}');
  if (!grid || !dotsWrap) return;
  var dots = dotsWrap.querySelectorAll('.ma-picks__dot');
  var cards = grid.querySelectorAll('.ma-picks__card');
  if (!cards.length) return;

  grid.addEventListener('scroll', function() {
    var cardW = cards[0].offsetWidth + 10;
    var i = Math.round(grid.scrollLeft / cardW);
    dots.forEach(function(d, idx){ d.classList.toggle('ma-picks__dot--active', idx === i); });
  }, { passive: true });

  dots.forEach(function(dot, i){
    dot.addEventListener('click', function(){
      grid.scrollTo({ left: i * (cards[0].offsetWidth + 10), behavior: 'smooth' });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Most Wanted Grid",
  "tag": "section",
  "class": "ma-most-wanted",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (small gold line above heading)" },
    { "type": "text", "id": "heading", "label": "Section heading", "default": "Most Wanted" },
    { "type": "collection", "id": "collection", "label": "Collection to display", "info": "First 4 products will show." },
    { "type": "url", "id": "cta_link", "label": "Shop Now link" },
    { "type": "text", "id": "cta_label", "label": "Shop Now label", "default": "Shop Now" }
  ],
  "presets": [{ "name": "Most Wanted Grid" }]
}
{% endschema %}
