{% comment %} MAISON AMIIR — §7 Social Proof: aggregate rating + rotating real review cards
   Cards pull product image/name/link from a product picker; JS shuffles and
   rotates them so each visit shows a different mix. {% endcomment %}

<div class="ma-sproof">
  <h2 class="ma-sproof__h2 ma-home-reveal">{{ section.settings.heading }}</h2>

  <div class="ma-sproof__agg ma-home-reveal">
    {%- assign rating_pct = section.settings.rating | times: 20.0 -%}
    <div class="ma-sproof__agg-stars" role="img" aria-label="{{ section.settings.rating }} out of 5 stars">
      <span class="ma-sproof__agg-stars-off" aria-hidden="true">★★★★★</span>
      <span class="ma-sproof__agg-stars-on" aria-hidden="true" style="width: {{ rating_pct }}%;">★★★★★</span>
    </div>
    <p class="ma-sproof__agg-label">{{ section.settings.aggregate }}</p>
  </div>

  <div class="ma-sproof__grid" id="ma-sproof-grid-{{ section.id }}">
    {%- for block in section.blocks -%}
      <figure class="ma-sproof__card ma-home-reveal" {{ block.shopify_attributes }}>
        <div class="ma-sproof__stars" aria-label="{{ block.settings.stars }} out of 5 stars">
          {%- assign full = block.settings.stars -%}
          {%- for i in (1..5) -%}{%- if i <= full -%}★{%- else -%}☆{%- endif -%}{%- endfor -%}
        </div>
        <blockquote class="ma-sproof__quote">&ldquo;{{ block.settings.quote }}&rdquo;</blockquote>
        <figcaption class="ma-sproof__foot">
          {%- assign prod = block.settings.product -%}
          {%- if prod != blank -%}
            <a class="ma-sproof__prod" href="{{ prod.url }}">
              {%- if prod.featured_image -%}
                {{ prod.featured_image | image_url: width: 120 | image_tag: loading: 'lazy', alt: prod.title, class: 'ma-sproof__prod-img', width: 48, height: 48 }}
              {%- endif -%}
              <span class="ma-sproof__prod-meta">
                <span class="ma-sproof__attr">{{ block.settings.author }}</span>
                <span class="ma-sproof__prod-title">{{ prod.title }}</span>
              </span>
            </a>
          {%- else -%}
            <span class="ma-sproof__attr">{{ block.settings.author }}</span>
          {%- endif -%}
        </figcaption>
      </figure>
    {%- endfor -%}
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} { opacity: 1 !important; transform: none !important; }

  .ma-sproof {
    background: #fff;
    color: rgba(0,0,0,.81);
    text-align: center;
    padding: clamp(3.5rem, 8vw, 5.5rem) clamp(1.2rem, 5vw, 3.5rem);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }
  .ma-sproof *, .ma-sproof *::before, .ma-sproof *::after { box-sizing: border-box; }

  .ma-sproof__h2 { font-family: 'Sinoreta', Georgia, serif; font-size: clamp(1.8rem, 4vw, 2.5rem); font-weight: 300; letter-spacing: .02em; color: rgba(0,0,0,.85); margin: 0 0 1.8rem; }

  .ma-sproof__agg { margin-bottom: clamp(2rem, 4.5vw, 2.8rem); }
  .ma-sproof__agg-stars { position: relative; display: inline-block; font-size: 1.15rem; letter-spacing: 2px; line-height: 1; margin-bottom: .55rem; }
  .ma-sproof__agg-stars-off { color: rgba(0,0,0,.25); }
  .ma-sproof__agg-stars-on { position: absolute; inset: 0 auto 0 0; overflow: hidden; white-space: nowrap; color: rgba(0,0,0,.85); }
  .ma-sproof__agg-label { font-size: .74rem; letter-spacing: .14em; text-transform: uppercase; color: rgba(0,0,0,.4); margin: 0; }

  .ma-sproof__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 1080px; margin: 0 auto; align-items: stretch; }
  .ma-sproof__card { border: 1px solid rgba(0,0,0,.08); padding: clamp(1.6rem, 3vw, 1.9rem) 1.5rem 1.4rem; margin: 0; text-align: center; display: flex; flex-direction: column; transition: opacity .55s ease, transform .55s ease; }
  .ma-sproof__stars { font-size: .85rem; letter-spacing: 2px; color: rgba(0,0,0,.85); margin-bottom: .95rem; }
  .ma-sproof__quote { font-family: 'Sinoreta', Georgia, serif; font-size: clamp(1.02rem, 1.5vw, 1.14rem); font-weight: 300; font-style: italic; color: rgba(0,0,0,.8); line-height: 1.7; margin: 0 0 1.2rem; flex: 1; }
  .ma-sproof__foot { border-top: 1px solid rgba(0,0,0,.07); padding-top: 1rem; }
  .ma-sproof__prod { display: inline-flex; align-items: center; gap: .8rem; text-decoration: none; }
  .ma-sproof__prod-img { width: 48px; height: 48px; object-fit: cover; display: block; }
  .ma-sproof__prod-meta { text-align: left; }
  .ma-sproof__attr { display: block; font-size: .7rem; letter-spacing: .12em; text-transform: uppercase; color: rgba(0,0,0,.55); }
  .ma-sproof__prod-title { display: block; font-size: .74rem; letter-spacing: .1em; text-transform: uppercase; color: rgba(0,0,0,.85); margin-top: .25rem; border-bottom: 1px solid rgba(0,0,0,.2); padding-bottom: .1rem; }
  .ma-sproof__prod:hover .ma-sproof__prod-title { border-color: rgba(0,0,0,.7); }

  /* no-JS: show first 3; JS takes over selection + rotation */
  .ma-sproof__card:nth-child(n+4) { display: none; }
  .ma-sproof__grid.ma-sproof--js .ma-sproof__card { display: none; }
  .ma-sproof__grid.ma-sproof--js .ma-sproof__card.is-live { display: flex; }
  .ma-sproof__grid.ma-sproof--js .ma-sproof__card.is-out { opacity: 0; transform: translateY(10px); }

  @media (max-width: 849px) {
    .ma-sproof__grid { grid-template-columns: 1fr; max-width: 460px; }
  }
</style>

<script src="{{ 'ma-social-proof.js' | asset_url }}" defer></script>
<script src="{{ 'ma-home-sections.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "MA Social Proof",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our Clients Say" },
    { "type": "range", "id": "rating", "label": "Aggregate star fill", "min": 1, "max": 5, "step": 0.1, "default": 4.3 },
    { "type": "text", "id": "aggregate", "label": "Aggregate line", "default": "4.3 · Verified Buyers" },
    { "type": "range", "id": "rotate_seconds", "label": "Seconds between rotations", "min": 3, "max": 15, "step": 1, "default": 6 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "range", "id": "stars", "label": "Stars", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "author", "label": "Customer name" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [{ "name": "MA Social Proof" }]
}
{% endschema %}
