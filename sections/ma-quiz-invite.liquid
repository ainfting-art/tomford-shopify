{% comment %} Quiz Invite — Maison Amiir homepage teaser {% endcomment %}

{%- assign bg_url = '' -%}
{%- if section.settings.bg_image != blank -%}
  {%- assign bg_url = section.settings.bg_image | image_url: width: 1800 -%}
{%- endif -%}

<style>
  #maqi-{{ section.id }} {
    --qi-bg:   #c2ccd4;
    --qi-ink:  #ffffff;
    --qi-mut:  rgba(255,255,255,0.86);
    --qi-gold: {{ section.settings.accent_color | default: '#D9B779' }};
    --qi-btn:  #2e4a5f;
    --qi-line: rgba(255,255,255,0.45);
    --qi-orb:  var(--qi-gold);
    background: #1c2530;
    color: var(--qi-ink);
    position: relative;
    overflow: hidden;
    /* Desktop: 16:9 */
    aspect-ratio: 16 / 9;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  #maqi-{{ section.id }} * { box-sizing: border-box; }

  /* ── Background media ────────────────────────────── */
  .qi__media {
    position: absolute; inset: 0; z-index: 0; overflow: hidden; pointer-events: none;
  }
  /* full-banner click target — covers the whole GIF, links to the quiz */
  .qi__coverlink {
    position: absolute; inset: 0; z-index: 1;
    display: block; text-indent: -9999px; overflow: hidden;
    cursor: pointer;
  }
  .qi__media img, .qi__media video {
    width: 100%; height: 100%; object-fit: cover;
    opacity: {{ section.settings.media_opacity | default: 100 | divided_by: 100.0 }};
    transform: scale(1.05);
    animation: qiKen 28s ease-in-out infinite alternate;
  }
  @keyframes qiKen {
    from { transform: scale(1.05) translate3d(0,0,0); }
    to   { transform: scale(1.12) translate3d(-1%, -1.5%, 0); }
  }
  /* readability scrim — darkens ONLY behind the centred text so the GIF stays visible */
  .qi__media::after {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background:
      radial-gradient(75% 65% at 50% 52%, rgba(0,0,0,0.62) 0%, rgba(0,0,0,0.34) 46%, rgba(0,0,0,0) 80%),
      linear-gradient(to bottom, rgba(0,0,0,0.30) 0%, rgba(0,0,0,0) 30%, rgba(0,0,0,0) 70%, rgba(0,0,0,0.30) 100%);
  }
  /* ── Content ─────────────────────────────────────── */
  .qi__inner {
    position: relative; z-index: 2;
    width: 100%; max-width: 720px;
    padding: 32px 28px 36px;
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: qiSlideUp 0.9s cubic-bezier(.22,.61,.36,1) both;
    /* let clicks fall through to the full-banner link; button re-enables below */
    pointer-events: none;
  }
  .qi__cta { pointer-events: auto; }
  @keyframes qiSlideUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .qi__brand {
    font-family: var(--font-body--family, sans-serif);
    font-size: 13px; letter-spacing: 0.42em; text-transform: uppercase;
    color: var(--qi-gold); margin: 0 0 10px;
    display: flex; align-items: center; justify-content: center; gap: 14px;
  }
  .qi__brand::before, .qi__brand::after {
    content: ''; display: block; width: 28px; height: 1px; background: var(--qi-gold); opacity: 0.55;
  }

  .qi__eyebrow {
    font-family: var(--font-body--family, sans-serif);
    font-size: 14px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--qi-mut); margin: 0 0 18px;
    text-shadow: 0 1px 8px rgba(0,0,0,0.5);
  }

  .qi__headline {
    font-family: var(--font-heading--family, serif);
    font-weight: 400;
    font-size: clamp(26px, 4.5vw, 52px);
    line-height: 1.08; letter-spacing: 0.01em;
    margin: 0 0 14px; color: var(--qi-ink);
    text-shadow: 0 2px 18px rgba(0,0,0,0.55), 0 1px 3px rgba(0,0,0,0.5);
  }
  .qi__headline em { font-style: italic; color: var(--qi-gold); }

  .qi__sub {
    font-family: var(--font-body--family, sans-serif);
    font-weight: 400; font-size: 14px; line-height: 1.6;
    color: var(--qi-mut); max-width: 460px; margin: 0 auto 28px;
    text-shadow: 0 1px 10px rgba(0,0,0,0.5);
  }

  /* feature pills */
  .qi__pills {
    display: flex; flex-wrap: wrap; gap: 8px;
    justify-content: center; margin: 0 auto 28px;
  }
  .qi__pill {
    display: inline-flex; align-items: center; gap: 7px;
    font-family: var(--font-body--family, sans-serif);
    font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
    color: #fff;
    border: 1px solid var(--qi-line);
    border-radius: 30px; padding: 8px 16px;
    background: rgba(0,0,0,0.22);
    backdrop-filter: blur(4px);
  }
  .qi__pill-dot {
    width: 5px; height: 5px; border-radius: 50%; background: var(--qi-gold);
    flex-shrink: 0;
    box-shadow: 0 0 6px var(--qi-gold);
  }

  /* CTA button — blue-grey steel to match palette */
  .qi__cta {
    position: relative; overflow: hidden; display: inline-block;
    font-family: var(--font-body--family, sans-serif);
    font-size: 12px; font-weight: 500; letter-spacing: 0.28em; text-transform: uppercase;
    color: #e8ecef;
    background: var(--qi-btn);
    text-decoration: none;
    border: none; padding: 16px 48px; cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
    box-shadow: 0 10px 36px -12px rgba(46,74,95,0.65);
  }
  .qi__cta:hover {
    background: #3a5c74;
    transform: translateY(-3px);
    box-shadow: 0 18px 44px -14px rgba(46,74,95,0.80);
  }
  .qi__cta::after {
    content: ''; position: absolute; top: 0; left: -140%; width: 55%; height: 100%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,0.35), transparent);
    transform: skewX(-20deg); transition: left 0.65s ease;
  }
  .qi__cta:hover::after { left: 160%; }

  .qi__hint {
    margin-top: 16px;
    font-family: var(--font-body--family, sans-serif);
    font-size: 13px; letter-spacing: 0.1em;
    color: rgba(255,255,255,0.72);
    text-shadow: 0 1px 8px rgba(0,0,0,0.5);
  }

  /* ── Decorative rule ─────────────────────────────── */
  .qi__rule {
    position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(to right, transparent, var(--qi-line) 30%, var(--qi-line) 70%, transparent);
  }

  /* ── Mobile: square(ish) ─────────────────────────── */
  @media (max-width: 767px) {
    #maqi-{{ section.id }} {
      aspect-ratio: 1 / 1.05;
    }
    .qi__inner { padding: 20px 18px 24px; }
    .qi__headline { font-size: clamp(22px, 7.5vw, 32px); margin-bottom: 10px; }
    .qi__sub { font-size: 13px; margin-bottom: 18px; }
    .qi__pills { gap: 6px; margin-bottom: 18px; }
    .qi__pill { padding: 7px 13px; font-size: 9px; }
    .qi__cta { padding: 14px 34px; font-size: 11px; }
    .qi__brand { font-size: 11px; margin-bottom: 7px; }
    .qi__eyebrow { font-size: 12px; margin-bottom: 12px; }
    .qi__hint { font-size: 11px; margin-top: 12px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .qi__media img, .qi__media video { animation: none; }
    .qi__inner { animation: none; }
  }
</style>

<div id="maqi-{{ section.id }}">

  <div class="qi__media">
    {%- if section.settings.bg_video != blank -%}
      {{ section.settings.bg_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, preload: 'metadata' }}
    {%- elsif bg_url != '' -%}
      <img src="{{ bg_url }}" alt="" loading="lazy">
    {%- endif -%}
  </div>

  {%- comment %} Whole banner is clickable — links to the quiz {% endcomment -%}
  <a class="qi__coverlink"
     href="{{ section.settings.quiz_url | default: '/pages/find-your-signature' }}"
     aria-label="{{ section.settings.cta_label | default: 'Find My Signature' }}">
    {{ section.settings.cta_label | default: 'Find My Signature' }}
  </a>

  <div class="qi__inner">

    {%- if section.settings.brand_line != blank -%}
      <p class="qi__brand">{{ section.settings.brand_line }}</p>
    {%- endif -%}

    {%- if section.settings.eyebrow != blank -%}
      <p class="qi__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    <h2 class="qi__headline">{{ section.settings.headline | default: 'Not Sure Which Scent <em>Is Yours?</em>' }}</h2>

    {%- if section.settings.subtext != blank -%}
      <p class="qi__sub">{{ section.settings.subtext }}</p>
    {%- endif -%}

    <div class="qi__pills">
      {%- if section.settings.pill1 != blank -%}
        <span class="qi__pill"><span class="qi__pill-dot"></span>{{ section.settings.pill1 }}</span>
      {%- endif -%}
      {%- if section.settings.pill2 != blank -%}
        <span class="qi__pill"><span class="qi__pill-dot"></span>{{ section.settings.pill2 }}</span>
      {%- endif -%}
      {%- if section.settings.pill3 != blank -%}
        <span class="qi__pill"><span class="qi__pill-dot"></span>{{ section.settings.pill3 }}</span>
      {%- endif -%}
    </div>

    <a class="qi__cta" href="{{ section.settings.quiz_url | default: '/pages/find-your-signature' }}">
      {{ section.settings.cta_label | default: 'Find My Signature' }}
    </a>

    {%- if section.settings.hint != blank -%}
      <p class="qi__hint">{{ section.settings.hint }}</p>
    {%- endif -%}

  </div>

  <div class="qi__rule"></div>

</div>

{% schema %}
{
  "name": "Quiz Invite",
  "tag": "section",
  "class": "ma-quiz-invite",
  "settings": [
    { "type": "header", "content": "Background" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image or GIF", "info": "Moody, on-brand. GIFs work too." },
    { "type": "video", "id": "bg_video", "label": "Background video", "info": "Overrides image if set. Plays muted and looped." },
    { "type": "range", "id": "media_opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "label": "Media opacity", "info": "Set to 100% to show the GIF/video at full strength.", "default": 100 },
    { "type": "header", "content": "Copy" },
    { "type": "text", "id": "brand_line", "label": "Brand line (above headline)", "default": "The Fragrance Finder" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Maison Amiir" },
    { "type": "text", "id": "headline", "label": "Headline (use <em>text</em> for gold italic)", "default": "Not Sure Which Scent <em>Is Yours?</em>" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Answer questions about your lifestyle, mood and the world you carry with you." },
    { "type": "text", "id": "pill1", "label": "Feature pill 1", "default": "6 Questions" },
    { "type": "text", "id": "pill2", "label": "Feature pill 2", "default": "Under 2 Minutes" },
    { "type": "text", "id": "pill3", "label": "Feature pill 3", "default": "AI Matched" },
    { "type": "text", "id": "hint", "label": "Hint text below button", "default": "No account required" },
    { "type": "header", "content": "Button" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Find My Signature" },
    { "type": "url", "id": "quiz_url", "label": "Quiz page URL", "info": "Link this to your Find Your Signature page." },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "accent_color", "label": "Accent / gold", "default": "#B89766" }
  ],
  "presets": [{ "name": "Quiz Invite" }]
}
{% endschema %}
