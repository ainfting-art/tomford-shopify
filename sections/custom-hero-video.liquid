{% schema %}
{
  "name": "Custom Hero Video",
  "settings": [
    {
      "type": "video",
      "id": "desktop_video",
      "label": "Desktop Video"
    },
    {
      "type": "video",
      "id": "mobile_video",
      "label": "Mobile Video"
    }
  ],
  "presets": [
    {
      "name": "Custom Hero Video"
    }
  ]
}
{% endschema %}

<style>
.hero-video-wrapper {
  position: relative;
  height: 100vh;
  overflow: hidden;
}

.hero-video-wrapper video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Mobile switch */
.mobile-video { display: none; }

@media (max-width: 768px) {
  .desktop-video { display: none; }
  .mobile-video { display: block; }
}

/* Mute button */
.mute-toggle {
  position: absolute;
  bottom: 20px;
  right: 20px;
  z-index: 5;
  background: none;
  border: none;
  cursor: pointer;
}

.mute-toggle svg {
  width: 26px;
  height: 26px;
  opacity: 0.9;
}
</style>

<div class="hero-video-wrapper">

  {% if section.settings.desktop_video != blank %}
    <video class="desktop-video" autoplay loop muted playsinline preload="metadata">
      <source src="{{ section.settings.desktop_video | video_url }}" type="video/mp4">
    </video>
  {% endif %}

  {% if section.settings.mobile_video != blank %}
    <video class="mobile-video" autoplay loop muted playsinline preload="metadata">
      <source src="{{ section.settings.mobile_video | video_url }}" type="video/mp4">
    </video>
  {% endif %}

  <button class="mute-toggle">
    <!-- Unmuted -->
    <svg class="icon-unmuted" viewBox="0 0 24 24" fill="white" style="display:none;">
      <path d="M3 10v4h4l5 5V5L7 10H3z"/>
      <path d="M14 3.23v2.06c2.89 1.04 5 3.77 5 7.71s-2.11 6.67-5 7.71v2.06c4.01-1.14 7-4.87 7-9.77s-2.99-8.63-7-9.77z"/>
    </svg>

    <!-- Muted -->
    <svg class="icon-muted" viewBox="0 0 24 24" fill="white">
      <path d="M16.5 12l4.5 4.5-1.5 1.5L15 13.5l-4.5 4.5V5l4.5 4.5 4.5-4.5 1.5 1.5z"/>
    </svg>
  </button>

</div>

<script>
(function(){
  function getActiveVideo() {
    return window.innerWidth <= 768
      ? document.querySelector('.mobile-video')
      : document.querySelector('.desktop-video');
  }

  function updateIcons(isMuted) {
    const btn = document.querySelector('.mute-toggle');
    if (!btn) return;

    btn.querySelector('.icon-muted').style.display = isMuted ? "block" : "none";
    btn.querySelector('.icon-unmuted').style.display = isMuted ? "none" : "block";
  }

  function toggleMute() {
    const video = getActiveVideo();
    if (!video) return;

    video.muted = !video.muted;
    if (!video.muted) video.volume = 1;

    updateIcons(video.muted);
  }

  document.addEventListener("DOMContentLoaded", function () {
    const wrapper = document.querySelector('.hero-video-wrapper');
    const button = document.querySelector('.mute-toggle');

    if (!wrapper || !button) return;

    wrapper.addEventListener('click', toggleMute);

    button.addEventListener('click', function(e){
      e.stopPropagation();
      toggleMute();
    });

    const video = getActiveVideo();
    if (video) updateIcons(video.muted);
  });

})();
</script>