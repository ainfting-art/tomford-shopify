{%- comment -%}
  MAISON AMIIR — Home · Honest Arithmetic (Editorial).
  Editorial-luxury redesign: desire-first, restraint palette (ivory/charcoal, minimal gold),
  whispered serif headline, delicate comparison, optional real bottle photo.
  If no bottle image is set, the layout becomes a clean centered (bottle-less) composition.
{%- endcomment -%}

{%- assign has_img = false -%}
{%- if section.settings.bottle_image != blank -%}{%- assign has_img = true -%}{%- endif -%}

<section
  class="ma-ar {% if has_img %}ma-ar--split{% else %}ma-ar--center{% endif %}"
  id="ma-ar-{{ section.id }}"
>
  <div class="ma-ar__in">
    {%- if has_img -%}
      <div class="ma-ar__photo">
        <div class="ma-ar__photo-stage">
          {{ section.settings.bottle_image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'ma-ar__img', alt: section.settings.bottle_image.alt | default: shop.name }}
          <span class="ma-ar__floor" aria-hidden="true"></span>
        </div>
      </div>
    {%- endif -%}

    <div class="ma-ar__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ma-ar__k">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="ma-ar__h">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="ma-ar__sub">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      <div class="ma-ar__cmp">
        <div class="ma-ar__row">
          <div class="ma-ar__top">
            <span class="ma-ar__lab">{{ section.settings.left_label | escape }}</span>
            <span class="ma-ar__val ma-ar__val--typ">{{ section.settings.left_value | escape }}</span>
          </div>
          <div class="ma-ar__track"><span class="ma-ar__fill ma-ar__fill--typ"></span></div>
        </div>
        <div class="ma-ar__row">
          <div class="ma-ar__top">
            <span class="ma-ar__lab">{{ section.settings.right_label | escape }}</span>
            <span class="ma-ar__val ma-ar__val--now">{{ section.settings.right_value | escape }}</span>
          </div>
          <div class="ma-ar__track"><span class="ma-ar__fill ma-ar__fill--now"></span></div>
        </div>
      </div>

      {%- if section.settings.refine_1 != blank or section.settings.refine_2 != blank -%}
        <div class="ma-ar__refine">
          {%- if section.settings.refine_1 != blank -%}
            <span class="ma-ar__ref">
              <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8.5"/><path d="M12 7v5l3.5 2"/></svg>
              {{ section.settings.refine_1 | escape }}
            </span>
          {%- endif -%}
          {%- if section.settings.refine_2 != blank -%}
            <span class="ma-ar__ref">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 19C5 10 12 5 19 5c0 9-7 14-14 14z"/><path d="M8 16c2-4 5-6 8-7"/></svg>
              {{ section.settings.refine_2 | escape }}
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #ma-ar-{{ section.id }}.ma-ar{
    --ivory:#f4efe7; --ivory2:#faf7f1; --ivory3:#efe8db;
    --ink:#26211c; --ink2:#6a6157; --ink3:#928878;
    --gold:#a89566; --burg:#8a1f2c; --line:#e5dfd2;
    background:var(--ivory); color:var(--ink);
    font-family:"Helvetica Neue",Helvetica,Arial,sans-serif;
    border-top:1px solid var(--line); border-bottom:1px solid var(--line);
  }
  #ma-ar-{{ section.id }} .ma-ar__in{ max-width:1180px; margin:0 auto; }
  #ma-ar-{{ section.id }}.ma-ar--split .ma-ar__in{
    display:grid; grid-template-columns:1fr; align-items:stretch;
  }

  /* photo stage */
  #ma-ar-{{ section.id }} .ma-ar__photo{
    background:linear-gradient(170deg,var(--ivory2),var(--ivory3));
    display:grid; place-items:center; padding:40px 24px; min-height:300px;
  }
  #ma-ar-{{ section.id }} .ma-ar__photo-stage{ position:relative; display:grid; place-items:center; }
  #ma-ar-{{ section.id }} .ma-ar__img{
    display:block; width:auto; max-width:280px; max-height:360px; height:auto;
    filter:drop-shadow(0 20px 26px rgba(38,33,28,.22));
  }
  #ma-ar-{{ section.id }} .ma-ar__floor{
    position:absolute; bottom:-6px; left:50%; transform:translateX(-50%);
    width:60%; height:22px; border-radius:50%;
    background:radial-gradient(ellipse at center,rgba(38,33,28,.20),transparent 72%); filter:blur(3px);
  }

  /* copy */
  #ma-ar-{{ section.id }} .ma-ar__copy{ padding:56px 30px; display:flex; flex-direction:column; justify-content:center; }
  #ma-ar-{{ section.id }}.ma-ar--center .ma-ar__copy{ align-items:center; text-align:center; max-width:640px; margin:0 auto; }
  #ma-ar-{{ section.id }} .ma-ar__k{
    font-size:10px; letter-spacing:.34em; text-transform:uppercase; color:var(--ink3); margin:0 0 20px;
  }
  #ma-ar-{{ section.id }} .ma-ar__h{
    /* base.css locks h1-h4 to uppercase/.08em/500 with !important — counter all three */
    font-family:Georgia,"Times New Roman",serif; font-weight:400 !important;
    text-transform:none !important; letter-spacing:.005em !important;
    font-size:26px; line-height:1.34; color:var(--ink); margin:0; max-width:15ch;
  }
  #ma-ar-{{ section.id }} .ma-ar__sub{
    font-family:Georgia,serif; font-style:italic; font-size:14.5px; line-height:1.7;
    color:var(--ink2); margin:18px 0 0; max-width:34ch;
  }

  /* delicate comparison */
  #ma-ar-{{ section.id }} .ma-ar__cmp{ margin:34px 0 0; max-width:380px; width:100%; }
  #ma-ar-{{ section.id }}.ma-ar--center .ma-ar__cmp{ margin-left:auto; margin-right:auto; }
  #ma-ar-{{ section.id }} .ma-ar__row{ margin-bottom:20px; }
  #ma-ar-{{ section.id }} .ma-ar__row:last-child{ margin-bottom:0; }
  #ma-ar-{{ section.id }} .ma-ar__top{ display:flex; justify-content:space-between; align-items:baseline; margin-bottom:9px; }
  #ma-ar-{{ section.id }} .ma-ar__lab{ font-size:9.5px; letter-spacing:.18em; text-transform:uppercase; color:var(--ink3); }
  #ma-ar-{{ section.id }} .ma-ar__val{ font-family:Georgia,serif; }
  #ma-ar-{{ section.id }} .ma-ar__val--typ{ font-size:15px; color:var(--ink2); text-decoration:line-through; text-decoration-thickness:1px; text-decoration-color:var(--ink3); }
  #ma-ar-{{ section.id }} .ma-ar__val--now{ font-size:23px; color:var(--burg); letter-spacing:.005em; }
  #ma-ar-{{ section.id }} .ma-ar__track{ display:block; height:4px; background:#e7e0d2; border-radius:2px; overflow:hidden; }
  #ma-ar-{{ section.id }} .ma-ar__fill{ display:block; height:100%; width:0; border-radius:2px; transition:width 1.1s cubic-bezier(.2,.7,.2,1) .2s; }
  #ma-ar-{{ section.id }} .ma-ar__fill--typ{ background:#cdc3b2; }
  #ma-ar-{{ section.id }} .ma-ar__fill--now{ background:var(--burg); }
  #ma-ar-{{ section.id }}.is-in .ma-ar__fill--typ{ width:100%; }
  #ma-ar-{{ section.id }}.is-in .ma-ar__fill--now{ width:12%; }

  /* refinements — whisper */
  #ma-ar-{{ section.id }} .ma-ar__refine{ display:flex; gap:28px; margin:32px 0 0; flex-wrap:wrap; }
  #ma-ar-{{ section.id }}.ma-ar--center .ma-ar__refine{ justify-content:center; }
  #ma-ar-{{ section.id }} .ma-ar__ref{ display:inline-flex; align-items:center; gap:9px; font-size:9.5px; letter-spacing:.13em; text-transform:uppercase; color:var(--ink2); }
  #ma-ar-{{ section.id }} .ma-ar__ref svg{ width:15px; height:15px; fill:none; stroke:var(--gold); stroke-width:1.4; stroke-linecap:round; stroke-linejoin:round; flex:0 0 auto; }

  /* quiet reveal (only when JS marks the section ready) */
  #ma-ar-{{ section.id }}.is-ready .ma-ar__copy > *{ opacity:0; transform:translateY(12px); transition:opacity .9s ease, transform .9s cubic-bezier(.2,.7,.2,1); }
  #ma-ar-{{ section.id }}.is-ready.is-in .ma-ar__copy > *{ opacity:1; transform:none; }
  #ma-ar-{{ section.id }}.is-ready.is-in .ma-ar__h{ transition-delay:.05s; }
  #ma-ar-{{ section.id }}.is-ready.is-in .ma-ar__cmp{ transition-delay:.15s; }
  #ma-ar-{{ section.id }}.is-ready.is-in .ma-ar__refine{ transition-delay:.25s; }
  #ma-ar-{{ section.id }}.is-ready .ma-ar__photo{ opacity:0; transition:opacity 1.1s ease; }
  #ma-ar-{{ section.id }}.is-ready.is-in .ma-ar__photo{ opacity:1; }

  @media (min-width:750px){
    #ma-ar-{{ section.id }}.ma-ar--split .ma-ar__in{ grid-template-columns:0.82fr 1fr; }
    #ma-ar-{{ section.id }} .ma-ar__photo{ min-height:440px; }
    #ma-ar-{{ section.id }} .ma-ar__img{ max-width:320px; max-height:420px; }
    #ma-ar-{{ section.id }} .ma-ar__copy{ padding:70px 64px; }
    #ma-ar-{{ section.id }} .ma-ar__h{ font-size:31px; }
  }
  @media (max-width:749px){
    #ma-ar-{{ section.id }} .ma-ar__copy{ padding:42px 26px; }
    #ma-ar-{{ section.id }} .ma-ar__h{ font-size:23px; }
    #ma-ar-{{ section.id }} .ma-ar__photo{ min-height:250px; padding:28px 20px; }
    #ma-ar-{{ section.id }} .ma-ar__refine{ gap:20px; }
  }
  @media (prefers-reduced-motion:reduce){
    #ma-ar-{{ section.id }} *{ transition:none !important; }
    #ma-ar-{{ section.id }}.is-ready .ma-ar__copy > *,
    #ma-ar-{{ section.id }}.is-ready .ma-ar__photo{ opacity:1 !important; transform:none !important; }
    #ma-ar-{{ section.id }} .ma-ar__fill--typ{ width:100%; }
    #ma-ar-{{ section.id }} .ma-ar__fill--now{ width:12%; }
  }
</style>

<script>
  (function(){
    var s = document.getElementById('ma-ar-{{ section.id }}');
    if(!s) return;
    s.classList.add('is-ready');
    var show = function(){ s.classList.add('is-in'); };
    {% if request.design_mode %}
      show(); return;
    {% endif %}
    if(!('IntersectionObserver' in window)){ show(); return; }
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){ if(e.isIntersecting){ show(); io.disconnect(); } });
    }, { threshold: 0.3 });
    io.observe(s);
  })();
</script>

{% schema %}
{
  "name": "MA — Honest Arithmetic",
  "tag": "section",
  "class": "ma-arith-section",
  "settings": [
    { "type": "paragraph", "content": "Editorial layout. Add a bottle photo for the split layout, or leave it empty for a clean centered composition." },
    { "type": "image_picker", "id": "bottle_image", "label": "Bottle photo (optional — real studio shot recommended)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Maison Amiir" },
    { "type": "textarea", "id": "heading", "label": "Headline", "default": "Luxury belongs inside the bottle. Not on the receipt." },
    { "type": "text", "id": "subheading", "label": "Sub-line", "default": "Only the scent should define the experience." },
    { "type": "header", "content": "Comparison" },
    { "type": "text", "id": "left_label", "label": "Left label", "default": "Typical luxury pricing" },
    { "type": "text", "id": "left_value", "label": "Left value", "default": "₹20,000" },
    { "type": "text", "id": "right_label", "label": "Right label", "default": "Maison Amiir" },
    { "type": "text", "id": "right_value", "label": "Right value", "default": "from ₹2,200" },
    { "type": "header", "content": "Refinements (kept honest)" },
    { "type": "text", "id": "refine_1", "label": "Refinement 1", "default": "Lasts all day · 30% extrait" },
    { "type": "text", "id": "refine_2", "label": "Refinement 2", "default": "Kind to skin · IFRA-compliant oils" }
  ],
  "presets": [{ "name": "MA — Honest Arithmetic" }]
}
{% endschema %}
