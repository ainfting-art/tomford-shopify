{%- comment -%}
  MAISON AMIIR — Home · Honest Arithmetic (DC presentation).
  Approved 2026-07-16: exact one-screen section (100svh minus sticky header),
  cream ground, Cormorant/Marcellus, photo melts into the cream (intensity slider),
  price bars fill on scroll (them 100% → us 12%). Setting IDs unchanged so
  existing editor content carries over.
{%- endcomment -%}

{%- assign has_img = false -%}
{%- if section.settings.bottle_image != blank -%}{%- assign has_img = true -%}{%- endif -%}
{%- assign melt = section.settings.melt | default: 100 -%}
{%- assign melt_blur = melt | times: 9.0 | divided_by: 100.0 -%}
{%- assign melt_veil = melt | divided_by: 100.0 -%}
{%- assign now_value = section.settings.right_value | escape | replace: 'from ', '<em>from</em> ' -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Marcellus&display=swap" rel="stylesheet">

<section class="ma-ar {% if has_img %}ma-ar--split{% endif %}" id="ma-ar-{{ section.id }}">
  <div class="ma-ar__copy">
    {%- if section.settings.eyebrow != blank -%}
      <p class="ma-ar__k">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="ma-ar__h">{{ section.settings.heading | escape | replace: 'Not on the receipt.', '<em>Not on the receipt.</em>' }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="ma-ar__sub">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}

    <div class="ma-ar__cmp">
      <div class="ma-ar__row">
        <div class="ma-ar__top">
          <span class="ma-ar__lab">{{ section.settings.left_label | escape }}</span>
          <span class="ma-ar__val ma-ar__val--typ">{{ section.settings.left_value | escape }}</span>
        </div>
        <div class="ma-ar__track"><span class="ma-ar__fill ma-ar__fill--typ"></span></div>
      </div>
      <div class="ma-ar__row">
        <div class="ma-ar__top">
          <span class="ma-ar__lab">{{ section.settings.right_label | escape }}</span>
          <span class="ma-ar__val ma-ar__val--now">{{ now_value }}</span>
        </div>
        <div class="ma-ar__track"><span class="ma-ar__fill ma-ar__fill--now"></span></div>
      </div>
    </div>

    {%- if section.settings.refine_1 != blank or section.settings.refine_2 != blank -%}
      <div class="ma-ar__refine">
        {%- if section.settings.refine_1 != blank -%}
          <p class="ma-ar__ref"><b>◆</b>{{ section.settings.refine_1 | escape }}</p>
        {%- endif -%}
        {%- if section.settings.refine_2 != blank -%}
          <p class="ma-ar__ref"><b>◆</b>{{ section.settings.refine_2 | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  {%- if has_img -%}
    <div class="ma-ar__photo">
      {{ section.settings.bottle_image | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'ma-ar__img', alt: section.settings.bottle_image.alt | default: shop.name }}
    </div>
  {%- endif -%}
</section>

<style>
  #ma-ar-{{ section.id }}.ma-ar{
    --cream:#F4EEE1; --ink:#171310; --gold:#C6A15B; --burg:#6E1220; --burg2:#8E1B28;
    --ma-hdr:0px;
    height:calc(100svh - var(--ma-hdr));
    max-height:calc(100svh - var(--ma-hdr));
    overflow:hidden;
    display:flex; flex-direction:column;
    background:var(--cream); color:var(--ink);
    font-family:'Cormorant Garamond',Georgia,serif;
  }

  /* ---- copy ---- */
  #ma-ar-{{ section.id }} .ma-ar__copy{
    flex:1 1 auto; min-height:0; box-sizing:border-box;
    display:flex; flex-direction:column;
    justify-content:center; justify-content:safe center; /* never clip the eyebrow/refinements */
    padding:18px 24px 14px;
  }
  #ma-ar-{{ section.id }} .ma-ar__k{
    font-family:'Marcellus',serif; font-size:11px; letter-spacing:.26em;
    text-transform:uppercase; color:var(--burg2); margin:0 0 14px;
    display:flex; align-items:center; gap:12px;
  }
  #ma-ar-{{ section.id }} .ma-ar__k::before{ content:""; width:34px; height:2px; background:var(--burg2); flex:0 0 auto; }
  #ma-ar-{{ section.id }} .ma-ar__h{
    /* base.css locks case/tracking/weight with !important — counter all three.
       Size follows BOTH width and height so short windows never clip. */
    font-family:'Cormorant Garamond',Georgia,serif;
    font-weight:600 !important; text-transform:none !important; letter-spacing:0 !important;
    font-size:clamp(26px, min(9.2vw, 5.2svh), 42px); line-height:1.12; margin:0 0 10px; color:var(--ink);
  }
  #ma-ar-{{ section.id }} .ma-ar__h em{ font-style:italic; color:var(--burg); }
  #ma-ar-{{ section.id }} .ma-ar__sub{
    font-style:italic; font-weight:500; font-size:clamp(14px, 2.4svh, 17.5px); line-height:1.45;
    color:rgba(23,19,16,.74); margin:0 0 clamp(8px,2svh,18px); max-width:40ch;
  }

  /* ---- comparison rows + bars ---- */
  #ma-ar-{{ section.id }} .ma-ar__cmp{ margin:0; width:100%; }
  #ma-ar-{{ section.id }} .ma-ar__row{ padding:13px 0 0; border-top:1px solid rgba(23,19,16,.14); }
  #ma-ar-{{ section.id }} .ma-ar__top{ display:flex; justify-content:space-between; align-items:baseline; gap:14px; }
  #ma-ar-{{ section.id }} .ma-ar__lab{
    font-family:'Marcellus',serif; font-size:10px; letter-spacing:.18em;
    text-transform:uppercase; color:rgba(23,19,16,.7);
  }
  #ma-ar-{{ section.id }} .ma-ar__val{ font-family:'Cormorant Garamond',Georgia,serif; white-space:nowrap; }
  #ma-ar-{{ section.id }} .ma-ar__val--typ{
    font-size:clamp(20px, 3.2svh, 27px); font-weight:500; color:rgba(23,19,16,.44);
    text-decoration:line-through; text-decoration-thickness:1.5px;
  }
  #ma-ar-{{ section.id }} .ma-ar__val--now{ font-size:clamp(30px, min(10.5vw, 5.6svh), 48px); font-weight:600; color:var(--burg2); }
  #ma-ar-{{ section.id }} .ma-ar__val--now em{ font-style:italic; font-weight:400; font-size:.52em; color:var(--burg); margin-right:2px; }
  #ma-ar-{{ section.id }} .ma-ar__track{ display:block; height:4px; background:rgba(23,19,16,.08); border-radius:2px; overflow:hidden; margin:10px 0 12px; }
  #ma-ar-{{ section.id }} .ma-ar__fill{ display:block; height:100%; width:0; border-radius:2px; }
  #ma-ar-{{ section.id }} .ma-ar__fill--typ{ background:rgba(23,19,16,.55); transition:width 1.4s cubic-bezier(.25,.8,.25,1) .1s; }
  #ma-ar-{{ section.id }} .ma-ar__fill--now{ background:var(--burg2); transition:width 1.1s cubic-bezier(.25,.8,.25,1) .7s; }
  #ma-ar-{{ section.id }}.is-in .ma-ar__fill--typ{ width:100%; }
  #ma-ar-{{ section.id }}.is-in .ma-ar__fill--now{ width:12%; }

  /* ---- refinements ---- */
  #ma-ar-{{ section.id }} .ma-ar__refine{ margin:16px 0 0; display:flex; flex-direction:column; gap:8px; }
  #ma-ar-{{ section.id }} .ma-ar__ref{
    font-size:16.5px; font-weight:500; color:rgba(23,19,16,.85); line-height:1.5; margin:0;
  }
  #ma-ar-{{ section.id }} .ma-ar__ref b{ color:var(--gold); font-weight:400; margin-right:8px; }

  /* ---- photo, melted into the cream ---- */
  #ma-ar-{{ section.id }} .ma-ar__photo{
    flex:0 0 29svh; min-height:0; overflow:hidden; position:relative;
  }
  #ma-ar-{{ section.id }} .ma-ar__img{
    width:100%; height:100%; object-fit:cover; object-position:center; display:block;
  }
  {%- if melt > 0 -%}
  #ma-ar-{{ section.id }} .ma-ar__photo::before{
    content:""; position:absolute; z-index:2; left:0; right:0; top:0; height:34%;
    backdrop-filter:blur({{ melt_blur }}px); -webkit-backdrop-filter:blur({{ melt_blur }}px);
    -webkit-mask-image:linear-gradient(180deg,#000 0,transparent 100%);
            mask-image:linear-gradient(180deg,#000 0,transparent 100%);
  }
  #ma-ar-{{ section.id }} .ma-ar__photo::after{
    content:""; position:absolute; z-index:3; inset:0; opacity:{{ melt_veil }};
    background:linear-gradient(180deg,var(--cream) 0%,rgba(244,238,225,.55) 14%,rgba(244,238,225,0) 46%);
  }
  {%- endif -%}

  /* ---- mobile only: photo on top, copy below (desktop <900px untouched) ---- */
  @media (max-width:899px){
    #ma-ar-{{ section.id }} .ma-ar__photo{ order:-1; }
    {%- if melt > 0 -%}
    /* melt now blends the photo's BOTTOM edge into the copy beneath it */
    #ma-ar-{{ section.id }} .ma-ar__photo::before{
      top:auto; bottom:0; height:34%;
      -webkit-mask-image:linear-gradient(0deg,#000 0,transparent 100%);
              mask-image:linear-gradient(0deg,#000 0,transparent 100%);
    }
    #ma-ar-{{ section.id }} .ma-ar__photo::after{
      background:linear-gradient(0deg,var(--cream) 0%,rgba(244,238,225,.55) 14%,rgba(244,238,225,0) 46%);
    }
    {%- endif -%}
  }

  /* ---- desktop: split, still exactly one screen ---- */
  @media (min-width:900px){
    #ma-ar-{{ section.id }}.ma-ar--split{ flex-direction:row; }
    #ma-ar-{{ section.id }} .ma-ar__copy{ width:54%; padding:0 56px 0 64px; }
    #ma-ar-{{ section.id }} .ma-ar__k{ margin-bottom:clamp(10px,2svh,18px); font-size:12px; }
    #ma-ar-{{ section.id }} .ma-ar__h{ font-size:clamp(30px, min(4vw, 6svh), 54px); max-width:16ch; margin-bottom:12px; }
    #ma-ar-{{ section.id }} .ma-ar__sub{ font-size:clamp(15px, 2.5svh, 19px); margin-bottom:clamp(12px,3svh,28px); }
    #ma-ar-{{ section.id }} .ma-ar__row{ padding:clamp(10px,2svh,17px) 0 0; }
    #ma-ar-{{ section.id }} .ma-ar__lab{ font-size:11px; }
    #ma-ar-{{ section.id }} .ma-ar__val--typ{ font-size:clamp(22px, 3.4svh, 30px); }
    #ma-ar-{{ section.id }} .ma-ar__val--now{ font-size:clamp(34px, min(4.2vw, 6.4svh), 58px); }
    #ma-ar-{{ section.id }} .ma-ar__refine{ margin-top:24px; flex-direction:row; gap:34px; flex-wrap:wrap; }
    #ma-ar-{{ section.id }} .ma-ar__ref{ font-size:17px; }
    #ma-ar-{{ section.id }} .ma-ar__photo{ flex:0 0 46%; height:100%; }
    {%- if melt > 0 -%}
    #ma-ar-{{ section.id }} .ma-ar__photo::before{
      top:0; bottom:0; left:0; right:auto; width:44%; height:auto;
      -webkit-mask-image:linear-gradient(90deg,#000 0,transparent 100%);
              mask-image:linear-gradient(90deg,#000 0,transparent 100%);
    }
    #ma-ar-{{ section.id }} .ma-ar__photo::after{
      background:linear-gradient(90deg,var(--cream) 0%,rgba(244,238,225,.6) 12%,rgba(244,238,225,0) 48%);
    }
    {%- endif -%}
  }

  @media (prefers-reduced-motion:reduce){
    #ma-ar-{{ section.id }} .ma-ar__fill{ transition:none !important; }
    #ma-ar-{{ section.id }} .ma-ar__fill--typ{ width:100% !important; }
    #ma-ar-{{ section.id }} .ma-ar__fill--now{ width:12% !important; }
  }
</style>

<script>
  (function(){
    var s = document.getElementById('ma-ar-{{ section.id }}');
    if(!s) return;

    /* exact one-screen: subtract any sticky/fixed header from the section height */
    function fitHeader(){
      var off = 0;
      ['sticky-header','.shopify-section-group-header-group','.section-header','header'].some(function(sel){
        var el = document.querySelector(sel);
        if(!el) return false;
        var cs = getComputedStyle(el);
        if(cs.position === 'sticky' || cs.position === 'fixed'){ off = el.getBoundingClientRect().height; return true; }
        return false;
      });
      s.style.setProperty('--ma-hdr', off + 'px');
    }
    fitHeader();
    window.addEventListener('resize', fitHeader);

    /* bars fill when the customer actually arrives — and replay on every visit */
    {% if request.design_mode %}
      s.classList.add('is-in'); return;
    {% endif %}
    if(!('IntersectionObserver' in window)){ s.classList.add('is-in'); return; }
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){ s.classList.add('is-in'); }
        else { s.classList.remove('is-in'); }   /* reset off-screen so it replays */
      });
    }, { threshold: 0.55 });
    io.observe(s);
  })();
</script>

{% schema %}
{
  "name": "MA — Honest Arithmetic",
  "tag": "section",
  "class": "ma-arith-section",
  "settings": [
    { "type": "paragraph", "content": "Exact one-screen section. Photo melts into the cream — tune it below." },
    { "type": "image_picker", "id": "bottle_image", "label": "Bottle photo" },
    { "type": "range", "id": "melt", "label": "Photo melt intensity", "min": 0, "max": 100, "step": 10, "unit": "%", "default": 100 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Honest Arithmetic" },
    { "type": "textarea", "id": "heading", "label": "Headline", "default": "Luxury belongs inside the bottle. Not on the receipt." },
    { "type": "text", "id": "subheading", "label": "Sub-line", "default": "Only the scent should define the experience." },
    { "type": "header", "content": "Comparison" },
    { "type": "text", "id": "left_label", "label": "Left label", "default": "Typical luxury pricing" },
    { "type": "text", "id": "left_value", "label": "Left value", "default": "₹20,000" },
    { "type": "text", "id": "right_label", "label": "Right label", "default": "Maison Amiir" },
    { "type": "text", "id": "right_value", "label": "Right value", "default": "from ₹2,200" },
    { "type": "header", "content": "Refinements (kept honest)" },
    { "type": "text", "id": "refine_1", "label": "Refinement 1", "default": "Lasts all day · 30% extrait" },
    { "type": "text", "id": "refine_2", "label": "Refinement 2", "default": "Kind to skin · IFRA-compliant oils" }
  ],
  "presets": [{ "name": "MA — Honest Arithmetic" }]
}
{% endschema %}

