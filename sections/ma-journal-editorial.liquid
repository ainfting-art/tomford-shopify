{%- comment -%}
  MA Journal Editorial — standalone luxury publication-style journal section.
  Pulls live articles from a chosen Shopify blog, auto-rotates which ones show
  based on a day interval, and renders an asymmetric editorial layout (intro +
  curated cards) on desktop and a choice of 4 distinct compositions on mobile.
  Does not modify or depend on any other section.
{%- endcomment -%}

{%- liquid
  assign jblog = section.settings.blog
  if jblog == blank
    assign jblog = blogs['blogs']
  endif
  assign total = jblog.articles_count
  if total > 50
    assign total = 50
  endif
  assign n = section.settings.num_articles
  if n > total
    assign n = total
  endif
-%}

{% style %}
  #shopify-section-{{ section.id }} .ma-j {
    background: {{ section.settings.background_color }};
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_right }}px {{ section.settings.padding_bottom }}px {{ section.settings.padding_left }}px;
  }
  #shopify-section-{{ section.id }} .ma-j__inner {
    max-width: {{ section.settings.section_width }}px;
    margin: 0 auto;
    {% if section.settings.section_min_height > 0 %}min-height: {{ section.settings.section_min_height }}px;{% endif %}
  }

  /* ---------- Intro block ---------- */
  #shopify-section-{{ section.id }} .ma-j__eyebrow {
    font-family: {{ section.settings.eyebrow_font.family }}, sans-serif;
    font-weight: {{ section.settings.eyebrow_weight }};
    font-size: {{ section.settings.eyebrow_size }}px;
    letter-spacing: {{ section.settings.eyebrow_letter_spacing }}px;
    text-transform: uppercase;
    color: {{ section.settings.eyebrow_color }};
    margin: 0 0 12px;
  }
  #shopify-section-{{ section.id }} .ma-j__heading {
    font-family: {{ section.settings.heading_font.family }}, serif;
    font-weight: {{ section.settings.heading_weight }};
    font-size: {{ section.settings.heading_size_mobile }}px;
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
    line-height: {{ section.settings.heading_line_height }};
    color: {{ section.settings.heading_color }};
    margin: 0 0 20px;
  }
  #shopify-section-{{ section.id }} .ma-j__cta {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: {{ section.settings.cta_font.family }}, sans-serif;
    font-weight: {{ section.settings.cta_weight }};
    font-size: {{ section.settings.cta_size }}px;
    letter-spacing: {{ section.settings.cta_letter_spacing }}px;
    text-transform: uppercase;
    color: {{ section.settings.cta_color }};
    text-decoration: none;
    {% if section.settings.cta_underline %}border-bottom: 1px solid currentColor; padding-bottom: 3px;{% endif %}
    transition: color 0.3s ease;
  }
  #shopify-section-{{ section.id }} .ma-j__cta:hover { color: {{ section.settings.cta_hover_color }}; }
  #shopify-section-{{ section.id }} .ma-j__cta-arrow { transition: transform 0.3s ease; }
  #shopify-section-{{ section.id }} .ma-j__cta:hover .ma-j__cta-arrow { transform: translateX(4px); }

  /* ---------- Card (shared building block) ---------- */
  #shopify-section-{{ section.id }} .ma-j__card {
    display: block;
    text-decoration: none;
    background: transparent;
    color: {{ section.settings.card_text_color }};
    border: 0;
    border-radius: 0;
    overflow: visible;
    transition: background 0.35s ease, color 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
  }
  #shopify-section-{{ section.id }} .ma-j__stories--magazine_cards .ma-j__card {
    background: {{ section.settings.card_bg_color }};
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    {% if section.settings.card_shadow_strength > 0 %}box-shadow: 0 {{ section.settings.card_shadow_strength }}px {{ section.settings.card_shadow_strength | times: 2 }}px rgba(0,0,0,{{ section.settings.card_shadow_strength | times: 1.0 | divided_by: 100 }});{% endif %}
  }
  #shopify-section-{{ section.id }} .ma-j__stories--magazine_cards .ma-j__card:hover {
    background: {{ section.settings.card_hover_bg_color }};
    border-color: {{ section.settings.card_hover_border_color }};
  }
  #shopify-section-{{ section.id }} .ma-j__stories--magazine_cards .ma-j__name,
  #shopify-section-{{ section.id }} .ma-j__stories--magazine_cards .ma-j__excerpt,
  #shopify-section-{{ section.id }} .ma-j__stories--magazine_cards .ma-j__date,
  #shopify-section-{{ section.id }} .ma-j__stories--magazine_cards .ma-j__author,
  #shopify-section-{{ section.id }} .ma-j__stories--magazine_cards .ma-j__read {
    color: #1a1a1a;
  }
  #shopify-section-{{ section.id }} .ma-j__media {
    position: relative;
    aspect-ratio: {{ section.settings.image_aspect_ratio }};
    overflow: hidden;
    background: rgba(0,0,0,0.06);
    border-radius: {{ section.settings.image_radius }}px;
  }
  #shopify-section-{{ section.id }} .ma-j__media img {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_crop }};
    display: block;
    transition: transform 0.6s ease, filter 0.6s ease;
  }
  {% if section.settings.hover_zoom %}
    #shopify-section-{{ section.id }} .ma-j__card:hover .ma-j__media img { transform: scale(1.06); }
  {% endif %}
  {% if section.settings.hover_darken %}
    #shopify-section-{{ section.id }} .ma-j__card:hover .ma-j__media img { filter: brightness(0.8); }
  {% endif %}
  #shopify-section-{{ section.id }} .ma-j__body {
    padding: {{ section.settings.text_spacing }}px {{ section.settings.text_spacing | times: 1.4 }}px;
  }
  #shopify-section-{{ section.id }} .ma-j__category {
    display: block;
    font-family: {{ section.settings.category_font.family }}, sans-serif;
    font-size: {{ section.settings.category_size }}px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: {{ section.settings.category_color }};
    margin: 0 0 8px;
  }
  #shopify-section-{{ section.id }} .ma-j__name {
    display: block;
    font-family: {{ section.settings.title_font.family }}, serif;
    font-weight: {{ section.settings.title_weight }};
    font-size: {{ section.settings.title_size }}px;
    color: {{ section.settings.title_color }};
    line-height: 1.3;
    margin: 0 0 10px;
  }
  #shopify-section-{{ section.id }} .ma-j__excerpt {
    display: block;
    font-family: {{ section.settings.excerpt_font.family }}, sans-serif;
    font-size: {{ section.settings.excerpt_size }}px;
    line-height: {{ section.settings.excerpt_line_height }};
    color: {{ section.settings.excerpt_color }};
    margin: 0 0 10px;
  }
  #shopify-section-{{ section.id }} .ma-j__meta {
    display: flex;
    gap: 10px;
    font-size: 11px;
    margin: 0 0 10px;
  }
  #shopify-section-{{ section.id }} .ma-j__date { color: {{ section.settings.date_color }}; }
  #shopify-section-{{ section.id }} .ma-j__author { color: {{ section.settings.author_color }}; }
  #shopify-section-{{ section.id }} .ma-j__read {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }
  #shopify-section-{{ section.id }} .ma-j__divider {
    height: 1px;
    background: {{ section.settings.divider_color }};
    margin: 0 auto;
  }

  {% if section.settings.fade_in_animation %}
    #shopify-section-{{ section.id }} .ma-j__reveal {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.16,1,0.3,1);
    }
    #shopify-section-{{ section.id }} .ma-j__reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  {% endif %}

  /* ---------- Mobile (default): intro stacked, then chosen story layout ---------- */
  #shopify-section-{{ section.id }} .ma-j__intro { margin-bottom: {{ section.settings.content_spacing }}px; }

  #shopify-section-{{ section.id }} .ma-j__stories--editorial_stack .ma-j__card {
    display: flex;
    flex-direction: column;
    margin-bottom: {{ section.settings.story_spacing }}px;
  }
  #shopify-section-{{ section.id }} .ma-j__stories--editorial_stack .ma-j__media { aspect-ratio: {{ section.settings.image_aspect_ratio }}; }

  #shopify-section-{{ section.id }} .ma-j__stories--magazine_cards .ma-j__card {
    margin-bottom: {{ section.settings.story_spacing }}px;
  }

  #shopify-section-{{ section.id }} .ma-j__stories--full_editorial .ma-j__card:first-child .ma-j__media { aspect-ratio: 4 / 5; }
  #shopify-section-{{ section.id }} .ma-j__stories--full_editorial .ma-j__card:first-child .ma-j__name { font-size: {{ section.settings.title_size | plus: 4 }}px; }
  #shopify-section-{{ section.id }} .ma-j__stories--full_editorial .ma-j__card { margin-bottom: {{ section.settings.story_spacing }}px; }
  #shopify-section-{{ section.id }} .ma-j__stories--full_editorial .ma-j__card:not(:first-child) { display: flex; align-items: center; }
  #shopify-section-{{ section.id }} .ma-j__stories--full_editorial .ma-j__card:not(:first-child) .ma-j__media { flex: 0 0 96px; aspect-ratio: 1/1; }
  #shopify-section-{{ section.id }} .ma-j__stories--full_editorial .ma-j__card:not(:first-child) .ma-j__body { flex: 1; padding: 12px 14px; }

  #shopify-section-{{ section.id }} .ma-j__stories--horizontal_scroll {
    display: flex;
    gap: {{ section.settings.mobile_card_gap }}px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 6px;
    -webkit-overflow-scrolling: touch;
  }
  #shopify-section-{{ section.id }} .ma-j__stories--horizontal_scroll .ma-j__card {
    flex: 0 0 {{ section.settings.mobile_card_width }}px;
    scroll-snap-align: start;
  }

  #shopify-section-{{ section.id }} .ma-j__stories { display: block; }

  /* ---------- Desktop: editorial intro + curated cards ---------- */
  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .ma-j__inner {
      display: grid;
      grid-template-columns: {{ section.settings.intro_width }}px 1fr;
      gap: {{ section.settings.content_spacing }}px;
      align-items: start;
    }
    #shopify-section-{{ section.id }} .ma-j__intro { margin-bottom: 0; }
    #shopify-section-{{ section.id }} .ma-j__heading { font-size: {{ section.settings.heading_size }}px; }

    #shopify-section-{{ section.id }} .ma-j__stories {
      display: grid !important;
      grid-template-columns: repeat({{ section.settings.desktop_columns }}, {{ section.settings.card_min_width }}px);
      justify-content: start;
      gap: {{ section.settings.card_gap }}px;
      overflow: visible;
    }
    #shopify-section-{{ section.id }} .ma-j__stories .ma-j__card {
      display: block;
      flex: none;
      margin-bottom: 0;
    }
    /* Constrain image height on desktop so card body (title/CTA) is never pushed out of view */
    #shopify-section-{{ section.id }} .ma-j__stories .ma-j__media {
      aspect-ratio: {{ section.settings.image_aspect_ratio }};
      max-height: 220px;
    }
    #shopify-section-{{ section.id }} .ma-j__stories .ma-j__body {
      padding-top: 14px;
      padding-left: 0;
      padding-right: 0;
    }
    {% if section.settings.show_featured_story %}
      #shopify-section-{{ section.id }} .ma-j__stories .ma-j__card:first-child .ma-j__media {
        aspect-ratio: {{ section.settings.featured_image_aspect }};
      }
      #shopify-section-{{ section.id }} .ma-j__stories .ma-j__card:first-child .ma-j__name {
        font-size: {{ section.settings.title_size | plus: 3 }}px;
      }
    {% endif %}

    /* Reset mobile-only layout styling so desktop is always uniform, no matter which
       mobile layout is selected (Full Editorial's small-row treatment for non-first
       cards otherwise leaks through due to higher selector specificity). */
    #shopify-section-{{ section.id }} .ma-j__stories--full_editorial .ma-j__card:first-child .ma-j__media {
      aspect-ratio: {{ section.settings.image_aspect_ratio }};
    }
    #shopify-section-{{ section.id }} .ma-j__stories--full_editorial .ma-j__card:first-child .ma-j__name {
      font-size: {{ section.settings.title_size }}px;
    }
    #shopify-section-{{ section.id }} .ma-j__stories--full_editorial .ma-j__card:not(:first-child) {
      display: block;
      align-items: normal;
    }
    #shopify-section-{{ section.id }} .ma-j__stories--full_editorial .ma-j__card:not(:first-child) .ma-j__media {
      flex: none;
      aspect-ratio: {{ section.settings.image_aspect_ratio }};
    }
    #shopify-section-{{ section.id }} .ma-j__stories--full_editorial .ma-j__card:not(:first-child) .ma-j__body {
      flex: none;
      padding: 0;
      margin-top: {{ section.settings.text_spacing }}px;
    }
  }
{% endstyle %}

{%- if total > 0 and n > 0 -%}
  {%- liquid
    assign days = section.settings.rotation_days
    assign win_len = days | times: 86400
    assign now_s = 'now' | date: '%s' | plus: 0
    assign window = now_s | divided_by: win_len
    assign hop = total | divided_by: n
    if hop < 1
      assign hop = 1
    endif
    assign start = window | times: 7 | plus: 1 | modulo: total
  -%}

  <section class="ma-j">
    <div class="ma-j__inner">
      <div class="ma-j__intro ma-j__reveal">
        {%- if section.settings.eyebrow != blank -%}
          <p class="ma-j__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="ma-j__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.cta_text != blank -%}
          <a class="ma-j__cta" href="{{ section.settings.cta_link | default: jblog.url }}">
            <span>{{ section.settings.cta_text }}</span>
            <span class="ma-j__cta-arrow">→</span>
          </a>
        {%- endif -%}
      </div>

      <div class="ma-j__stories ma-j__stories--{{ section.settings.mobile_layout }}">
        {%- for i in (1..n) -%}
          {%- assign step_offset = forloop.index0 | times: hop -%}
          {%- assign idx = start | plus: step_offset | modulo: total -%}
          {%- assign article = jblog.articles[idx] -%}
          {%- if article -%}
            <a class="ma-j__card ma-j__reveal" href="{{ article.url }}">
              {%- if section.settings.show_featured_image -%}
                <span class="ma-j__media">
                  {%- if article.image -%}
                    {{ article.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: article.title }}
                  {%- endif -%}
                </span>
              {%- endif -%}
              <span class="ma-j__body">
                {%- if section.settings.show_category and article.tags.size > 0 -%}
                  <span class="ma-j__category">{{ article.tags.first }}</span>
                {%- endif -%}
                {%- if section.settings.show_title -%}
                  <span class="ma-j__name">{{ article.title }}</span>
                {%- endif -%}
                {%- if section.settings.show_excerpt and article.excerpt != blank -%}
                  <span class="ma-j__excerpt">{{ article.excerpt | strip_html | truncate: 110 }}</span>
                {%- endif -%}
                {%- if section.settings.show_date or section.settings.show_author -%}
                  <span class="ma-j__meta">
                    {%- if section.settings.show_date -%}
                      <span class="ma-j__date">{{ article.published_at | date: '%e %b %Y' | lstrip | upcase }}</span>
                    {%- endif -%}
                    {%- if section.settings.show_author -%}
                      <span class="ma-j__author">{{ article.author }}</span>
                    {%- endif -%}
                  </span>
                {%- endif -%}
                {%- if section.settings.show_cta -%}
                  <span class="ma-j__read">Read Article →</span>
                {%- endif -%}
              </span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  {% if section.settings.fade_in_animation or section.settings.reveal_on_scroll %}
    <script>
      (function () {
        var els = document.querySelectorAll('#shopify-section-{{ section.id }} .ma-j__reveal');
        if (!els.length || !('IntersectionObserver' in window)) {
          els.forEach(function (el) { el.classList.add('is-visible'); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15 });
        els.forEach(function (el) { io.observe(el); });
      })();
    </script>
  {% endif %}

  {% if section.settings.parallax_image %}
    <script>
      (function () {
        var imgs = document.querySelectorAll('#shopify-section-{{ section.id }} .ma-j__media img');
        if (!imgs.length) return;
        var ticking = false;
        function update() {
          imgs.forEach(function (img) {
            var rect = img.parentElement.getBoundingClientRect();
            var vh = window.innerHeight || document.documentElement.clientHeight;
            var progress = (vh - rect.top) / (vh + rect.height);
            var offset = (progress - 0.5) * 20;
            img.style.transform = 'translateY(' + offset + 'px) scale(1.1)';
          });
          ticking = false;
        }
        window.addEventListener('scroll', function () {
          if (!ticking) {
            requestAnimationFrame(update);
            ticking = true;
          }
        }, { passive: true });
        update();
      })();
    </script>
  {% endif %}
{%- endif -%}

{% schema %}
{
  "name": "MA Journal Editorial",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Notes on Craft & Scent" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Thoughts on scent, craft and culture." },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Explore the Journal" },
    { "type": "url", "id": "cta_link", "label": "CTA link (defaults to the blog page)" },
    { "type": "checkbox", "id": "cta_underline", "label": "Underline CTA", "default": true },

    {
      "type": "header",
      "content": "Blog & rotation"
    },
    { "type": "blog", "id": "blog", "label": "Blog source (defaults to \"Blogs\")" },
    { "type": "range", "id": "rotation_days", "label": "Rotate stories every (days)", "min": 1, "max": 30, "step": 1, "default": 3 },
    { "type": "range", "id": "num_articles", "label": "Number of articles displayed", "min": 3, "max": 9, "step": 1, "default": 3 },

    {
      "type": "header",
      "content": "Article display toggles"
    },
    { "type": "checkbox", "id": "show_featured_image", "label": "Show featured image", "default": true },
    { "type": "checkbox", "id": "show_category", "label": "Show category (first tag)", "default": true },
    { "type": "checkbox", "id": "show_title", "label": "Show title", "default": true },
    { "type": "checkbox", "id": "show_excerpt", "label": "Show excerpt", "default": false },
    { "type": "checkbox", "id": "show_date", "label": "Show publish date", "default": false },
    { "type": "checkbox", "id": "show_author", "label": "Show author", "default": false },
    { "type": "checkbox", "id": "show_cta", "label": "Show \"Read Article\" link", "default": true },
    { "type": "checkbox", "id": "show_featured_story", "label": "Style first article as a featured story (desktop)", "default": false },

    {
      "type": "header",
      "content": "Desktop grid"
    },
    { "type": "range", "id": "intro_width", "label": "Intro column width", "min": 240, "max": 520, "step": 10, "default": 340, "unit": "px" },
    { "type": "range", "id": "desktop_columns", "label": "Number of columns", "min": 1, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "card_min_width", "label": "Card minimum width", "min": 200, "max": 400, "step": 10, "default": 260, "unit": "px" },
    { "type": "range", "id": "card_gap", "label": "Card spacing (desktop)", "min": 8, "max": 60, "step": 2, "default": 26, "unit": "px" },
    { "type": "select", "id": "featured_image_aspect", "label": "Featured story image ratio", "default": "4 / 5", "options": [
      { "value": "1 / 1", "label": "Square" },
      { "value": "4 / 5", "label": "Portrait 4:5" },
      { "value": "3 / 4", "label": "Portrait 3:4" },
      { "value": "16 / 9", "label": "Widescreen" }
    ]},

    {
      "type": "header",
      "content": "Mobile layout"
    },
    { "type": "select", "id": "mobile_layout", "label": "Mobile story layout", "default": "editorial_stack", "options": [
      { "value": "editorial_stack", "label": "01 — Editorial Stack" },
      { "value": "magazine_cards", "label": "02 — Magazine Cards" },
      { "value": "full_editorial", "label": "03 — Full Editorial" },
      { "value": "horizontal_scroll", "label": "04 — Horizontal Scroll" }
    ]},
    { "type": "range", "id": "mobile_card_width", "label": "Card width (horizontal scroll layout)", "min": 220, "max": 360, "step": 10, "default": 300, "unit": "px" },
    { "type": "range", "id": "mobile_card_gap", "label": "Card spacing (horizontal scroll layout)", "min": 8, "max": 40, "step": 2, "default": 20, "unit": "px" },
    { "type": "range", "id": "story_spacing", "label": "Story spacing (stacked mobile layouts)", "min": 0, "max": 80, "step": 4, "default": 32, "unit": "px" },

    {
      "type": "header",
      "content": "Image"
    },
    { "type": "select", "id": "image_aspect_ratio", "label": "Image aspect ratio", "default": "16 / 9", "options": [
      { "value": "1 / 1", "label": "Square" },
      { "value": "4 / 5", "label": "Portrait 4:5" },
      { "value": "3 / 4", "label": "Portrait 3:4" },
      { "value": "16 / 9", "label": "Widescreen" }
    ]},
    { "type": "select", "id": "image_crop", "label": "Image crop style", "default": "cover", "options": [
      { "value": "cover", "label": "Cover (fill, crop)" },
      { "value": "contain", "label": "Contain (fit, no crop)" }
    ]},
    { "type": "range", "id": "image_radius", "label": "Image / card corner radius", "min": 0, "max": 32, "step": 2, "default": 8, "unit": "px" },

    {
      "type": "header",
      "content": "Effects"
    },
    { "type": "checkbox", "id": "fade_in_animation", "label": "Fade in on load", "default": true },
    { "type": "checkbox", "id": "reveal_on_scroll", "label": "Reveal on scroll", "default": true },
    { "type": "checkbox", "id": "hover_zoom", "label": "Image zoom on hover", "default": true },
    { "type": "checkbox", "id": "hover_darken", "label": "Image darken on hover", "default": false },
    { "type": "checkbox", "id": "parallax_image", "label": "Subtle image parallax on scroll", "default": false },
    { "type": "range", "id": "card_shadow_strength", "label": "Card shadow strength", "min": 0, "max": 60, "step": 5, "default": 15 },

    {
      "type": "header",
