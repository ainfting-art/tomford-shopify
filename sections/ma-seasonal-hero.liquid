{%- comment -%} MAISON AMIIR — Seasonal Hero (collection pages). Full-bleed image hero
  with centered eyebrow/title/tagline, plus an optional quick-filter chip row underneath.
  Everything is editor-driven: image pickers, texts, and chips as "Label|URL" lines
  (get a URL by clicking a sidebar filter and copying the address bar). Used by the
  collection.winter template; reusable for summer later. {%- endcomment -%}
{%- liquid
  case section.settings.height_mode
    when 'large'
      assign h_desktop = 560
      assign h_mobile = 420
    when 'small'
      assign h_desktop = 380
      assign h_mobile = 300
    else
      assign h_desktop = section.settings.height_desktop
      assign h_mobile = section.settings.height_mobile
  endcase
-%}
<style>
  #shopify-section-{{ section.id }} { opacity: 1 !important; transform: none !important; }
  #shopify-section-{{ section.id }} .ma-shero { position: relative; min-height: {{ h_desktop }}px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #10151d; }
  #shopify-section-{{ section.id }} .ma-shero--tone-dark { background: #e9e4da; }
  #shopify-section-{{ section.id }} .ma-shero--tone-dark .ma-shero__img--ph { background: #e9e4da; }
  #shopify-section-{{ section.id }} .ma-shero--tone-dark .ma-shero__title { color: #1c1c1c; }
  #shopify-section-{{ section.id }} .ma-shero--tone-dark .ma-shero__tagline { color: rgba(28, 28, 28, .75); }
  #shopify-section-{{ section.id }} .ma-shero--left { justify-content: flex-start; }
  #shopify-section-{{ section.id }} .ma-shero--left .ma-shero__content { text-align: left; padding: 48px 24px 48px clamp(28px, 7vw, 100px); }
  #shopify-section-{{ section.id }} .ma-shero--left .ma-shero__tagline { margin: 0; }
  #shopify-section-{{ section.id }} .ma-shero--right { justify-content: flex-end; align-items: flex-start; }
  #shopify-section-{{ section.id }} .ma-shero--right .ma-shero__content { text-align: right; padding: clamp(44px, 9vh, 76px) clamp(28px, 7vw, 100px) 48px 24px; }
  #shopify-section-{{ section.id }} .ma-shero--right .ma-shero__tagline { margin: 0 0 0 auto; }
  #shopify-section-{{ section.id }} .ma-shero__media, #shopify-section-{{ section.id }} .ma-shero__media picture { position: absolute; inset: 0; }
  #shopify-section-{{ section.id }} .ma-shero__img { width: 100%; height: 100%; object-fit: cover; object-position: {{ section.settings.focal_desktop }}% center; display: block; position: absolute; inset: 0; }
  #shopify-section-{{ section.id }} .ma-shero__img--ph { background: #10151d; }
  #shopify-section-{{ section.id }} .ma-shero__overlay { position: absolute; inset: 0; background: rgba(6, 10, 16, {{ section.settings.overlay | divided_by: 100.0 }}); }
  #shopify-section-{{ section.id }} .ma-shero__content { position: relative; z-index: 2; text-align: center; padding: 48px 24px; max-width: 620px; }
  #shopify-section-{{ section.id }} .ma-shero__eyebrow { margin: 0 0 14px; font-size: 11px; letter-spacing: .32em; text-transform: uppercase; color: #A8894E; }
  #shopify-section-{{ section.id }} .ma-shero__title { margin: 0 0 14px; font-family: Sinoreta, Georgia, 'Times New Roman', serif; font-weight: 400; font-size: clamp(34px, 4.6vw, 52px); line-height: 1.1; color: #f4efe6; }
  #shopify-section-{{ section.id }} .ma-shero__tagline { margin: 0 auto; max-width: 540px; font-size: 15.5px; line-height: 1.75; color: rgba(244, 239, 230, .78); }
  #shopify-section-{{ section.id }} .ma-shero-chips { padding: 20px 18px 6px; }
  #shopify-section-{{ section.id }} .ma-shero-chips__row { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; }
  #shopify-section-{{ section.id }} .ma-shero-chips__chip { display: inline-block; border: 1px solid rgb(var(--color-foreground-rgb, 26 26 26) / .28); padding: 10px 22px; font-size: 10.5px; letter-spacing: .16em; text-transform: uppercase; color: var(--color-foreground, #111); text-decoration: none; transition: background .25s ease, color .25s ease, border-color .25s ease; }
  #shopify-section-{{ section.id }} .ma-shero-chips__chip:hover { background: var(--color-foreground, #111); color: var(--color-background, #fff); border-color: var(--color-foreground, #111); }
  #shopify-section-{{ section.id }} .ma-shero-chips__note { margin: 12px 0 0; text-align: center; font-size: 9.5px; letter-spacing: .18em; text-transform: uppercase; color: rgb(var(--color-foreground-rgb, 26 26 26) / .45); }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .ma-shero { min-height: {{ h_mobile }}px; align-items: flex-start; }
    #shopify-section-{{ section.id }} .ma-shero__img { object-position: {{ section.settings.focal_mobile }}% center; }
    #shopify-section-{{ section.id }} .ma-shero__content { padding: 44px 18px 28px; }
    #shopify-section-{{ section.id }} .ma-shero--left .ma-shero__content { padding: 44px 18px 28px 22px; }
    #shopify-section-{{ section.id }} .ma-shero--right .ma-shero__content { padding: 40px 20px 28px 18px; max-width: 340px; }
    #shopify-section-{{ section.id }} .ma-shero__eyebrow { font-size: 10px; letter-spacing: .26em; margin-bottom: 10px; }
    #shopify-section-{{ section.id }} .ma-shero__title { font-size: clamp(26px, 8vw, 32px); margin-bottom: 12px; }
    #shopify-section-{{ section.id }} .ma-shero__tagline { font-size: 13.5px; max-width: 300px; }
    #shopify-section-{{ section.id }} .ma-shero-chips__row { justify-content: flex-start; flex-wrap: nowrap; overflow-x: auto; scrollbar-width: none; padding: 0 18px; -webkit-overflow-scrolling: touch; }
    #shopify-section-{{ section.id }} .ma-shero-chips__row::-webkit-scrollbar { display: none; }
    #shopify-section-{{ section.id }} .ma-shero-chips__chip { flex: 0 0 auto; }
    #shopify-section-{{ section.id }} .ma-shero-chips { padding-inline: 0; }
  }
</style>
<section class="ma-shero ma-shero--{{ section.settings.content_position | default: 'left' }} ma-shero--tone-{{ section.settings.text_tone | default: 'light' }}">
  <div class="ma-shero__media">
    {%- if section.settings.image -%}
      <picture>
        {%- if section.settings.image_mobile -%}
          <source media="(max-width: 749px)" srcset="{{ section.settings.image_mobile | image_url: width: 1100 }}">
        {%- endif -%}
        {{ section.settings.image | image_url: width: 2400 | image_tag: class: 'ma-shero__img', loading: 'eager', fetchpriority: 'high', alt: section.settings.heading | default: collection.title }}
      </picture>
    {%- else -%}
      <span class="ma-shero__img ma-shero__img--ph"></span>
    {%- endif -%}
    <span class="ma-shero__overlay"></span>
  </div>
  {%- if section.settings.show_heading or section.settings.eyebrow != blank or section.settings.tagline != blank -%}
    <div class="ma-shero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ma-shero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.show_heading -%}
        <h1 class="ma-shero__title">{{ section.settings.heading | default: collection.title | escape }}</h1>
      {%- endif -%}
      {%- if section.settings.tagline != blank -%}
        <p class="ma-shero__tagline">{{ section.settings.tagline | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>
{%- assign chips_raw = section.settings.chips | strip -%}
{%- if chips_raw != blank -%}
  <nav class="ma-shero-chips" aria-label="Quick filters">
    <div class="ma-shero-chips__row">
      {%- assign chip_lines = chips_raw | newline_to_br | split: '<br />' -%}
      {%- for line in chip_lines -%}
        {%- assign clean = line | replace: '<br>', '' | strip -%}
        {%- assign parts = clean | split: '|' -%}
        {%- if parts.size >= 2 -%}
          <a class="ma-shero-chips__chip" href="{{ parts[1] | strip }}">{{ parts[0] | strip | escape }}</a>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- if section.settings.chips_note != blank -%}
      <p class="ma-shero-chips__note">{{ section.settings.chips_note | escape }}</p>
    {%- endif -%}
  </nav>
{%- endif -%}

{% schema %}
{
  "name": "MA — Seasonal Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image (desktop / wide)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Hero image (mobile, optional)"
    },
    {
      "type": "range",
      "id": "focal_desktop",
      "label": "Image focus point desktop (% from left)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "range",
      "id": "focal_mobile",
      "label": "Image focus point mobile (% from left)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 75
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Winter Edit"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (blank = collection title)"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline (one or two lines)",
      "default": "Rich resins, dense woods and smoke — compositions that unfold slowly through colder air. This is where intensity becomes elegance."
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Text position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right (top corner)" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_tone",
      "label": "Text tone",
      "info": "Light text for dark images (winter), dark text for bright images (summer)",
      "options": [
        { "value": "light", "label": "Light text" },
        { "value": "dark", "label": "Dark text" }
      ],
      "default": "light"
    },
    {
      "type": "range",
      "id": "overlay",
      "label": "Darkening overlay (%)",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30
    },
    {
      "type": "select",
      "id": "height_mode",
      "label": "Banner height",
      "options": [
        { "value": "large", "label": "Large" },
        { "value": "small", "label": "Small" },
        { "value": "custom", "label": "Custom (use sliders below)" }
      ],
      "default": "large"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Custom height desktop (px)",
      "info": "Used only when Banner height = Custom",
      "min": 320,
      "max": 680,
      "step": 20,
      "default": 480
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Custom height mobile (px)",
      "info": "Used only when Banner height = Custom",
      "min": 240,
      "max": 520,
      "step": 20,
      "default": 360
    },
    {
      "type": "textarea",
      "id": "chips",
      "label": "Quick-filter chips — one per line: Label|URL",
      "info": "To get a URL: tick a sidebar filter on the collection page and copy the address bar. Leave empty to hide the chip row."
    },
    {
      "type": "text",
      "id": "chips_note",
      "label": "Note under chips",
      "default": "Tap a note — the shelf rearranges"
    }
  ],
  "presets": [
    {
      "name": "MA — Seasonal Hero"
    }
  ]
}
{% endschema %}
