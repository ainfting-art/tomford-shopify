<style>
  .ma-footer {
    background: #1a1a1a;
    color: #c8b8a2;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    padding: 0;
    margin: 0;
    width: 100%;
  }

  .ma-footer__top {
    max-width: 1400px;
    margin: 0 auto;
    padding: 70px 50px 50px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1.4fr;
    gap: 40px;
    border-bottom: 1px solid #2e2e2e;
  }

  .ma-footer__col-title {
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    font-weight: 500;
    margin: 0 0 22px 0;
    padding: 0;
    display: block;
  }

  .ma-footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ma-footer__col ul li {
    margin-bottom: 10px;
  }

  .ma-footer__col ul li a {
    color: #a09080;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.2s;
    display: block;
    line-height: 1.4;
  }

  .ma-footer__col ul li a:hover {
    color: #c8b8a2;
  }

  .ma-footer__subscribe-text {
    font-size: 11px;
    letter-spacing: 0.1em;
    color: #a09080;
    line-height: 1.7;
    margin: 0 0 24px 0;
    text-transform: uppercase;
  }

  .ma-footer__form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ma-footer__input {
    background: transparent;
    border: none;
    border-bottom: 1px solid #444;
    color: #c8b8a2;
    font-size: 11px;
    letter-spacing: 0.1em;
    padding: 8px 0;
    outline: none;
    font-family: inherit;
    text-transform: uppercase;
    width: 100%;
    box-sizing: border-box;
  }

  .ma-footer__input::placeholder {
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 10px;
  }

  .ma-footer__input:focus {
    border-bottom-color: #c8b8a2;
  }

  .ma-footer__submit {
    background: transparent;
    border: 1px solid #555;
    color: #c8b8a2;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 11px 20px;
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.2s, color 0.2s;
    margin-top: 6px;
    align-self: flex-start;
  }

  .ma-footer__submit:hover {
    border-color: #c8b8a2;
    color: #fff;
  }

  .ma-footer__bottom {
    max-width: 1400px;
    margin: 0 auto;
    padding: 24px 50px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .ma-footer__copyright {
    font-size: 10px;
    letter-spacing: 0.12em;
    color: #555;
    text-transform: uppercase;
  }

  .ma-footer__social {
    display: flex;
    gap: 18px;
    align-items: center;
  }

  .ma-footer__social a {
    color: #555;
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }

  .ma-footer__social a:hover {
    color: #c8b8a2;
  }

  .ma-footer__mobile-section {
    display: none;
    border-bottom: 1px solid #2e2e2e;
    flex-direction: column;
  }

  .ma-footer__acc-btn {
    background: none;
    border: none;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 0;
    cursor: pointer;
    color: #fff;
    font-family: inherit;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .ma-footer__acc-icon {
    font-size: 20px;
    color: #888;
    line-height: 1;
    font-style: normal;
  }

  .ma-footer__acc-body {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s ease;
  }

  .ma-footer__acc-body ul {
    list-style: none;
    margin: 0;
    padding: 0 0 18px 0;
  }

  .ma-footer__acc-body ul li {
    margin-bottom: 13px;
  }

  .ma-footer__acc-body ul li a {
    color: #888;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    display: block;
    transition: color 0.2s;
  }

  .ma-footer__acc-body ul li a:hover {
    color: #c8b8a2;
  }

  .ma-footer__mobile-subscribe {
    display: none;
    padding: 30px 0 10px;
    border-bottom: 1px solid #2e2e2e;
    flex-direction: column;
  }

  .ma-footer__mobile-subscribe p {
    font-size: 10px;
    letter-spacing: 0.1em;
    color: #888;
    text-transform: uppercase;
    margin: 0 0 16px;
    line-height: 1.6;
  }

  .ma-footer__mobile-bottom {
    display: none;
    padding: 24px 0 36px;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  @media (max-width: 767px) {
    .ma-footer__top,
    .ma-footer__bottom {
      display: none;
    }
    .ma-footer__mobile-section,
    .ma-footer__mobile-subscribe,
    .ma-footer__mobile-bottom {
      display: flex;
    }
    .ma-footer {
      padding: 0 24px;
    }
    .ma-footer__mobile-bottom .ma-footer__social {
      justify-content: center;
    }
    .ma-footer__mobile-bottom .ma-footer__copyright {
      text-align: center;
    }
  }
</style>

