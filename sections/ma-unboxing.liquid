{% comment %} MAISON AMIIR — The Unboxing: 4-frame crossfading gift sequence + editorial copy {% endcomment %}

<div class="ma-unbox">
  <div class="ma-unbox__grid">

    <div class="ma-unbox__stage ma-home-reveal" id="ma-unbox-stage-{{ section.id }}">
      {%- for i in (1..4) -%}
        {%- assign img_key = 'image_' | append: i -%}
        {%- assign img = section.settings[img_key] -%}
        <div class="ma-unbox__frame{% if forloop.first %} is-on{% endif %}">
          {%- if img != blank -%}
            {{ img | image_url: width: 1200 | image_tag: loading: 'lazy', alt: 'Maison Amiir unboxing', class: 'ma-unbox__img' }}
          {%- else -%}
            <div class="ma-unbox__img ma-unbox__img--fallback ma-unbox__img--f{{ i }}"></div>
          {%- endif -%}
        </div>
      {%- endfor -%}
      <p class="ma-unbox__cap">
        <span class="ma-unbox__cap-num">01</span>
        <span class="ma-unbox__cap-text">{{ section.settings.cap_1 }}</span>
      </p>
      <button class="ma-unbox__arrow ma-unbox__arrow--prev" type="button" aria-label="Previous image">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 5L8 12L15 19" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="ma-unbox__arrow ma-unbox__arrow--next" type="button" aria-label="Next image">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <div class="ma-unbox__dots" aria-hidden="true">
        <span class="ma-unbox__dot is-on"></span>
        <span class="ma-unbox__dot"></span>
        <span class="ma-unbox__dot"></span>
        <span class="ma-unbox__dot"></span>
      </div>
    </div>

    <div class="ma-unbox__text">
      <p class="ma-unbox__eyebrow ma-home-reveal">{{ section.settings.eyebrow }}</p>
      <h2 class="ma-unbox__h2 ma-home-reveal">{{ section.settings.heading }}</h2>
      <p class="ma-unbox__body ma-home-reveal">{{ section.settings.body }}</p>
      {%- if section.settings.gift_line != blank -%}
        <p class="ma-unbox__gift ma-home-reveal">{{ section.settings.gift_line }}</p>
      {%- endif -%}
      <div class="ma-unbox__segs ma-home-reveal" aria-hidden="true">
        <span class="ma-unbox__seg is-on"></span>
        <span class="ma-unbox__seg"></span>
        <span class="ma-unbox__seg"></span>
        <span class="ma-unbox__seg"></span>
      </div>
      {%- if section.settings.button_label != blank -%}
        <a class="ma-unbox__btn ma-home-reveal" href="{{ section.settings.button_link | default: '/collections/all-perfumes' }}">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>

  </div>

  <script type="application/json" class="ma-unbox-caps">[{{ section.settings.cap_1 | json }},{{ section.settings.cap_2 | json }},{{ section.settings.cap_3 | json }},{{ section.settings.cap_4 | json }}]</script>
</div>

<style>
  #shopify-section-{{ section.id }} { opacity: 1 !important; transform: none !important; }

  .ma-unbox {
    background: #F7F3EA;
    color: #171410;
    padding: clamp(3.2rem, 7vw, 5.5rem) clamp(1.2rem, 4vw, 3rem);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }
  .ma-unbox *, .ma-unbox *::before, .ma-unbox *::after { box-sizing: border-box; }

  .ma-unbox__grid { display: grid; grid-template-columns: 52% 48%; gap: clamp(1.8rem, 4.5vw, 3.6rem); align-items: center; max-width: 1140px; margin: 0 auto; }

  .ma-unbox__stage { position: relative; overflow: hidden; aspect-ratio: 1 / 1; background: #171410; }
  .ma-unbox__frame { position: absolute; inset: 0; opacity: 0; transition: opacity 1.1s ease; }
  .ma-unbox__frame.is-on { opacity: 1; }
  .ma-unbox__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
  .ma-unbox__img--f1 { background: #7A1A33; }
  .ma-unbox__img--f2 { background: #B98F4D; }
  .ma-unbox__img--f3 { background: #1E1A16; }
  .ma-unbox__img--f4 { background: #EFE9DC; }

  .ma-unbox__cap { position: absolute; left: 1.4rem; bottom: 1.1rem; z-index: 2; margin: 0; display: flex; align-items: baseline; gap: .7rem; color: #fff; text-shadow: 0 1px 14px rgba(0,0,0,.55); }
  .ma-unbox__cap-num { font-size: .72rem; letter-spacing: .3em; color: #E7C98B; }
  .ma-unbox__cap-text { font-size: .78rem; letter-spacing: .26em; text-transform: uppercase; }

  .ma-unbox__arrow {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 3;
    width: 44px; height: 44px; display: flex; align-items: center; justify-content: center;
    background: none; border: 0; padding: 0; cursor: pointer;
    color: rgba(255,255,255,.75); transition: color .3s, opacity .3s; opacity: 0;
  }
  .ma-unbox__arrow svg { width: 26px; height: 26px; filter: drop-shadow(0 1px 8px rgba(0,0,0,.5)); }
  .ma-unbox__arrow--prev { left: .5rem; }
  .ma-unbox__arrow--next { right: .5rem; }
  .ma-unbox__stage:hover .ma-unbox__arrow { opacity: 1; }
  .ma-unbox__arrow:hover { color: #fff; }
  .ma-unbox__arrow:focus-visible { opacity: 1; outline: 1px solid rgba(255,255,255,.7); outline-offset: 2px; }

  .ma-unbox__dots { position: absolute; left: 50%; transform: translateX(-50%); bottom: 1rem; z-index: 2; display: none; gap: .5rem; }
  .ma-unbox__dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,.45); transition: background .4s, transform .4s; }
  .ma-unbox__dot.is-on { background: #fff; transform: scale(1.25); }

  .ma-unbox__text { text-align: left; }
  .ma-unbox__eyebrow { font-size: .72rem; letter-spacing: .45em; text-transform: uppercase; color: #A8894E; margin: 0 0 1.1rem; }
  .ma-unbox__h2 { font-family: 'Sinoreta', Georgia, serif; font-size: clamp(1.8rem, 3.8vw, 2.6rem); font-weight: 300; line-height: 1.25; letter-spacing: .02em; margin: 0 0 1.1rem; color: #171410; }
  .ma-unbox__body { font-size: clamp(.98rem, 1.4vw, 1.08rem); font-weight: 300; line-height: 1.95; color: rgba(23,20,16,.72); max-width: 40ch; margin: 0 0 1rem; }
  .ma-unbox__gift { font-family: 'Sinoreta', Georgia, serif; font-style: italic; font-size: clamp(1.08rem, 1.7vw, 1.25rem); color: #171410; margin: 0 0 1.6rem; }

  .ma-unbox__segs { display: flex; gap: .45rem; margin: 0 0 1.7rem; }
  .ma-unbox__seg { width: 28px; height: 2px; background: rgba(23,20,16,.15); transition: background .5s; }
  .ma-unbox__seg.is-on { background: #A8894E; }

  .ma-unbox__btn { display: inline-block; font-size: .74rem; letter-spacing: .3em; text-indent: .3em; text-transform: uppercase; color: #171410; border: 1px solid #171410; padding: .95em 1.9em; text-decoration: none; transition: background .35s, color .35s; }
  .ma-unbox__btn:hover { background: #171410; color: #F7F3EA; }

  @media (max-width: 749px) {
    .ma-unbox__grid { grid-template-columns: 1fr; gap: 1.6rem; }
    .ma-unbox__stage { aspect-ratio: 1 / 1; touch-action: pan-y; }
    .ma-unbox__text { text-align: center; }
    .ma-unbox__body { margin-left: auto; margin-right: auto; }
    .ma-unbox__segs { justify-content: center; }
    .ma-unbox__arrow { display: none; }
    .ma-unbox__dots { display: flex; }
  }
</style>

<script src="{{ 'ma-unboxing.js' | asset_url }}" defer></script>
<script src="{{ 'ma-home-sections.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "MA Unboxing",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image_1", "label": "Frame 1 — the coffret" },
    { "type": "image_picker", "id": "image_2", "label": "Frame 2 — the reveal" },
    { "type": "image_picker", "id": "image_3", "label": "Frame 3 — the bottle" },
    { "type": "image_picker", "id": "image_4", "label": "Frame 4 — the note" },
    { "type": "text", "id": "cap_1", "label": "Caption 1", "default": "The Coffret" },
    { "type": "text", "id": "cap_2", "label": "Caption 2", "default": "The Reveal" },
    { "type": "text", "id": "cap_3", "label": "Caption 3", "default": "The Bottle" },
    { "type": "text", "id": "cap_4", "label": "Caption 4", "default": "The Note" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Maison Amiir Coffret" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Every order arrives as a gift." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Our coffrets are crafted with premium materials, subtle texture, and clean lines — the purity of French design and the sophistication of Dubai. Every bottle is placed with intention." },
    { "type": "text", "id": "gift_line", "label": "Gift line", "default": "Gift-ready, always. No wrapping required." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Explore the Collection" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "MA Unboxing" }]
}
{% endschema %}
