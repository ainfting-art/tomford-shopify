<div id="ma-reviews" class="ma-reviews-wrapper">
  {% render 'ma-reviews', product: product %}
</div>

{% stylesheet %}
  .ma-reviews-wrapper {
    max-width: 1440px;
    margin: 80px auto;
    padding: 64px 48px 80px;
    border-top: 1px solid #e8e8e8;
  }

  @media screen and (max-width: 749px) {
    .ma-reviews-wrapper {
      padding: 40px 16px 80px;
      margin-top: 40px;
    }
  }
{% endstylesheet %}

<script>
(function () {
  var css = [
    /* ---- Widget shell ---- */
    '.jdgm-widget, .jdgm-rev-widg { font-family: inherit; color: #1a1a1a; }',

    /* ---- Heading "Customer Reviews" ---- */
    '.jdgm-rev-widg__title { font-size: 22px !important; letter-spacing: 0.14em !important; text-transform: uppercase !important; font-weight: 400 !important; color: #1a1a1a !important; text-align: left !important; }',

    /* ---- Summary (avg rating) ---- */
    '.jdgm-rev-widg__summary { border-top: 1px solid #e8e8e8 !important; border-bottom: 1px solid #e8e8e8 !important; padding: 24px 0 !important; margin: 24px 0 32px !important; }',
    '.jdgm-rev-widg__summary-average { font-size: 36px !important; font-weight: 300 !important; color: #1a1a1a !important; }',
    '.jdgm-rev-widg__summary-text { font-size: 11px !important; letter-spacing: 0.08em !important; text-transform: uppercase !important; color: #888 !important; }',

    /* ---- Stars: filled = black, empty = light grey ---- */
    '.jdgm-star, .jdgm-star.jdgm--on { color: #1a1a1a !important; font-size: 15px !important; }',
    '.jdgm-star.jdgm--off { color: #d0d0d0 !important; }',

    /* ---- "Write a review" button ---- */
    '.jdgm-write-rev-link { display: inline-block !important; background: #1a1a1a !important; color: #fff !important; border: 1px solid #1a1a1a !important; border-radius: 0 !important; padding: 13px 36px !important; font-size: 11px !important; letter-spacing: 0.16em !important; text-transform: uppercase !important; font-weight: 400 !important; text-decoration: none !important; transition: background 0.25s, color 0.25s !important; }',
    '.jdgm-write-rev-link:hover { background: #fff !important; color: #1a1a1a !important; }',

    /* ---- Sort / search controls ---- */
    '.jdgm-rev-widg__sort-wrapper select, .jdgm-search-rev__input { border: 1px solid #d5d5d5 !important; border-radius: 0 !important; font-size: 11px !important; letter-spacing: 0.06em !important; text-transform: uppercase !important; color: #1a1a1a !important; padding: 10px 14px !important; background: #fff !important; }',

    /* ---- Review cards ---- */
    '.jdgm-rev { border-top: none !important; border-bottom: 1px solid #ececec !important; padding: 28px 0 !important; }',
    '.jdgm-rev__author { font-size: 15px !important; letter-spacing: 0.03em !important; color: #1a1a1a !important; font-weight: 400 !important; }',
    '.jdgm-rev__location, .jdgm-rev__timestamp { font-size: 10px !important; letter-spacing: 0.08em !important; text-transform: uppercase !important; color: #999 !important; }',
    '.jdgm-rev__title { font-size: 14px !important; letter-spacing: 0.02em !important; color: #1a1a1a !important; font-weight: 400 !important; margin-top: 8px !important; }',
    '.jdgm-rev__body p, .jdgm-rev__body { font-size: 14px !important; line-height: 1.75 !important; color: #555 !important; }',

    /* ---- Verified / recommend badges ---- */
    '.jdgm-rev__buyer-badge { color: #888 !important; font-size: 11px !important; letter-spacing: 0.04em !important; }',

    /* ---- Helpful / not helpful ---- */
    '.jdgm-rev__helpful-btns span { color: #aaa !important; font-size: 11px !important; letter-spacing: 0.04em !important; }',

    /* ---- Load more / pagination ---- */
    '.jdgm-paginate__page, .jdgm-paginate__load-more { border: 1px solid #1a1a1a !important; border-radius: 0 !important; background: #fff !important; color: #1a1a1a !important; font-size: 10px !important; letter-spacing: 0.16em !important; text-transform: uppercase !important; padding: 12px 28px !important; }',
    '.jdgm-paginate__page.jdgm-curt, .jdgm-paginate__load-more:hover { background: #1a1a1a !important; color: #fff !important; }',

    /* ---- Write-a-review modal ---- */
    '.jdgm-modal__content { font-family: inherit !important; }',
    '.jdgm-form__title { font-size: 18px !important; letter-spacing: 0.12em !important; text-transform: uppercase !important; font-weight: 400 !important; color: #1a1a1a !important; }',
    '.jdgm-form input[type="text"], .jdgm-form input[type="email"], .jdgm-form textarea { border: 1px solid #d5d5d5 !important; border-radius: 0 !important; font-size: 13px !important; }',
    '.jdgm-form input:focus, .jdgm-form textarea:focus { border-color: #1a1a1a !important; outline: none !important; box-shadow: none !important; }',
    '.jdgm-form__submit-button { background: #1a1a1a !important; color: #fff !important; border: 1px solid #1a1a1a !important; border-radius: 0 !important; font-size: 11px !important; letter-spacing: 0.16em !important; text-transform: uppercase !important; font-weight: 400 !important; padding: 14px 36px !important; }',
    '.jdgm-form__submit-button:hover { background: #fff !important; color: #1a1a1a !important; }',

    /* ---- Modal close button ---- */
    '.jdgm-modal__close-btn { color: #1a1a1a !important; font-size: 22px !important; }'
  ].join('\n');

  function inject() {
    var existing = document.getElementById('ma-jdgm-override');
    if (existing) existing.remove();
    var style = document.createElement('style');
    style.id = 'ma-jdgm-override';
    style.textContent = css;
    document.head.appendChild(style);
  }

  /* Inject immediately, on window load, on any Judge.me event, and after 1.5s safety net */
  inject();
  window.addEventListener('load', inject);
  document.addEventListener('jdgm:all:done', inject);
  document.addEventListener('jdgm:loadMore:finished', inject);
  setTimeout(inject, 1500);
  setTimeout(inject, 3000);
})();
</script>

{% schema %}
{
  "name": "Product Reviews",
  "tag": "section",
  "limit": 1,
  "templates": ["product"],
  "presets": [
    {
      "name": "Product Reviews"
    }
  ]
}
{% endschema %}
