lay__panel')) {\n            overlay.hidden = true;\n          }\n        });\n      }\n    }\n\n    function init() { initAnnouncement(); initHeaderUI(); initCartSync(); initSearchPopular(); }\n    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);\n    else init();\n  })();\n</script>\n\n<script>\n  (function () {\n    var wrap = document.querySelector('.ma-header-wrap');\n    if (!wrap) return;\n    var ann = wrap.querySelector('.ma-announcement');\n    function annH() { return ann ? ann.offsetHeight : 0; }\n    function applyPadding() {\n      document.body.style.paddingTop = wrap.offsetHeight + 'px';\n      document.documentElement.style.setProperty('--ma-header-h', wrap.offsetHeight + 'px');\n    }\n    applyPadding();\n    window.addEventListener('resize', applyPadding);\n    if (document.fonts && document.fonts.ready) document.fonts.ready.then(applyPadding);\n    var lastY = window.scrollY || 0, rafId = null;\n    function update() {\n      rafId = null;\n      var y = window.scrollY || 0;\n      if (y < 0) y = 0;\n      if (document.body.classList.contains('ma-no-scroll')) return;\n      wrap.style.transform = 'translateY(-' + Math.min(y, annH()) + 'px)';\n      if (y <= wrap.offsetHeight) {\n        wrap.classList.remove('ma-header-wrap--hidden');\n      } else if (y > lastY + 10) {\n        wrap.classList.add('ma-header-wrap--hidden');\n      } else if (y < lastY - 10) {\n        wrap.classList.remove('ma-header-wrap--hidden');\n      }\n      lastY = y;\n    }\n    update();\n    window.addEventListener('scroll', function () {\n      if (!rafId) rafId = requestAnimationFrame(update);\n    }, { passive: true });\n  })();\n</script>",
