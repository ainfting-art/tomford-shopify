dd('ma-no-scroll'); }\n    function closeEl(el) { if (!el) return; el.classList.remove('is-open'); body.classList.remove('ma-no-scroll'); setTimeout(function () { el.hidden = true; }, 320); }\n\n    function initHeaderUI() {\n      var header = document.querySelector('.custom-header');\n      if (!header || header.dataset.maInit) return; header.dataset.maInit = '1';\n      var drawer = document.getElementById('ma-drawer');\n      var search = document.getElementById('ma-search');\n      var hamburger = document.getElementById('mobile-menu-trigger');\n      var searchBtn = document.getElementById('mobile-search-trigger');\n      var cartBtn = document.getElementById('custom-cart-trigger');\n      if (hamburger && drawer) hamburger.addEventListener('click', function (e) { e.preventDefault(); openEl(drawer); });\n      if (searchBtn && search) searchBtn.addEventListener('click', function (e) {\n        e.preventDefault(); openEl(search);\n        var inp = search.querySelector('input[name=\"q\"]'); if (inp) setTimeout(function () { inp.focus(); }, 260);\n      });\n      [drawer, search].forEach(function (el) {\n        if (!el) return;\n        el.querySelectorAll('[data-ma-close]').forEach(function (btn) { btn.addEventListener('click', function (e) { e.preventDefault(); closeEl(el); }); });\n      });\n      document.addEventListener('keydown', function (e) {\n        if (e.key === 'Escape') { if (drawer && !drawer.hidden) closeEl(drawer); if (search && !search.hidden) closeEl(search); }\n      });\n      if (cartBtn) cartBtn.addEventListener('click', function (e) {\n        e.preventDefault();\n        var drawerComp = document.querySelector('cart-drawer-component');\n        if (drawerComp && typeof drawerComp.open === 'function') { drawerComp.open(); }\n        else if (drawerComp) { var btn = drawerComp.querySelector('button'); if (btn) btn.click(); }\n      });\n      var acctLabel = document.querySelector('.ma-account-label');\n      var acctComp = document.get