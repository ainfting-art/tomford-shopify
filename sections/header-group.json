      "settings": {
        "custom_liquid": "{%- comment %}\n  MAISON AMIIR — Header + Search\n{% endcomment -%}\n\n<div class=\"ma-header-wrap\">\n\n  <div class=\"ma-announcement\" role=\"region\" aria-label=\"Announcements\">\n    <div class=\"ma-announcement__viewport\">\n      <p class=\"ma-announcement__slide is-active\"><span class=\"ma-announcement__long\"><span class=\"ma-annc-d is-on\">15% OFF YOUR FIRST ORDER &mdash; CODE <strong>WELCOME15</strong> &nbsp;&middot;&nbsp; COMPLIMENTARY DELIVERY ACROSS INDIA</span><span class=\"ma-annc-d\">COMPLIMENTARY SAMPLE TESTER WITH EVERY ORDER &mdash; TRY BEFORE YOU COMMIT</span></span><span class=\"ma-announcement__short\"><span class=\"ma-annc-m is-on\">15% OFF YOUR FIRST ORDER &mdash; CODE <strong>WELCOME15</strong></span><span class=\"ma-annc-m\">COMPLIMENTARY DELIVERY ACROSS INDIA</span><span class=\"ma-annc-m\">FREE TESTER IN EVERY ORDER &mdash; TRY BEFORE YOU COMMIT</span></span></p>\n    </div>\n  </div>\n\n  <script>(function(){function R(s,it){var w=document.querySelector(s);if(!w||w.dataset.maRot)return;w.dataset.maRot='1';var m=w.querySelectorAll(it);if(m.length<2)return;var i=0;setInterval(function(){w.style.opacity='0';setTimeout(function(){m[i].classList.remove('is-on');i=(i+1)%m.length;m[i].classList.add('is-on');w.style.opacity='1';},380);},5000);}R('.ma-announcement__short','.ma-annc-m');R('.ma-announcement__long','.ma-annc-d');})();</script>\n\n  <div class=\"custom-header\">\n    <div class=\"custom-header__container\">\n      <div class=\"custom-header__right\">\n        <div class=\"custom-header__row-top\">\n\n          <div class=\"custom-header__col-left\">\n            <button class=\"custom-header__hamburger ma-mobile-only\" id=\"mobile-menu-trigger\" aria-label=\"Open menu\" type=\"button\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M3 7H21M3 12H21M3 17H21\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\"/></svg>\n            </button>\n            <button class=\"custom-header__mobile-search ma-mobile-only\" id=\"mobile-search-trigger\" aria-label=\"Search\" type=\"button\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><circle cx=\"11\" cy=\"11\" r=\"7\" stroke=\"currentColor\" stroke-width=\"1.6\"/><path d=\"M20 20L16.5 16.5\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\"/></svg>\n            </button>\n            <form class=\"custom-header__desktop-search ma-desktop-only\" action=\"{{ routes.search_url }}\" method=\"get\" role=\"search\">\n              <input type=\"search\" name=\"q\" placeholder=\"Search for a product…\" aria-label=\"Search\" autocomplete=\"off\">\n              <button type=\"submit\" aria-label=\"Submit search\">\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><circle cx=\"11\" cy=\"11\" r=\"7\" stroke=\"currentColor\" stroke-width=\"1.6\"/><path d=\"M20 20L16.5 16.5\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\"/></svg>\n              </button>\n            </form>\n          </div>\n\n          <div class=\"custom-header__col-center\">\n            <a href=\"{{ routes.root_url }}\" class=\"custom-header__brand-link\">\n              <span class=\"custom-header__brand-text\">{{ shop.name }}</span>\n            </a>\n          </div>\n\n          <div class=\"custom-header__col-right\">\n            <div class=\"custom-header__icons\">\n              <div class=\"custom-header__icon-link custom-header__account-wrapper\" id=\"account-wrapper\">\n                <shopify-store store-domain=\"https://maison-amire.myshopify.com\" country=\"IN\" language=\"en\"></shopify-store>\n                <shopify-account menu=\"customer-account-main-menu\" id=\"shopify-account-comp\">\n                  <span slot=\"signed-out-avatar\" class=\"ma-account-svg\" aria-hidden=\"true\">\n                    <svg viewBox=\"0 0 24 24\" fill=\"none\"><circle cx=\"12\" cy=\"8\" r=\"4\" stroke=\"currentColor\" stroke-width=\"1.5\"/><path d=\"M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>\n                  </span>\n                </shopify-account>\n                <button class=\"ma-account-label ma-desktop-only\" type=\"button\" aria-label=\"Account\">ACCOUNT</button>\n              </div>\n              <button class=\"custom-header__icon-link custom-cart-trigger\" id=\"custom-cart-trigger\" aria-label=\"Cart\" type=\"button\">\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M5 8H19L18 20H6L5 8Z\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linejoin=\"round\"/><path d=\"M9 8V6C9 4.34 10.34 3 12 3C13.66 3 15 4.34 15 6V8\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>\n                <span class=\"ma-icon-label ma-desktop-only\">CART</span>\n                <span class=\"custom-header__cart-count\" id=\"custom-cart-count\">{{ cart.item_count }}</span>\n              </button>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"custom-header__row-bottom\">\n          <nav class=\"custom-header__nav\" aria-label=\"Main navigation\">\n            <ul class=\"custom-header__menu\">\n              {% for link in linklists.main-menu.links %}\n                {% assign lt = link.title | downcase | strip %}\n                {% if lt == 'collections' %}\n                <li class=\"custom-header__menu-item ma-has-dd\">\n                  <a href=\"{{ link.url }}\" class=\"custom-header__menu-link\">{{ link.title }}</a>\n                  <div class=\"ma-nav-dd\">\n                    <a class=\"ma-nav-dd__link\" href=\"/collections/all-perfumes\">All Perfumes</a>\n                    <div class=\"ma-nav-dd__rule\"></div>\n                    <p class=\"ma-nav-dd__label\">By Season</p>\n                    <a class=\"ma-nav-dd__link\" href=\"/collections/summer-collection\">Summer Collection</a>\n                    <a class=\"ma-nav-dd__link\" href=\"/collections/winter-collection\">Winter Collection</a>\n                  </div>\n                </li>\n                {% else %}\n                <li class=\"custom-header__menu-item\">\n                  <a href=\"{{ link.url }}\" class=\"custom-header__menu-link\">{{ link.title }}</a>\n                </li>\n                {% endif %}\n              {% endfor %}\n            </ul>\n          </nav>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<div class=\"ma-search-overlay\" id=\"ma-search-overlay\" hidden>\n  <div class=\"ma-search-overlay__backdrop\" id=\"ma-search-overlay-backdrop\"></div>\n  <div class=\"ma-search-overlay__panel\">\n    <p class=\"ma-search-overlay__label\">POPULAR SEARCHES</p>\n    <div class=\"ma-search-overlay__tags\">\n      <a href=\"/search?q=Oud\" class=\"ma-search-overlay__tag\">Oud</a>\n      <a href=\"/search?q=Fresh\" class=\"ma-search-overlay__tag\">Fresh</a>\n      <a href=\"/search?q=Seductive\" class=\"ma-search-overlay__tag\">Seductive</a>\n      <a href=\"/search?q=Tobacco\" class=\"ma-search-overlay__tag\">Tobacco</a>\n      <a href=\"/search?q=Rose\" class=\"ma-search-overlay__tag\">Rose</a>\n      <a href=\"/search?q=Woody\" class=\"ma-search-overlay__tag\">Woody</a>\n      <a href=\"/search?q=Amber\" class=\"ma-search-overlay__tag\">Amber</a>\n      <a href=\"/search?q=Musk\" class=\"ma-search-overlay__tag\">Musk</a>\n    </div>\n  </div>\n</div>\n\n<div class=\"ma-drawer\" id=\"ma-drawer\" hidden>\n  <div class=\"ma-drawer__overlay\" data-ma-close></div>\n  <aside class=\"ma-drawer__panel\" role=\"dialog\" aria-modal=\"true\" aria-label=\"Menu\">\n    <div class=\"ma-drawer__head\">\n      <span class=\"ma-drawer__title\">MENU</span>\n      <button class=\"ma-drawer__close\" data-ma-close aria-label=\"Close menu\" type=\"button\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M6 6L18 18M18 6L6 18\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\"/></svg>\n      </button>\n    </div>\n\n    <nav class=\"ma-drawer__nav\" aria-label=\"Mobile navigation\">\n      <ul>\n        {% for link in linklists.main-menu.links %}\n          <li><a href=\"{{ link.url }}\">{{ link.title }}</a></li>\n        {% endfor %}\n        <li class=\"ma-drawer__nav-divider\"></li>\n        <li><a href=\"/collections/winter-collection\">Winter Collection</a></li>\n        <li><a href=\"/collections/summer-collection\">Summer Collection</a></li>\n        <li class=\"ma-drawer__nav-divider\"></li>\n        \n        <li><a href=\"/pages/faq\">FAQ</a></li>\n        <li><a href=\"/pages/our-story\">Our Story</a></li>\n        <li><a href=\"/pages/contact\">Contact Us</a></li>\n      </ul>\n    </nav>\n  </aside>\n</div>\n\n<div class=\"ma-search\" id=\"ma-search\" hidden>\n  <form class=\"ma-search__form\" action=\"{{ routes.search_url }}\" method=\"get\" role=\"search\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><circle cx=\"11\" cy=\"11\" r=\"7\" stroke=\"currentColor\" stroke-width=\"1.6\"/><path d=\"M20 20L16.5 16.5\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\"/></svg>\n    <input type=\"search\" name=\"q\" placeholder=\"Search for a product…\" aria-label=\"Search\" autocomplete=\"off\">\n    <button class=\"ma-search__close\" data-ma-close aria-label=\"Close search\" type=\"button\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M6 6L18 18M18 6L6 18\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\"/></svg>\n    </button>\n  </form>\n  <div class=\"ma-search__popular\">\n    <p class=\"ma-search-overlay__label\">POPULAR SEARCHES</p>\n    <div class=\"ma-search-overlay__tags\">\n      <a href=\"/search?q=Oud\" class=\"ma-search-overlay__tag\">Oud</a>\n      <a href=\"/search?q=Fresh\" class=\"ma-search-overlay__tag\">Fresh</a>\n      <a href=\"/search?q=Seductive+Floral\" class=\"ma-search-overlay__tag\">Seductive Floral</a>\n      <a href=\"/search?q=Tobacco\" class=\"ma-search-overlay__tag\">Tobacco</a>\n      <a href=\"/search?q=Floral\" class=\"ma-search-overlay__tag\">Floral</a>\n      <a href=\"/search?q=Woody\" class=\"ma-search-overlay__tag\">Woody</a>\n      <a href=\"/search?q=Amber\" class=\"ma-search-overlay__tag\">Amber</a>\n      <a href=\"/search?q=Musk\" class=\"ma-search-overlay__tag\">Musk</a>\n    </div>\n  </div>\n</div>\n\n<style>\n  .header-section { height: 0 !important; min-height: 0 !important; padding: 0 !important; margin: 0 !important; border: 0 !important; overflow: hidden !important; }\n  .ma-header-wrap { position: fixed; top: 0; left: 0; right: 0; width: 100%; box-sizing: border-box; z-index: 999; background: #ffffff; transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1); will-change: transform, opacity; }\n  .ma-header-wrap--hidden { opacity: 0; pointer-events: none; }\n  body.ma-no-scroll { overflow: hidden; }\n  .ma-announcement { position: relative; width: 100%; background: #3a3a3a; color: #ffffff; display: flex; align-items: center; justify-content: center; min-height: 40px; padding: 8px 50px; box-sizing: border-box; font-family: \"Helvetica Neue\", Helvetica, Arial, sans-serif; }\n  .ma-announcement__viewport { position: relative; flex: 1; display: flex; justify-content: center; }\n  .ma-announcement__slide { position: absolute; top: 0; left: 0; right: 0; margin: 0; opacity: 0; transition: opacity 0.5s ease; text-align: center; font-size: 13px; line-height: 1.4; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 400; color: #ffffff; }\n  .ma-announcement__slide.is-active { position: relative; opacity: 1; }\n  .ma-announcement__slide strong { font-weight: 600; letter-spacing: 0.18em; }\n  .ma-announcement__short { display: none; transition: opacity 0.35s ease; }\n  .ma-annc-m { display: none; }\n  .ma-annc-m.is-on { display: inline; } .ma-annc-d { display: none; } .ma-annc-d.is-on { display: inline; } .ma-announcement__long { transition: opacity 0.35s ease; }\n  .ma-announcement__arrow { position: absolute; top: 0; bottom: 0; width: 50px; background: none; border: none; color: #ffffff; cursor: pointer; opacity: 0.8; transition: opacity 0.2s ease; display: flex; align-items: center; justify-content: center; padding: 0; }\n  .ma-announcement__arrow svg { width: 18px; height: 18px; display: block; }\n  .ma-announcement__arrow:hover { opacity: 1; }\n  .ma-announcement__arrow--prev { left: 0; }\n  .ma-announcement__arrow--next { right: 0; }\n  .custom-header { background: #ffffff; padding: 18px 24px 0; border-bottom: 1px solid #e5e5e5; font-family: \"Helvetica Neue\", Helvetica, Arial, sans-serif; }\n  .custom-header__container { display: flex; align-items: stretch; margin: 0 auto; }\n  .custom-header__right { flex: 1; display: flex; flex-direction: column; }\n  .custom-header__row-top { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 24px; min-height: 64px; }\n  .custom-header__col-left { display: flex; align-items: center; gap: 12px; justify-self: start; }\n  .custom-header__col-center { display: flex; align-items: center; justify-content: center; }\n  .custom-header__col-right { display: flex; align-items: center; justify-self: end; }\n  .ma-mobile-only { display: none; }\n  .ma-desktop-only { display: inline-flex; }\n  shopify-store { display: none !important; }\n  .custom-header__desktop-search { position: relative; width: 100%; max-width: 360px; margin-right: auto; display: flex; align-items: center; border-bottom: 1px solid #000; }\n  .custom-header__desktop-search input { flex: 1; border: 0; background: transparent; outline: none; padding: 10px 8px; font-size: 13px; letter-spacing: 0.04em; color: #000; font-family: inherit; }\n  .custom-header__desktop-search input::placeholder { color: #777; }\n  .custom-header__desktop-search button { background: none; border: 0; cursor: pointer; padding: 6px; color: #000; display: flex; align-items: center; }\n  .custom-header__desktop-search svg { width: 18px; height: 18px; }\n  .custom-header__brand-link { text-decoration: none; display: inline-flex; align-items: center; line-height: 1; }\n  .custom-header__brand-text { font-size: clamp(30px, 5.2vw, 60px); font-family: Sinoreta, Georgia, serif; font-weight: 500; letter-spacing: 0.3px; text-transform: uppercase; color: #000; line-height: 1; display: inline-block; white-space: nowrap; }\n  .custom-header__icons { display: flex; align-items: center; gap: 22px; }\n  .custom-header__icon-link { display: inline-flex; align-items: center; gap: 8px; color: #000; background: none; border: none; cursor: pointer; padding: 0; text-decoration: none; line-height: 1; position: relative; }\n  .custom-header__icon-link:hover { opacity: 0.7; }\n  .custom-header__icon-link > svg { width: 22px; height: 22px; display: block; flex-shrink: 0; }\n  .ma-icon-label { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: #000; font-weight: 500; line-height: 1; }\n  .custom-header__account-wrapper { gap: 6px; cursor: pointer; }\n  .custom-header__account-wrapper shopify-account { display: inline-flex !important; align-items: center !important; justify-content: center !important; width: 22px !important; height: 22px !important; min-width: 22px; margin: 0 !important; padding: 0 !important; overflow: hidden; line-height: 1 !important; }\n  .custom-header__account-wrapper shopify-account .ma-account-svg,\n  .custom-header__account-wrapper shopify-account [slot=\"signed-out-avatar\"] { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; }\n  .custom-header__account-wrapper shopify-account svg { width: 22px !important; height: 22px !important; display: block; color: #000; }\n  .custom-header__account-wrapper shopify-account span:not([slot]) { display: none; }\n  .ma-account-label { background: none; border: 0; cursor: pointer; padding: 0; margin: 0; fo