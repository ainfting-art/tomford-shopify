{% comment %} MAISON AMIIR — §6 Explore the Maison: 3+2 collection photography grid {% endcomment %}

<div class="ma-explore">
  <div class="ma-explore__head">
    <h2 class="ma-explore__h2 ma-home-reveal">{{ section.settings.heading }}</h2>
    {%- if section.settings.subtext != blank -%}
      <p class="ma-explore__sub ma-home-reveal">{{ section.settings.subtext }}</p>
    {%- endif -%}
  </div>

  <div class="ma-explore__grid">
    {%- for block in section.blocks -%}
      {%- assign col = block.settings.collection -%}
      {%- assign tile_img = block.settings.image -%}
      {%- if tile_img == blank and col != blank and col.featured_image -%}
        {%- assign tile_img = col.featured_image -%}
      {%- endif -%}
      <a class="ma-explore__tile ma-home-reveal"
         href="{% if block.settings.link != blank %}{{ block.settings.link }}{% elsif col != blank %}{{ col.url }}{% else %}#{% endif %}"
         {{ block.shopify_attributes }}>
        {%- if tile_img != blank -%}
          {{ tile_img | image_url: width: 1400 | image_tag: loading: 'lazy', alt: block.settings.label, class: 'ma-explore__img' }}
        {%- else -%}
          <span class="ma-explore__img ma-explore__img--fallback" aria-hidden="true"></span>
        {%- endif -%}
        <span class="ma-explore__shade" aria-hidden="true"></span>
        <span class="ma-explore__meta">
          <span class="ma-explore__label">{{ block.settings.label }}</span>
          {%- if block.settings.subline != blank -%}
            <span class="ma-explore__subline">{{ block.settings.subline }}</span>
          {%- endif -%}
        </span>
      </a>
    {%- endfor -%}
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} { opacity: 1 !important; transform: none !important; }

  .ma-explore {
    background: #fff;
    color: rgba(0,0,0,.81);
    padding: clamp(3.2rem, 7vw, 5rem) clamp(1.2rem, 4vw, 3rem);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }
  .ma-explore *, .ma-explore *::before, .ma-explore *::after { box-sizing: border-box; }

  .ma-explore__head { text-align: center; margin-bottom: clamp(2rem, 4.5vw, 3rem); }
  .ma-explore__h2 { font-family: 'Sinoreta', Georgia, serif; font-size: clamp(1.8rem, 4vw, 2.5rem); font-weight: 300; letter-spacing: .02em; color: rgba(0,0,0,.85); margin: 0 0 1rem; }
  .ma-explore__sub { font-size: clamp(.95rem, 1.4vw, 1.06rem); font-weight: 300; line-height: 1.85; color: rgba(0,0,0,.55); max-width: 560px; margin: 0 auto; }

  .ma-explore__grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: clamp(.8rem, 1.6vw, 1.4rem); max-width: 1200px; margin: 0 auto; }
  .ma-explore__tile { position: relative; display: block; overflow: hidden; text-decoration: none; grid-column: span 2; aspect-ratio: 4 / 5; background: #14100c; }
  .ma-explore__tile:nth-child(4), .ma-explore__tile:nth-child(5) { grid-column: span 3; aspect-ratio: 21 / 9; }

  .ma-explore__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 1.1s cubic-bezier(.16,1,.3,1); }
  .ma-explore__tile:hover .ma-explore__img { transform: scale(1.045); }
  .ma-explore__img--fallback { background: linear-gradient(150deg, #1a1410 0%, #2a1e14 55%, #0c0906 100%); }
  .ma-explore__tile:nth-child(2) .ma-explore__img--fallback { background: linear-gradient(150deg, #14101a 0%, #241424 55%, #0a0710 100%); }
  .ma-explore__tile:nth-child(3) .ma-explore__img--fallback { background: linear-gradient(150deg, #0a1210 0%, #14201a 55%, #060c0a 100%); }

  .ma-explore__shade { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,.62) 0%, rgba(0,0,0,.12) 45%, rgba(0,0,0,0) 70%); transition: background .5s; }
  .ma-explore__tile:hover .ma-explore__shade { background: linear-gradient(to top, rgba(0,0,0,.72) 0%, rgba(0,0,0,.2) 50%, rgba(0,0,0,.05) 100%); }

  .ma-explore__meta { position: absolute; left: 1.4rem; right: 1.4rem; bottom: 1.25rem; }
  .ma-explore__label { display: block; font-family: 'Sinoreta', Georgia, serif; font-size: clamp(1.25rem, 2.2vw, 1.7rem); font-weight: 300; letter-spacing: .06em; color: #fff; line-height: 1.2; }
  .ma-explore__subline { display: block; margin-top: .45rem; font-size: .72rem; font-weight: 300; letter-spacing: .22em; text-transform: uppercase; color: rgba(255,255,255,.72); }

  @media (max-width: 749px) {
    .ma-explore__grid { grid-template-columns: 1fr 1fr; }
    .ma-explore__tile { grid-column: span 1; aspect-ratio: 4 / 5; }
    .ma-explore__tile:nth-child(3) { grid-column: span 2; aspect-ratio: 16 / 9; }
    .ma-explore__tile:nth-child(4), .ma-explore__tile:nth-child(5) { grid-column: span 2; aspect-ratio: 16 / 9; }
  }
</style>


{% schema %}
{
  "name": "MA Explore the Maison",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Explore the Maison" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "We don't just sell scents; we archive moments of elegance, capturing the ephemeral and making it eternal." }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Collection tile",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "url", "id": "link", "label": "Link override (optional)" },
        { "type": "image_picker", "id": "image", "label": "Image (falls back to collection image)" },
        { "type": "text", "id": "label", "label": "Label", "default": "Masculine" },
        { "type": "text", "id": "subline", "label": "Subline (optional)" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [{ "name": "MA Explore the Maison" }]
}
{% endschema %}
