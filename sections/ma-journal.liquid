{%- comment -%} MAISON AMIIR — From the Journal. Shows 3 posts from the chosen blog,
  rotating automatically: server time is bucketed into N-day windows (default 3), and
  the window number deterministically picks 3 spread-out articles from the pool. All
  visitors see the same trio (cache-friendly); the trio changes when the window rolls.
  New posts join the pool automatically. Mobile = swipe row with dots (like Most Wanted). {%- endcomment -%}
{%- liquid
  assign jblog = section.settings.blog
  if jblog == blank
    assign jblog = blogs['blogs']
  endif
  assign total = jblog.articles_count
  if total > 50
    assign total = 50
  endif
-%}
{%- if jblog != blank and total > 0 -%}
  {%- liquid
    assign days = section.settings.rotation_days | default: 3
    assign win_len = days | times: 86400
    assign now_s = 'now' | date: '%s' | plus: 0
    assign window = now_s | divided_by: win_len
    if total <= 3
      assign i1 = 0
      assign i2 = 1
      assign i3 = 2
    else
      assign hop = window | times: 5 | plus: 1
      assign i1 = hop | modulo: total
      assign s1 = total | divided_by: 3
      if s1 < 1
        assign s1 = 1
      endif
      assign s2 = total | times: 2 | divided_by: 3
      if s2 <= s1
        assign s2 = s1 | plus: 1
      endif
      assign i2 = i1 | plus: s1 | modulo: total
      assign i3 = i1 | plus: s2 | modulo: total
    endif
    assign idxs = i1 | append: ',' | append: i2 | append: ',' | append: i3
    assign idx_arr = idxs | split: ','
  -%}
  <style>#shopify-section-{{ section.id }} { opacity: 1 !important; transform: none !important; }</style>
  <section class="ma-journal">
    <p class="ma-journal__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    <h2 class="ma-journal__title">{{ section.settings.heading | escape }}</h2>
    <div class="ma-journal__track">
      {%- for sidx in idx_arr -%}
        {%- assign ai = sidx | plus: 0 -%}
        {%- assign article = jblog.articles[ai] -%}
        {%- if article -%}
          <a class="ma-journal__card" href="{{ article.url }}">
            <span class="ma-journal__media">
              {%- if article.image -%}
                {{ article.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: article.title, class: 'ma-journal__img' }}
              {%- else -%}
                <span class="ma-journal__img ma-journal__img--ph"></span>
              {%- endif -%}
            </span>
            <span class="ma-journal__meta">{% if article.tags.first %}{{ article.tags.first | upcase }} &middot; {% endif %}{{ article.published_at | date: '%e %b %Y' | lstrip | upcase }}</span>
            <span class="ma-journal__name">{{ article.title }}</span>
            <span class="ma-journal__read">Read</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
    <div class="ma-journal__dots">
      {%- for sidx in idx_arr limit: total -%}
        <button type="button" class="ma-journal__dot{% if forloop.first %} is-active{% endif %}" aria-label="Story {{ forloop.index }}"></button>
      {%- endfor -%}
    </div>
  </section>
  <script src="{{ 'ma-journal.js' | asset_url }}" defer></script>
{%- endif -%}

{% stylesheet %}
  .ma-journal {
    max-width: 1200px;
    margin: 0 auto;
    padding: 56px 24px 64px;
  }
  .ma-journal__eyebrow {
    margin: 0 0 10px;
    text-align: center;
    font-size: 11px;
    letter-spacing: .3em;
    text-transform: uppercase;
    color: #A8894E;
  }
  .ma-journal__title {
    margin: 0 0 38px;
    text-align: center;
    font-family: Sinoreta, Georgia, 'Times New Roman', serif;
    font-weight: 400;
    font-size: clamp(30px, 4vw, 44px);
    color: var(--color-foreground);
  }
  .ma-journal__track {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 26px;
  }
  .ma-journal__card {
    display: block;
    text-decoration: none;
    color: var(--color-foreground);
  }
  .ma-journal__media {
    display: block;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / .06);
  }
  .ma-journal__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .6s ease;
  }
  .ma-journal__card:hover .ma-journal__img { transform: scale(1.04); }
  .ma-journal__img--ph { display: block; }
  .ma-journal__meta {
    display: block;
    margin: 14px 0 8px;
    font-size: 11px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / .55);
  }
  .ma-journal__name {
    display: block;
    margin: 0 0 12px;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 19px;
    line-height: 1.35;
  }
  .ma-journal__read {
    display: inline-block;
    font-size: 11px;
    letter-spacing: .2em;
    text-transform: uppercase;
    border-bottom: 1px solid currentColor;
    padding-bottom: 3px;
  }
  .ma-journal__dots { display: none; }

  @media screen and (max-width: 749px) {
    .ma-journal { padding: 40px 0 48px 18px; }
    .ma-journal__title { margin-bottom: 26px; }
    .ma-journal__track {
      display: flex;
      gap: 14px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-right: 18px;
    }
    .ma-journal__track::-webkit-scrollbar { display: none; }
    .ma-journal__card { flex: 0 0 78%; scroll-snap-align: start; }
    .ma-journal__dots {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-top: 18px;
      padding-right: 18px;
    }
    .ma-journal__dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      border: 0;
      padding: 0;
      background: rgb(var(--color-foreground-rgb) / .25);
      cursor: pointer;
    }
    .ma-journal__dot.is-active { background: var(--color-foreground); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MA — From the Journal",
  "tag": "section",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog to pull from (defaults to Blogs)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Notes on Craft & Scent"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From the Journal"
    },
    {
      "type": "range",
      "id": "rotation_days",
      "label": "Rotate stories every (days)",
      "min": 1,
      "max": 14,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "MA — From the Journal"
    }
  ]
}
{% endschema %}
