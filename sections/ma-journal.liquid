{%- comment -%} MAISON AMIIR — From the Journal. Shows 3 posts from the chosen blog,
  rotating automatically (server time bucketed into N-day windows; window number picks
  3 spread-out articles). DESKTOP = 3-column grid cards (image on top). MOBILE = stacked
  list (thumbnail left; date, title, Read each on its own line). {%- endcomment -%}
{%- liquid
  assign jblog = section.settings.blog
  if jblog == blank
    assign jblog = blogs['blogs']
  endif
  assign total = jblog.articles_count
  if total > 50
    assign total = 50
  endif
-%}
{%- if jblog != blank and total > 0 -%}
  {%- liquid
    assign days = section.settings.rotation_days | default: 3
    assign win_len = days | times: 86400
    assign now_s = 'now' | date: '%s' | plus: 0
    assign window = now_s | divided_by: win_len
    if total <= 3
      assign i1 = 0
      assign i2 = 1
      assign i3 = 2
    else
      assign hop = window | times: 5 | plus: 1
      assign i1 = hop | modulo: total
      assign s1 = total | divided_by: 3
      if s1 < 1
        assign s1 = 1
      endif
      assign s2 = total | times: 2 | divided_by: 3
      if s2 <= s1
        assign s2 = s1 | plus: 1
      endif
      assign i2 = i1 | plus: s1 | modulo: total
      assign i3 = i1 | plus: s2 | modulo: total
    endif
    assign idxs = i1 | append: ',' | append: i2 | append: ',' | append: i3
    assign idx_arr = idxs | split: ','
  -%}
  <style>
    #shopify-section-{{ section.id }} { opacity: 1 !important; transform: none !important; }
    .ma-journal { max-width: 740px; margin: 0 auto; padding: 56px 24px 60px; }
    .ma-journal__eyebrow { margin: 0 0 10px; text-align: center; font-size: 11px; letter-spacing: .3em; text-transform: uppercase; color: #A8894E; }
    .ma-journal__title { margin: 0 0 32px; text-align: center; font-family: Sinoreta, Georgia, 'Times New Roman', serif; font-weight: 400; font-size: clamp(30px, 4vw, 44px); color: var(--color-foreground, #1a1a1a); }

    /* ===== MOBILE (default): stacked list — thumbnail left, date/title/read stacked right ===== */
    .ma-journal__list { display: block; }
    .ma-journal__row { display: flex; align-items: center; gap: 15px; padding: 18px 0; border-top: 1px solid #e5dfd2; text-decoration: none; color: var(--color-foreground, #1a1a1a); }
    .ma-journal__row:last-child { border-bottom: 1px solid #e5dfd2; }
    .ma-journal__thumb { flex: 0 0 84px; aspect-ratio: 1 / 1; overflow: hidden; background: rgba(26, 26, 26, .06); }
    .ma-journal__img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .6s ease; }
    .ma-journal__row:hover .ma-journal__img { transform: scale(1.05); }
    .ma-journal__img--ph { display: block; }
    .ma-journal__body { flex: 1; min-width: 0; }
    .ma-journal__date { display: block; margin: 0 0 6px; font-size: 9px; letter-spacing: .18em; text-transform: uppercase; color: rgba(26, 26, 26, .55); }
    .ma-journal__name { display: block; margin: 0 0 8px; font-family: Georgia, 'Times New Roman', serif; font-size: 15px; line-height: 1.3; }
    .ma-journal__read { display: inline-block; font-size: 10px; letter-spacing: .2em; text-transform: uppercase; border-bottom: 1px solid currentColor; padding-bottom: 2px; }

    /* ===== DESKTOP: original 3-column grid cards (image on top) ===== */
    @media screen and (min-width: 750px) {
      .ma-journal { max-width: 1200px; }
      .ma-journal__list { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 26px; }
      .ma-journal__row { flex-direction: column; align-items: stretch; gap: 0; padding: 0; border: 0; }
      .ma-journal__row:last-child { border: 0; }
      .ma-journal__thumb { flex: none; width: 100%; aspect-ratio: 4 / 5; margin-bottom: 14px; }
      .ma-journal__date { margin: 0 0 8px; font-size: 11px; }
      .ma-journal__name { margin: 0 0 12px; font-size: 19px; line-height: 1.35; }
    }
  </style>
  <section class="ma-journal">
    <p class="ma-journal__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    <h2 class="ma-journal__title">{{ section.settings.heading | escape }}</h2>
    <div class="ma-journal__list">
      {%- for sidx in idx_arr -%}
        {%- assign ai = sidx | plus: 0 -%}
        {%- assign article = jblog.articles[ai] -%}
        {%- if article -%}
          <a class="ma-journal__row" href="{{ article.url }}">
            <span class="ma-journal__thumb">
              {%- if article.image -%}
                {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: article.title, class: 'ma-journal__img' }}
              {%- else -%}
                <span class="ma-journal__img ma-journal__img--ph"></span>
              {%- endif -%}
            </span>
            <span class="ma-journal__body">
              <span class="ma-journal__date">{{ article.published_at | date: '%e %b %Y' | lstrip | upcase }}</span>
              <span class="ma-journal__name">{{ article.title }}</span>
              <span class="ma-journal__read">Read</span>
            </span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}


{% schema %}
{
  "name": "MA — From the Journal",
  "tag": "section",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog to pull from (defaults to Blogs)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Notes on Craft & Scent"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From the Journal"
    },
    {
      "type": "range",
      "id": "rotation_days",
      "label": "Rotate stories every (days)",
      "min": 1,
      "max": 14,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "MA — From the Journal"
    }
  ]
}
{% endschema %}
