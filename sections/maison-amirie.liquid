<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Maison Amirie — House of Rare Fragrance</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #000000;
    --charcoal: #1A1A1A;
    --gold: #ffffff;
    --gold-light: #e0e0e0;
    --gold-dim: rgba(255,255,255,0.15);
    --white: #f5f5f5;
    --muted: rgba(255,255,255,0.45);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    letter-spacing: 0.04em;
    overflow-x: hidden;
    cursor: none;
  }
  #header-group , footer {
  display:none !important;
}

  /* Custom cursor */
  .cursor {
    position: fixed;
    width: 10px; height: 10px;
    background: var(--gold);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%,-50%);
    transition: transform 0.1s ease, width 0.3s ease, height 0.3s ease, background 0.3s ease;
    mix-blend-mode: difference;
  }
  .cursor-ring {
    position: fixed;
    width: 36px; height: 36px;
    border: 1px solid rgba(255,255,255,0.5);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9998;
    transform: translate(-50%,-50%);
    transition: transform 0.18s ease, width 0.3s ease, height 0.3s ease;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 28px 60px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.9) 0%, transparent 100%);
  }

  .nav-logo {
    font-size: 11px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
  }

  .nav-links {
    display: flex;
    gap: 44px;
    list-style: none;
  }

  .nav-links a {
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.4s ease;
  }
  .nav-links a:hover { color: var(--gold); }

  .nav-cta {
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    border: 1px solid rgba(255,255,255,0.4);
    color: var(--gold);
    padding: 10px 22px;
    text-decoration: none;
    transition: background 0.4s ease, color 0.4s ease;
  }
  .nav-cta:hover {
    background: var(--gold);
    color: var(--black);
  }

  /* ─── HERO ─── */
  .hero {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 70% at 50% 60%, rgba(255,255,255,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 30% 40% at 80% 20%, rgba(255,255,255,0.04) 0%, transparent 60%),
      var(--black);
  }

  /* Noise texture overlay */
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    opacity: 0.4;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    text-align: center;
    z-index: 2;
    animation: heroReveal 1.8s cubic-bezier(0.16,1,0.3,1) both;
  }

  @keyframes heroReveal {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow {
    font-size: 10px;
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 28px;
    font-weight: 500;
    animation: heroReveal 1.8s 0.2s cubic-bezier(0.16,1,0.3,1) both;
  }

  .hero-title {
    font-family: 'Didot', 'Didot LT STD', 'GFS Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-size: clamp(64px, 9vw, 140px);
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: var(--white);
    margin-bottom: 10px;
    animation: heroReveal 1.8s 0.35s cubic-bezier(0.16,1,0.3,1) both;
  }

  .hero-title span {
    display: block;
    color: var(--gold);
    font-style: italic;
  }

  .hero-sub {
    font-size: 11px;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 30px;
    margin-bottom: 56px;
    animation: heroReveal 1.8s 0.5s cubic-bezier(0.16,1,0.3,1) both;
  }

  .hero-actions {
    display: flex;
    gap: 20px;
    justify-content: center;
    animation: heroReveal 1.8s 0.65s cubic-bezier(0.16,1,0.3,1) both;
  }

  .btn-primary {
    background: var(--gold);
    color: var(--black);
    padding: 16px 42px;
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.4s, transform 0.3s;
    font-family: 'Montserrat', sans-serif;
    border: none;
    cursor: none;
  }
  .btn-primary:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
  }

  .btn-ghost {
    background: transparent;
    color: var(--white);
    padding: 16px 42px;
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    font-weight: 400;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.25);
    transition: border-color 0.4s, color 0.4s;
    font-family: 'Montserrat', sans-serif;
    cursor: none;
  }
  .btn-ghost:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  /* Scroll indicator */
  .scroll-hint {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    animation: heroReveal 2s 1s both;
  }
  .scroll-hint span {
    font-size: 9px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .scroll-line {
    width: 1px;
    height: 50px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }

  /* ─── MARQUEE ─── */
  .marquee-strip {
    border-top: 1px solid rgba(255,255,255,0.2);
    border-bottom: 1px solid rgba(255,255,255,0.2);
    padding: 18px 0;
    overflow: hidden;
    background: var(--charcoal);
  }
  .marquee-inner {
    display: flex;
    gap: 0;
    animation: marqueeScroll 22s linear infinite;
    white-space: nowrap;
  }
  .marquee-inner span {
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    padding: 0 48px;
    font-weight: 500;
  }
  .marquee-inner .sep {
    color: rgba(255,255,255,0.3);
    padding: 0;
    letter-spacing: 0;
  }
  @keyframes marqueeScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ─── STORY ─── */
  .section {
    padding: 130px 60px;
  }

  .story {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    align-items: center;
    max-width: 1300px;
    margin: 0 auto;
  }

  .story-label {
    font-size: 9px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    margin-bottom: 28px;
  }

  .story-heading {
    font-family: 'Didot', 'Didot LT STD', 'GFS Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-size: clamp(36px, 4vw, 62px);
    font-weight: 400;
    line-height: 1.1;
    margin-bottom: 32px;
    letter-spacing: -0.01em;
  }

  .story-heading em {
    color: var(--gold);
    font-style: italic;
  }

  .story-body {
    font-size: 13.5px;
    line-height: 1.95;
    color: var(--muted);
    margin-bottom: 40px;
    font-weight: 300;
  }

  .story-visual {
    position: relative;
    aspect-ratio: 3/4;
    background: var(--charcoal);
    overflow: hidden;
  }

  .story-visual::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 80%, rgba(255,255,255,0.12) 0%, transparent 60%),
      linear-gradient(135deg, #1A1A1A 0%, #0D0D0D 100%);
  }

  .story-visual-inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* SVG Bottle illustration */
  .bottle-svg {
    width: 180px;
    filter: drop-shadow(0 30px 60px rgba(255,255,255,0.25));
    animation: bottleFloat 6s ease-in-out infinite;
  }
  @keyframes bottleFloat {
    0%,100% { transform: translateY(0) rotate(-1deg); }
    50%      { transform: translateY(-18px) rotate(1deg); }
  }

  .story-visual-label {
    position: absolute;
    bottom: 40px;
    left: 40px;
    right: 40px;
    border-top: 1px solid rgba(255,255,255,0.2);
    padding-top: 20px;
  }
  .story-visual-label p {
    font-size: 9px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .story-visual-label h4 {
    font-family: 'Didot', 'Didot LT STD', 'GFS Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-size: 22px;
    font-weight: 400;
    margin-top: 6px;
    color: var(--white);
  }

  /* ─── COLLECTION ─── */
  .collection {
    background: var(--charcoal);
  }

  .section-header {
    text-align: center;
    margin-bottom: 80px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-header .label {
    font-size: 9px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    display: block;
    margin-bottom: 20px;
  }

  .section-header h2 {
    font-family: 'Didot', 'Didot LT STD', 'GFS Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-size: clamp(36px, 4vw, 58px);
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .section-header p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.8;
    font-weight: 300;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    max-width: 1300px;
    margin: 0 auto;
  }

  .product-card {
    position: relative;
    aspect-ratio: 3/4;
    background: #0D0D0D;
    overflow: hidden;
    cursor: none;
  }

  .product-card:nth-child(2) { background: #111; margin-top: -60px; }
  .product-card:nth-child(3) { background: #0A0A0A; }

  .product-card-bg {
    position: absolute;
    inset: 0;
    transition: transform 0.8s cubic-bezier(0.16,1,0.3,1);
  }

  .product-card:hover .product-card-bg {
    transform: scale(1.05);
  }

  .product-card-bg-1 {
    background:
      radial-gradient(ellipse 70% 50% at 50% 90%, rgba(255,255,255,0.15) 0%, transparent 60%),
      radial-gradient(ellipse 40% 30% at 30% 20%, rgba(255,255,255,0.05) 0%, transparent 50%),
      linear-gradient(160deg, #1a1a1a 0%, #0A0A0A 100%);
  }
  .product-card-bg-2 {
    background:
      radial-gradient(ellipse 70% 50% at 50% 85%, rgba(255,255,255,0.12) 0%, transparent 60%),
      linear-gradient(160deg, #151515 0%, #080808 100%);
  }
  .product-card-bg-3 {
    background:
      radial-gradient(ellipse 70% 50% at 50% 90%, rgba(255,255,255,0.1) 0%, transparent 60%),
      linear-gradient(160deg, #181818 0%, #0A0A0A 100%);
  }

  .product-card-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 40px;
    z-index: 2;
  }

  .product-card-content::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 60%);
    pointer-events: none;
  }

  .product-tag {
    position: absolute;
    top: 30px;
    right: 30px;
    font-size: 9px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(255,255,255,0.35);
    padding: 6px 14px;
  }

  .product-info {
    position: relative;
    z-index: 1;
  }

  .product-accord {
    font-size: 9px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
    font-weight: 500;
  }

  .product-name {
    font-family: 'Didot', 'Didot LT STD', 'GFS Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-size: 32px;
    font-weight: 400;
    margin-bottom: 8px;
    letter-spacing: 0.01em;
    color: var(--white);
  }

  .product-story {
    font-size: 12px;
    line-height: 1.7;
    color: rgba(255,255,255,0.5);
    margin-bottom: 24px;
    font-weight: 300;
    max-width: 260px;
  }

  .product-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(255,255,255,0.15);
    padding-top: 20px;
  }

  .product-price {
    font-size: 18px;
    color: var(--gold);
    font-family: 'Didot', 'Didot LT STD', 'GFS Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    letter-spacing: 0.02em;
  }

  .product-price span {
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--muted);
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    margin-right: 4px;
  }

  .btn-add {
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--white);
    background: transparent;
    border: 1px solid rgba(255,255,255,0.2);
    padding: 10px 20px;
    cursor: none;
    transition: border-color 0.4s, color 0.4s, background 0.4s;
    font-family: 'Montserrat', sans-serif;
  }
  .btn-add:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  /* Floating bottle in card */
  .card-bottle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -55%);
    width: 100px;
    filter: drop-shadow(0 20px 50px rgba(255,255,255,0.3));
    transition: transform 0.8s cubic-bezier(0.16,1,0.3,1);
  }
  .product-card:hover .card-bottle {
    transform: translate(-50%, -60%);
  }

  /* ─── RITUAL SECTION ─── */
  .ritual {
    position: relative;
    overflow: hidden;
  }

  .ritual-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 50%, rgba(255,255,255,0.06) 0%, transparent 70%),
      var(--black);
  }

  .ritual-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    max-width: 1300px;
    margin: 0 auto;
  }

  .ritual-steps {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .ritual-step {
    display: flex;
    gap: 24px;
    align-items: flex-start;
    opacity: 0.5;
    transition: opacity 0.4s;
    border-left: 1px solid transparent;
    padding-left: 24px;
    transition: all 0.4s ease;
  }
  .ritual-step:hover {
    opacity: 1;
    border-left-color: var(--gold);
  }

  .step-number {
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--gold);
    font-weight: 500;
    padding-top: 3px;
    min-width: 28px;
  }

  .step-title {
    font-family: 'Didot', 'Didot LT STD', 'GFS Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-size: 22px;
    font-weight: 400;
    margin-bottom: 8px;
  }

  .step-desc {
    font-size: 12.5px;
    color: var(--muted);
    line-height: 1.8;
    font-weight: 300;
  }

  .ritual-visual {
    position: relative;
    aspect-ratio: 1;
    background: var(--charcoal);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ritual-glow {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%);
    animation: glowPulse 4s ease-in-out infinite;
  }
  @keyframes glowPulse {
    0%,100% { transform: scale(1); opacity: 0.7; }
    50%      { transform: scale(1.3); opacity: 1; }
  }

  .ritual-circle {
    position: absolute;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 50%;
    animation: rotateSlow 20s linear infinite;
  }
  .ritual-circle:nth-child(2) { width: 280px; height: 280px; }
  .ritual-circle:nth-child(3) { width: 380px; height: 380px; animation-duration: 30s; animation-direction: reverse; }
  .ritual-circle:nth-child(4) { width: 460px; height: 460px; animation-duration: 40s; }
  @keyframes rotateSlow {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  .ritual-quote {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 40px;
  }
  .ritual-quote blockquote {
    font-family: 'Didot', 'Didot LT STD', 'GFS Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-size: 26px;
    font-weight: 400;
    font-style: italic;
    line-height: 1.5;
    color: var(--white);
    margin-bottom: 20px;
  }
  .ritual-quote cite {
    font-size: 9px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    font-style: normal;
    font-weight: 500;
  }

  /* ─── PROVENANCE ─── */
  .provenance {
    background: var(--charcoal);
  }
  .provenance-inner {
    max-width: 1300px;
    margin: 0 auto;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.1);
    margin-top: 80px;
  }

  .stat-block {
    background: var(--charcoal);
    padding: 60px 40px;
    text-align: center;
    transition: background 0.4s;
  }
  .stat-block:hover { background: #1E1E1E; }

  .stat-num {
    font-family: 'Didot', 'Didot LT STD', 'GFS Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-size: 58px;
    font-weight: 400;
    color: var(--gold);
    display: block;
    line-height: 1;
    margin-bottom: 12px;
  }

  .stat-label {
    font-size: 9px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }

  /* ─── TESTIMONIAL ─── */
  .testimonial-section {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .testimonial-quote {
    font-family: 'Didot', 'Didot LT STD', 'GFS Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-size: clamp(26px, 3vw, 42px);
    font-weight: 400;
    font-style: italic;
    line-height: 1.45;
    color: var(--white);
    margin-bottom: 36px;
  }

  .testimonial-author {
    font-size: 9px;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
  }

  .gold-line {
    width: 60px;
    height: 1px;
    background: var(--gold);
    margin: 30px auto;
    opacity: 0.5;
  }

  /* ─── NEWSLETTER ─── */
  .newsletter {
    background: var(--charcoal);
    text-align: center;
  }

  .newsletter-inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .newsletter h2 {
    font-family: 'Didot', 'Didot LT STD', 'GFS Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 400;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }

  .newsletter p {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 44px;
    line-height: 1.8;
    font-weight: 300;
  }

  .email-form {
    display: flex;
    gap: 0;
    border: 1px solid rgba(255,255,255,0.3);
  }

