{% comment %}
  Maison Amiir — custom footer (Tom Ford style)
  Hardened: no horizontal overflow / cropping, responsive side padding.
{% endcomment %}

{% stylesheet %}
/* === MAISON AMIIR FOOTER — TOM FORD STYLE === */

/* box-sizing + overflow guard so the footer can never be wider than the screen */
.ma-footer, .ma-footer * { box-sizing: border-box; }

.ma-footer {
  background: #fff;
  color: #000;
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  border-top: 1px solid #e0e0e0;
  width: 100%;
  max-width: 100%;
  overflow-x: hidden;
}

/* ── TOP INNER WRAPPER ── */
.ma-footer__inner {
  max-width: 1400px;
  margin: 0 auto;
  /* responsive side padding — shrinks gracefully instead of overflowing */
  padding: clamp(40px, 5vw, 80px) clamp(20px, 5vw, 80px) 0;
}

/* ── FOUR COLUMNS ROW (3 nav + 1 newsletter) ── */
.ma-footer__columns {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;            /* allow columns to wrap before overflowing */
  gap: clamp(24px, 3vw, 48px);
  padding-bottom: clamp(40px, 5vw, 80px);
}

.ma-footer__col {
  flex: 1 1 180px;           /* never narrower than 180px, wraps instead of clipping */
  min-width: 0;
}

/* Newsletter column slightly wider */
.ma-footer__col--subscribe {
  flex: 1.2 1 260px;
}

.ma-footer__col-heading {
  font-size: 15px;
  font-weight: 700;
  letter-spacing: -0.4px;
  text-transform: uppercase;
  color: #000;
  margin: 0 0 16px;
  padding: 0;
}

.ma-footer__col ul {
  list-style: none;
  margin: 0;
  padding: 0;
}

.ma-footer__col ul li a {
  font-size: 13px;
  color: #000;
  text-decoration: none;
  letter-spacing: -0.4px;
  text-transform: uppercase;
  line-height: 2.5;
  display: block;
}

.ma-footer__col ul li a:hover {
  text-decoration: underline;
}

/* ── NEWSLETTER (4th column, same row as nav) ── */
.ma-footer__newsletter-subtext {
  font-size: 13px;
  color: #000;
  letter-spacing: -0.4px;
  line-height: 1.7;
  margin: 0 0 10px;
}

.ma-footer__email-input {
  display: block;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  border: 0.83px solid #b7b7b7;
  background: #fff;
  font-size: 12px;
  letter-spacing: -0.4px;
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  color: #000;
  padding: 12px 14px;
  outline: none;
  margin-bottom: 10px;
}

.ma-footer__email-input::placeholder {
  color: #aaa;
  text-transform: uppercase;
  letter-spacing: -0.5px;
}

.ma-footer__consent {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  margin-bottom: 18px;
}

.ma-footer__consent input[type="checkbox"] {
  margin-top: 2px;
  flex-shrink: 0;
  accent-color: #000;
  width: 13px;
  height: 13px;
  cursor: pointer;
}

.ma-footer__consent-label {
  font-size: 11px;
  color: #000;
  letter-spacing: -0.4px;
  line-height: 1.6;
}

.ma-footer__consent-label a {
  color: #000;
  text-decoration: underline;
}

.ma-footer__signup-btn {
  display: block;
  width: 100%;
  max-width: 100%;
  background: #000;
  color: #fff;
  border: none;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 14px;
  cursor: pointer;
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  transition: background 0.2s;
}

.ma-footer__signup-btn:hover {
  background: #333;
}

/* ── BOTTOM BAR ── */
.ma-footer__bottom-wrap {
  border-top: 1px solid #e0e0e0;
}

.ma-footer__bottom {
  max-width: 1400px;
  margin: 0 auto;
  padding: 22px clamp(20px, 5vw, 60px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;           /* wrap instead of clipping on mid widths */
  gap: 16px;
}

.ma-footer__brand {
  font-family: 'Sinoreta', serif;
  font-size: 25px;
  font-weight: 700 !important;
  color: #000 !important;
  -webkit-text-fill-color: #000 !important;
  letter-spacing: 0.12em;
  text-decoration: none;
  text-transform: uppercase;
  flex-shrink: 0;
}

.ma-footer__bottom-right {
  display: flex;
  align-items: center;
  gap: 30px;
  flex-wrap: wrap;
}

.ma-footer__social {
  display: flex;
  align-items: center;
  gap: 18px;
}

.ma-footer__social a {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #000;
  line-height: 1;
  transition: opacity 0.2s;
}

.ma-footer__social a:hover {
  opacity: 0.5;
}

.ma-footer__copyright {
  font-size: 13px;
  color: #000 !important;
  -webkit-text-fill-color: #000 !important;
  letter-spacing: -0.4px;
  white-space: nowrap;
}

/* ── MOBILE ── */
@media (max-width: 768px) {
  .ma-footer__inner {
    padding: 0;
  }

  .ma-footer__columns {
    display: none;
  }

  /* Accordion items */
  .ma-footer__accordion {
    border-top: 1px solid #e0e0e0;
  }

  .ma-footer__accordion-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    border-bottom: 1px solid #e0e0e0;
    padding: 17px 20px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: -0.4px;
    text-transform: uppercase;
    color: #000;
    cursor: pointer;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .ma-footer__accordion-trigger[aria-expanded="true"] {
    border-bottom-color: transparent;
  }

  .ma-acc-icon {
    font-size: 20px;
    font-weight: 300;
    line-height: 1;
    display: inline-block;
    transition: transform 0.25s ease;
  }

  .ma-footer__accordion-trigger[aria-expanded="true"] .ma-acc-icon {
    transform: rotate(45deg);
  }

  .ma-footer__accordion-panel {
    display: none;
    padding: 4px 20px 18px;
    border-bottom: 1px solid #e0e0e0;
  }

  .ma-footer__accordion-panel.is-open {
    display: block;
  }

  .ma-footer__accordion-panel ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ma-footer__accordion-panel ul li a {
    font-size: 12px;
    color: #000;
    text-decoration: none;
    letter-spacing: -0.4px;
    text-transform: uppercase;
    line-height: 2.6;
    display: block;
  }

  /* Newsletter on mobile */
  .ma-footer__subscribe-mobile {
    padding: 30px 20px 36px;
    border-bottom: 1px solid #e0e0e0;
  }

  .ma-footer__signup-btn {
    width: 100%;
    padding: 14px;
  }

  /* Bottom bar mobile */
  .ma-footer__bottom {
    flex-direction: column;
    align-items: center;
    gap: 18px;
    padding: 26px 20px;
    text-align: center;
  }

  .ma-footer__brand {
    font-size: 17px;
    color: #000 !important;
    -webkit-text-fill-color: #000 !important;
    font-weight: 700 !important;
  }

  .ma-footer__bottom-right {
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .ma-footer__copyright {
    text-align: center;
    color: #000 !important;
    -webkit-text-fill-color: #000 !important;
    white-space: normal;
  }
}
{% endstylesheet %}

