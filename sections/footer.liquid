<script>
(function() {
  'use strict';

  var triggers = document.querySelectorAll('.ma-footer__accordion-trigger');
  triggers.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var isOpen = this.getAttribute('aria-expanded') === 'true';
      var panelId = this.getAttribute('aria-controls');
      var panel = document.getElementById(panelId);
      this.setAttribute('aria-expanded', String(!isOpen));
      if (panel) panel.classList.toggle('is-open', !isOpen);
    });
  });

  function applyLayout() {
    var mobile = window.innerWidth <= 768;
    var desktopCols = document.querySelector('.ma-footer__columns');
    if (desktopCols) desktopCols.style.display = mobile ? 'none' : 'grid';
    document.querySelectorAll('.ma-footer__accordion').forEach(function(el) {
      el.style.display = mobile ? 'block' : 'none';
    });
    var subMobile = document.querySelector('.ma-footer__subscribe-mobile');
    if (subMobile) subMobile.style.display = mobile ? 'block' : 'none';
  }

  applyLayout();
  window.addEventListener('resize', applyLayout);
})();
</script>

