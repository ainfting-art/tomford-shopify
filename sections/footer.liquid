{% comment %}
  Maison Amiir — custom footer (Tom Ford style)
  Hardened: no horizontal overflow / cropping, responsive side padding.
  Zones: 1) nav columns + newsletter  2) trust + payment bar  3) bottom bar
{% endcomment %}

{% stylesheet %}
/* === MAISON AMIIR FOOTER — TOM FORD STYLE === */

/* box-sizing + overflow guard so the footer can never be wider than the screen */
.ma-footer, .ma-footer * { box-sizing: border-box; }

.ma-footer {
  background: #fff;
  color: #000;
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  border-top: 1px solid #e0e0e0;
  width: 100%;
  max-width: 100%;
  overflow-x: hidden;
}

/* ── TOP INNER WRAPPER ── */
.ma-footer__inner {
  max-width: 1400px;
  margin: 0 auto;
  /* responsive side padding — shrinks gracefully instead of overflowing */
  padding: clamp(40px, 5vw, 80px) clamp(20px, 5vw, 80px) 0;
}

/* ── FOUR COLUMNS ROW (3 nav + 1 newsletter) ── */
.ma-footer__columns {
  display: grid;
  grid-template-columns: 1.1fr 1fr 1fr 1.35fr;
  gap: 44px;
  padding-bottom: clamp(40px, 5vw, 80px);
}

.ma-footer__col {
  min-width: 0;
}

.ma-footer__col-heading {
  font-size: 15px;
  font-weight: 700;
  letter-spacing: -0.4px;
  text-transform: uppercase;
  color: #000;
  margin: 0 0 16px;
  padding: 0;
}

.ma-footer__col ul {
  list-style: none;
  margin: 0;
  padding: 0;
}

.ma-footer__col ul li a {
  font-size: 13px;
  color: #000;
  text-decoration: none;
  letter-spacing: -0.4px;
  text-transform: uppercase;
  line-height: 2.5;
  display: block;
}

.ma-footer__col ul li a:hover {
  text-decoration: underline;
}

/* ── NEWSLETTER (4th column, same row as nav) ── */
.ma-footer__newsletter-subtext {
  font-size: 13px;
  color: #000;
  letter-spacing: -0.4px;
  line-height: 1.7;
  margin: 0 0 10px;
}

.ma-footer__email-input {
  display: block;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  border: 0.83px solid #b7b7b7;
  background: #fff;
  font-size: 12px;
  letter-spacing: -0.4px;
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  color: #000;
  padding: 12px 14px;
  outline: none;
  margin-bottom: 10px;
}

.ma-footer__email-input::placeholder {
  color: #aaa;
  text-transform: uppercase;
  letter-spacing: -0.5px;
}

.ma-footer__consent {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  margin-bottom: 18px;
}

.ma-footer__consent input[type="checkbox"] {
  margin-top: 2px;
  flex-shrink: 0;
  accent-color: #000;
  width: 13px;
  height: 13px;
  cursor: pointer;
}

.ma-footer__consent-label {
  font-size: 11px;
  color: #000;
  letter-spacing: -0.4px;
  line-height: 1.6;
}

.ma-footer__consent-label a {
  color: #000;
  text-decoration: underline;
}

.ma-footer__signup-btn {
  display: block;
  width: 100%;
  max-width: 100%;
  background: #000;
  color: #fff;
  border: none;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 14px;
  cursor: pointer;
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  transition: background 0.2s;
}

.ma-footer__signup-btn:hover {
  background: #333;
}

/* ── ZONE 2: TRUST + PAYMENT BAR (white-theme adaptation) ── */
.ma-footer__trust-wrap {
  border-top: 1px solid #e0e0e0;
  background: #fafafa;
}

.ma-footer__trust {
  max-width: 1400px;
  margin: 0 auto;
  padding: 14px clamp(20px, 5vw, 60px);
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
}

.ma-footer__trust-left {
  display: flex;
  align-items: center;
  gap: 8px;
}

.ma-footer__lock {
  color: #9b111e;
  flex-shrink: 0;
  display: block;
}

.ma-footer__trust-text {
  font-size: 10px;
  color: #555;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.ma-footer__trust-div {
  width: 1px;
  height: 14px;
  background: #d8d8d8;
  flex-shrink: 0;
}

.ma-footer__pay {
  display: flex;
  align-items: center;
  gap: 7px;
  flex-wrap: wrap;
}

.ma-footer__pay-pill {
  background: #fff;
  border: 1px solid #d8d8d8;
  border-radius: 3px;
  padding: 3px 9px;
  font-size: 9px;
  font-weight: 700;
  color: #555;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  line-height: 1.7;
}

.ma-footer__pay-pill--rz {
  display: flex;
  align-items: center;
  gap: 5px;
}

.ma-footer__rz-dot {
  width: 6px;
  height: 6px;
  background: #9b111e;
  border-radius: 50%;
  flex-shrink: 0;
}

.ma-footer__ssl {
  font-size: 10px;
  color: #888;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-left: auto;
}

/* ── BOTTOM BAR ── */
.ma-footer__bottom-wrap {
  border-top: 1px solid #e0e0e0;
}

.ma-footer__bottom {
  max-width: 1400px;
  margin: 0 auto;
  padding: 22px clamp(20px, 5vw, 60px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;           /* wrap instead of clipping on mid widths */
  gap: 16px;
}

.ma-footer__brand {
  display: inline-flex;
  align-items: center;
  font-family: 'Sinoreta', serif;
  font-size: 25px;
  font-weight: 700 !important;
  color: #000 !important;
  -webkit-text-fill-color: #000 !important;
  letter-spacing: 0.12em;
  text-decoration: none;
  text-transform: uppercase;
  flex-shrink: 0;
}

.ma-footer__logo-img {
  display: block;
  height: 38px;
  width: auto;
  max-width: 100%;
}

.ma-footer__bottom-right {
  display: flex;
  align-items: center;
  gap: 30px;
  flex-wrap: wrap;
}

.ma-footer__bottom-text {
  text-align: right;
}

.ma-footer__social {
  display: flex;
  align-items: center;
  gap: 18px;
}

.ma-footer__social a {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #000;
  line-height: 1;
  transition: opacity 0.2s;
}

.ma-footer__social a:hover {
  opacity: 0.5;
}

.ma-footer__copyright {
  font-size: 13px;
  color: #000 !important;
  -webkit-text-fill-color: #000 !important;
  letter-spacing: -0.4px;
  white-space: nowrap;
}

.ma-footer__crafted {
  font-size: 10px;
  color: #888;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin: 4px 0 0;
}

/* ── MOBILE ── */
@media (max-width: 768px) {
  .ma-footer__inner {
    padding: 0;
  }

  .ma-footer__columns {
    display: none;
  }

  /* Accordion items */
  .ma-footer__accordion {
    border-top: 1px solid #e0e0e0;
  }

  .ma-footer__accordion-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    border-bottom: 1px solid #e0e0e0;
    padding: 17px 20px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: -0.4px;
    text-transform: uppercase;
    color: #000;
    cursor: pointer;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .ma-footer__accordion-trigger[aria-expanded="true"] {
    border-bottom-color: transparent;
  }

  .ma-acc-icon {
    font-size: 20px;
    font-weight: 300;
    line-height: 1;
    display: inline-block;
    transition: transform 0.25s ease;
  }

  .ma-footer__accordion-trigger[aria-expanded="true"] .ma-acc-icon {
    transform: rotate(45deg);
  }

  .ma-footer__accordion-panel {
    display: none;
    padding: 4px 20px 18px;
    border-bottom: 1px solid #e0e0e0;
  }

  .ma-footer__accordion-panel.is-open {
    display: block;
  }

  .ma-footer__accordion-panel ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ma-footer__accordion-panel ul li a {
    font-size: 12px;
    color: #000;
    text-decoration: none;
    letter-spacing: -0.4px;
    text-transform: uppercase;
    line-height: 2.6;
    display: block;
  }

  /* Newsletter on mobile */
  .ma-footer__subscribe-mobile {
    padding: 30px 20px 36px;
    border-bottom: 1px solid #e0e0e0;
  }

  .ma-footer__signup-btn {
    width: 100%;
    padding: 14px;
  }

  /* Trust bar mobile — stacks vertically, sits between newsletter and bottom bar */
  .ma-footer__trust {
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-align: center;
    padding: 18px 20px;
  }

  .ma-footer__trust-div {
    display: none;
  }

  .ma-footer__pay {
    justify-content: center;
  }

  .ma-footer__ssl {
    margin-left: 0;
  }

  /* Bottom bar mobile */
  .ma-footer__bottom {
    flex-direction: column;
    align-items: center;
    gap: 18px;
    padding: 26px 20px;
    text-align: center;
  }

  .ma-footer__brand {
    font-size: 17px;
    color: #000 !important;
    -webkit-text-fill-color: #000 !important;
    font-weight: 700 !important;
  }

  .ma-footer__logo-img {
    height: 32px;
  }

  .ma-footer__bottom-right {
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .ma-footer__bottom-text {
    text-align: center;
  }

  .ma-footer__copyright {
    text-align: center;
    color: #000 !important;
    -webkit-text-fill-color: #000 !important;
    white-space: normal;
  }

  .ma-footer__crafted {
    text-align: center;
  }
}
{% endstylesheet %}

