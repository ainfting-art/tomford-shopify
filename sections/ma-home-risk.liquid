{%- comment -%}
  MAISON AMIIR — The Maison Promise (unified grid).
  One system across breakpoints: centred header -> four-promise grid -> founder's seal.
  Desktop reflows the grid 4-across with vertical hairline dividers + centred logo watermark;
  mobile is a compact one-screen 2x2 with a cross divider. Each cell carries a faint 01-04 numeral.
  Serif = Cormorant Garamond (Georgia fallback); labels = Marcellus. base.css h-lock countered on <h2> only.
{%- endcomment -%}

<section class="ma-pm" id="ma-pm-{{ section.id }}">
  <img class="ma-pm__logo" src="https://maisonamiir.com/cdn/shop/files/MAISON-LOGO-NEW.png?v=1775626552&width=800" alt="" aria-hidden="true" loading="lazy">
  <div class="ma-pm__in">
    <div class="ma-pm__head">
      {%- if section.settings.eyebrow != blank -%}<p class="ma-pm__k">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="ma-pm__h">{{ section.settings.heading | escape }}</h2>{%- endif -%}
      {%- if section.settings.subline != blank -%}<p class="ma-pm__s">{{ section.settings.subline | escape }}</p>{%- endif -%}
    </div>

    <div class="ma-pm__cards">
      <div class="ma-pm__c">
        <span class="ma-pm__num" aria-hidden="true">01</span>
        <span class="ma-pm__ic" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M9 2.5h6M10 2.5v4.6L6.5 15.1A3 3 0 0 0 9.3 20.9h5.4a3 3 0 0 0 2.8-5.8L14 7.1V2.5"/><path d="M8 14.5h8"/></svg></span>
        {%- if section.settings.k1 != blank -%}<p class="ma-pm__kick">{{ section.settings.k1 | escape }}</p>{%- endif -%}
        <p class="ma-pm__t">{{ section.settings.t1 | escape }}</p>
        <p class="ma-pm__d">{{ section.settings.d1 | escape }}</p>
      </div>
      <div class="ma-pm__c">
        <span class="ma-pm__num" aria-hidden="true">02</span>
        <span class="ma-pm__ic" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 3l7 2.6v5.1c0 4.4-3 7.4-7 8.8-4-1.4-7-4.4-7-8.8V5.6L12 3z"/><path d="M9 12l2 2 4-4.2"/></svg></span>
        {%- if section.settings.k2 != blank -%}<p class="ma-pm__kick">{{ section.settings.k2 | escape }}</p>{%- endif -%}
        <p class="ma-pm__t">{{ section.settings.t2 | escape }}</p>
        <p class="ma-pm__d">{{ section.settings.d2 | escape }}</p>
      </div>
      <div class="ma-pm__c">
        <span class="ma-pm__num" aria-hidden="true">03</span>
        <span class="ma-pm__ic" aria-hidden="true"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="4.1"/><path d="M12 2v2.3M12 19.7V22M2 12h2.3M19.7 12H22M4.9 4.9l1.6 1.6M17.5 17.5l1.6 1.6M19.1 4.9l-1.6 1.6M6.5 17.5l-1.6 1.6"/></svg></span>
        {%- if section.settings.k3 != blank -%}<p class="ma-pm__kick">{{ section.settings.k3 | escape }}</p>{%- endif -%}
        <p class="ma-pm__t">{{ section.settings.t3 | escape }}</p>
        <p class="ma-pm__d">{{ section.settings.d3 | escape }}</p>
      </div>
      <div class="ma-pm__c">
        <span class="ma-pm__num" aria-hidden="true">04</span>
        <span class="ma-pm__ic" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 3s6 6.6 6 11a6 6 0 0 1-12 0c0-4.4 6-11 6-11z"/><path d="M9.6 14.2a2.6 2.6 0 0 0 2.1 2.4"/></svg></span>
        {%- if section.settings.k4 != blank -%}<p class="ma-pm__kick">{{ section.settings.k4 | escape }}</p>{%- endif -%}
        <p class="ma-pm__t">{{ section.settings.t4 | escape }}</p>
        <p class="ma-pm__d">{{ section.settings.d4 | escape }}</p>
      </div>
    </div>

    {%- if section.settings.sign != blank -%}
      <div class="ma-pm__seal">
        <div class="ma-pm__seal-rule" aria-hidden="true"></div>
        <p class="ma-pm__sign">{{ section.settings.sign }} <b>&mdash; Amiir</b></p>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Marcellus&display=swap');

  #shopify-section-{{ section.id }}{ opacity:1 !important; transform:none !important; }

  #ma-pm-{{ section.id }}.ma-pm{
    --pm-cream:#F4EEE1; --pm-ink:#171310; --pm-ink2:rgba(23,19,16,.70);
    --pm-gold:#A8894E; --pm-goldlt:#C6A15B; --pm-burg:#6E1220; --pm-line:rgba(23,19,16,.14);
    --pm-serif:'Cormorant Garamond',Georgia,'Times New Roman',serif;
    --pm-label:'Marcellus',Georgia,serif;
    position:relative; overflow:hidden; background:var(--pm-cream); color:var(--pm-ink);
    font-family:var(--pm-serif);
    border-top:1px solid var(--pm-line); border-bottom:1px solid var(--pm-line);
  }

  /* logo watermark — desktop only, centred */
  #ma-pm-{{ section.id }} .ma-pm__logo{ display:none; }

  #ma-pm-{{ section.id }} .ma-pm__in{ position:relative; z-index:1; }

  /* ---- header ---- */
  #ma-pm-{{ section.id }} .ma-pm__head{ text-align:center; padding:30px 22px 6px; }
  #ma-pm-{{ section.id }} .ma-pm__k{
    font-family:var(--pm-label); font-size:9.5px; letter-spacing:.34em; text-transform:uppercase;
    color:var(--pm-burg); margin:0 0 12px;
  }
  #ma-pm-{{ section.id }} .ma-pm__h{
    font-family:var(--pm-serif) !important; font-weight:500 !important;
    text-transform:none !important; letter-spacing:.005em !important;
    font-size:30px; line-height:1.05; color:var(--pm-ink); margin:0;
  }
  #ma-pm-{{ section.id }} .ma-pm__s{
    font-family:var(--pm-serif); font-style:italic; font-size:14px; line-height:1.45;
    color:var(--pm-ink2); margin:9px auto 0; max-width:34ch;
  }

  /* ---- grid (mobile base: 2 columns) ---- */
  #ma-pm-{{ section.id }} .ma-pm__cards{ display:grid; grid-template-columns:1fr 1fr; margin:22px 0 0; }
  #ma-pm-{{ section.id }} .ma-pm__c{
    position:relative; overflow:hidden; padding:20px 15px 22px; text-align:left;
    border-top:1px solid var(--pm-line);
  }
  #ma-pm-{{ section.id }} .ma-pm__c:nth-child(odd){ border-right:1px solid var(--pm-line); }
  #ma-pm-{{ section.id }} .ma-pm__num{
    position:absolute; right:6px; bottom:-14px; z-index:0; pointer-events:none;
    font-family:var(--pm-serif); font-weight:600; font-size:70px; line-height:1;
    color:#6e122012;
  }
  #ma-pm-{{ section.id }} .ma-pm__ic{
    display:block; position:relative; z-index:1; width:26px; height:26px; color:var(--pm-gold); margin:0 0 12px;
  }
  #ma-pm-{{ section.id }} .ma-pm__ic svg{
    width:100%; height:100%; display:block; fill:none; stroke:currentColor;
    stroke-width:1.15; stroke-linecap:round; stroke-linejoin:round;
  }
  #ma-pm-{{ section.id }} .ma-pm__kick{
    position:relative; z-index:1; font-family:var(--pm-label); font-size:8.5px; letter-spacing:.22em;
    text-transform:uppercase; color:var(--pm-gold); margin:0 0 7px;
  }
  #ma-pm-{{ section.id }} .ma-pm__t{
    position:relative; z-index:1; font-family:var(--pm-serif); font-weight:600; font-size:19px;
    line-height:1.1; color:var(--pm-ink); margin:0 0 9px;
  }
  #ma-pm-{{ section.id }} .ma-pm__d{
    position:relative; z-index:1; font-family:var(--pm-serif); font-size:13.5px; line-height:1.4;
    color:var(--pm-ink2); margin:0;
  }

  /* ---- seal ---- */
  #ma-pm-{{ section.id }} .ma-pm__seal{ position:relative; z-index:1; text-align:center; padding:16px 20px 26px; border-top:1px solid var(--pm-line); }
  #ma-pm-{{ section.id }} .ma-pm__seal-rule{ height:1px; width:88px; margin:0 auto 12px; background:linear-gradient(90deg,transparent,var(--pm-gold),transparent); }
  #ma-pm-{{ section.id }} .ma-pm__sign{ font-family:var(--pm-serif); font-weight:500; font-size:16px; color:var(--pm-ink); margin:0; }
  #ma-pm-{{ section.id }} .ma-pm__sign b{ font-weight:400; font-style:italic; color:var(--pm-burg); }

  /* ---- DESKTOP: 4 across + centred logo watermark ---- */
  @media (min-width:900px){
    #ma-pm-{{ section.id }} .ma-pm__logo{
      display:block; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);
      width:min(50%,560px); opacity:.05; z-index:0; pointer-events:none;
    }
    #ma-pm-{{ section.id }} .ma-pm__in{ max-width:1180px; margin:0 auto; padding:8px 40px 4px; }
    #ma-pm-{{ section.id }} .ma-pm__head{ padding:60px 22px 8px; }
    #ma-pm-{{ section.id }} .ma-pm__k{ font-size:11px; letter-spacing:.42em; color:var(--pm-gold); margin-bottom:20px; }
    #ma-pm-{{ section.id }} .ma-pm__h{ font-size:clamp(40px,4vw,56px); }
    #ma-pm-{{ section.id }} .ma-pm__s{ font-size:19px; max-width:56ch; margin-top:18px; }
    #ma-pm-{{ section.id }} .ma-pm__cards{
      grid-template-columns:repeat(4,1fr); margin:44px 0 0;
      border-top:1px solid var(--pm-line); border-bottom:1px solid var(--pm-line);
    }
    #ma-pm-{{ section.id }} .ma-pm__c{ border-top:0; border-right:0; padding:38px 30px 42px; }
    #ma-pm-{{ section.id }} .ma-pm__c + .ma-pm__c{ border-left:1px solid var(--pm-line); }
    #ma-pm-{{ section.id }} .ma-pm__num{ right:14px; bottom:-20px; font-size:96px; }
    #ma-pm-{{ section.id }} .ma-pm__ic{ width:30px; height:30px; margin-bottom:18px; }
    #ma-pm-{{ section.id }} .ma-pm__kick{ font-size:10px; letter-spacing:.26em; margin-bottom:10px; }
    #ma-pm-{{ section.id }} .ma-pm__t{ font-size:23px; margin-bottom:12px; }
    #ma-pm-{{ section.id }} .ma-pm__d{ font-size:16px; line-height:1.55; }
    #ma-pm-{{ section.id }} .ma-pm__seal{ padding:34px 20px 44px; }
    #ma-pm-{{ section.id }} .ma-pm__seal-rule{ width:120px; margin-bottom:20px; }
    #ma-pm-{{ section.id }} .ma-pm__sign{ font-size:clamp(20px,2vw,26px); }
  }

  @media (prefers-reduced-motion:reduce){
    #ma-pm-{{ section.id }} *{ transition:none !important; }
  }
</style>

{% schema %}
{
  "name": "MA — Maison Promise",
  "tag": "section",
  "class": "ma-risk-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Buy Without a Doubt" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Maison Promise" },
    { "type": "text", "id": "subline", "label": "Sub-line", "default": "Wear it first. Decide after. A scent is personal — you should never commit to one you haven't lived with." },
    { "type": "header", "content": "Card 1 — The Tester" },
    { "type": "text", "id": "k1", "label": "Kicker", "default": "The Tester" },
    { "type": "text", "id": "t1", "label": "Title", "default": "A Tester in Every Order" },
    { "type": "textarea", "id": "d1", "label": "Promise", "default": "Live with the scent for days before you ever break the seal on the bottle." },
    { "type": "header", "content": "Card 2 — The Return" },
    { "type": "text", "id": "k2", "label": "Kicker", "default": "The Return" },
    { "type": "text", "id": "t2", "label": "Title", "default": "Seven Days to Decide" },
    { "type": "textarea", "id": "d2", "label": "Promise", "default": "Return the sealed bottle within seven days for a full refund. No questions asked." },
    { "type": "header", "content": "Card 3 — The Climate" },
    { "type": "text", "id": "k3", "label": "Kicker", "default": "The Climate" },
    { "type": "text", "id": "t3", "label": "Title", "default": "Crafted for India" },
    { "type": "textarea", "id": "d3", "label": "Promise", "default": "Built for Indian skin, heat and humidity — not London winters." },
    { "type": "header", "content": "Card 4 — The Formula" },
    { "type": "text", "id": "k4", "label": "Kicker", "default": "The Formula" },
    { "type": "text", "id": "t4", "label": "Title", "default": "The Oil is Everything" },
    { "type": "textarea", "id": "d4", "label": "Promise", "default": "Most of what you pay goes into the oil — not the bottle, the box, or the campaign." },
    { "type": "header", "content": "Signature" },
    { "type": "text", "id": "sign", "label": "Sign-off (— Amiir is appended)", "default": "The house takes the risk." }
  ],
  "presets": [{ "name": "MA — Maison Promise" }]
}
{% endschema %}
