{% comment %} MAISON AMIIR — §4 Value Story: solid black band, 4 pillars {% endcomment %}

<div class="ma-value">
  {%- if section.settings.bg_video != null -%}
    <div class="ma-value__media" aria-hidden="true">
      {{ section.settings.bg_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, preload: 'metadata' }}
    </div>
  {%- elsif section.settings.bg_image != blank -%}
    <div class="ma-value__media" aria-hidden="true">
      {{ section.settings.bg_image | image_url: width: 2400 | image_tag: loading: 'lazy', alt: '' }}
    </div>
  {%- endif -%}
  <div class="ma-value__scrim" aria-hidden="true"></div>

  <div class="ma-value__inner">
  <p class="ma-value__overline ma-home-reveal">{{ section.settings.overline }}</p>
  <h2 class="ma-value__h2 ma-home-reveal">{{ section.settings.heading }}</h2>
  <p class="ma-value__lede ma-home-reveal">{{ section.settings.lede }}</p>

  <div class="ma-value__pillars">
    {%- for block in section.blocks -%}
      <div class="ma-value__pillar ma-home-reveal" {{ block.shopify_attributes }}>
        <div class="ma-value__pillar-icon" aria-hidden="true">{{ block.settings.icon }}</div>
        <h3 class="ma-value__pillar-title">{{ block.settings.title }}</h3>
        <p class="ma-value__pillar-desc">{{ block.settings.text }}</p>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.settings.closing != blank -%}
    <p class="ma-value__closing ma-home-reveal">{{ section.settings.closing }}</p>
  {%- endif -%}
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} { opacity: 1 !important; transform: none !important; }

  .ma-value {
    position: relative;
    overflow: hidden;
    background: #eef3fbff;
    color: #fff;
    text-align: center;
    padding: clamp(3.5rem, 8vw, 5.5rem) clamp(1.2rem, 5vw, 3.5rem);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }
  .ma-value *, .ma-value *::before, .ma-value *::after { box-sizing: border-box; }

  .ma-value__media { position: absolute; inset: 0; z-index: 0; }
  .ma-value__media video, .ma-value__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ma-value__scrim {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(to bottom, rgba(0, 0, 0, 0.55) 0%, rgba(0,0,0,.25) 45%, rgba(0,0,0,.6) 100%),
      rgba(0,0,0, {{ section.settings.overlay | default: 65 | divided_by: 100.0 }});
  }
  .ma-value__inner { position: relative; z-index: 2; }
  .ma-value__media ~ .ma-value__inner .ma-value__overline,
  .ma-value__media ~ .ma-value__inner .ma-value__h2,
  .ma-value__media ~ .ma-value__inner .ma-value__lede,
  .ma-value__media ~ .ma-value__inner .ma-value__closing { text-shadow: 0 1px 18px #FFD700; }
  .ma-value__media ~ .ma-value__inner .ma-value__lede { color: rgba(255,255,255,.82); }
  .ma-value__media ~ .ma-value__inner .ma-value__pillar { background: #6e122012; }
  .ma-value__media ~ .ma-value__inner .ma-value__pillar-desc { color: rgba(255,255,255,.62); }

  .ma-value__overline { font-size: .72rem; letter-spacing: .32em; text-indent: .32em; text-transform: uppercase; color: rgba(255,255,255,.45); margin: 0 0 1.1rem; }
  .ma-value__h2 { font-family: 'Sinoreta', Georgia, serif; font-size: clamp(1.9rem, 4.4vw, 2.75rem); font-weight: 300; letter-spacing: .03em; line-height: 1.25; margin: 0 0 1.2rem; color: #fff; }
  .ma-value__lede { font-size: clamp(.95rem, 1.4vw, 1.08rem); font-weight: 300; line-height: 1.9; letter-spacing: .01em; color: rgba(255,255,255,.66); max-width: 620px; margin: 0 auto clamp(2.2rem, 5vw, 3rem); }

  .ma-value__pillars {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.1);
    max-width: 1080px;
    margin: 0 auto clamp(1.8rem, 4vw, 2.4rem);
  }
  .ma-value__pillar { background: #eef3fbff; padding: clamp(1.6rem, 3vw, 2rem) 1.3rem; }
  .ma-value__pillar-icon { font-size: 1.35rem; margin-bottom: .8rem; opacity: .6; }
  /* Helvetica here: Sinoreta lacks proper numerals ("30" breaks) */
  .ma-value__pillar-title { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: clamp(.82rem, 1.2vw, .92rem); font-weight: 400; letter-spacing: .2em; text-transform: uppercase; color: #fff; margin: 0 0 .55rem; line-height: 1.5; }
  .ma-value__pillar-desc { font-size: clamp(.82rem, 1.15vw, .9rem); font-weight: 300; color: rgba(255,255,255,.5); line-height: 1.7; margin: 0; }

  .ma-value__closing { font-size: .78rem; letter-spacing: .26em; text-indent: .26em; text-transform: uppercase; color: rgba(255,255,255,.5); margin: 0; }

  @media (max-width: 899px) {
    .ma-value__pillars { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 479px) {
    .ma-value__pillars { grid-template-columns: 1fr 1fr; }
    .ma-value__pillar { padding: 1.3rem .9rem; }
  }
</style>


{% schema %}
{
  "name": "MA Value Story",
  "tag": "section",
  "settings": [
    { "type": "video", "id": "bg_video", "label": "Background video (wins over image)" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "range", "id": "overlay", "label": "Dark overlay %", "min": 0, "max": 95, "step": 5, "default": 65 },
    { "type": "text", "id": "overline", "label": "Overline", "default": "The Maison Amiir Difference" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Luxury, Without the Markup" },
    { "type": "textarea", "id": "lede", "label": "Lede", "default": "A great fragrance is mostly oil and intention — not the marble store or the magazine campaign. We put the money where you smell it: 30% extrait concentration, international fragrance oils, made in small batches." },
    { "type": "text", "id": "closing", "label": "Closing line", "default": "Extrait Concentration · From ₹2,200" }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon character", "default": "◈" },
        { "type": "text", "id": "title", "label": "Title", "default": "30% Extrait Oil" },
        { "type": "text", "id": "text", "label": "Text", "default": "The same concentration tier as the houses that inspire us." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "MA Value Story",
      "blocks": [
        { "type": "pillar", "settings": { "icon": "◈", "title": "30% Extrait Oil", "text": "The same concentration tier as the houses that inspire us." } },
        { "type": "pillar", "settings": { "icon": "✦", "title": "International Fragrance Oils", "text": "Sourced from the same global suppliers as luxury perfumery." } },
        { "type": "pillar", "settings": { "icon": "⬡", "title": "Small Batch Crafted", "text": "Made to order, never mass-warehoused." } },
        { "type": "pillar", "settings": { "icon": "◎", "title": "No Boutique Markup", "text": "You pay for the scent, not the storefront." } }
      ]
    }
  ]
}
{% endschema %}
